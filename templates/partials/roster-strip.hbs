{{!-- Roster Strip Partial: [AFK toggle] | [Players] ... [GM chip] --}}
{{#if roster.length}}
<div class="roster-strip">
    {{!-- AFK button toggle: tall card style --}}
    <div class="roster-afk-btn {{#if selfAfk}}active{{/if}}" data-action="afkToggle" data-roster-id="{{selfAfkId}}"
        title="{{#if selfAfk}}Mark yourself present{{else}}Step away from the table{{/if}}" role="button" tabindex="0">
        <i class="fas fa-mug-hot"></i>
        <span>AFK</span>
    </div>

    <div class="roster-divider"></div>

    {{!-- Player chips --}}
    <div class="roster-players">
        {{#each roster}}
        <div class="roster-chip {{#if isSelected}}selected{{/if}} {{source}} {{#unless isOwner}}not-owned{{/unless}} {{#if isAfk}}afk{{/if}}"
            data-roster-id="{{id}}" title="{{fullName}}">
            {{#if isAfk}}
            <span class="roster-afk-portrait"><i class="fas fa-mug-hot"></i></span>
            {{else}}
            <img class="roster-portrait" src="{{img}}" alt="{{name}}">
            {{/if}}
            <span class="roster-name">{{name}}</span>
            {{#if activityLabel}}<span class="roster-activity-label" title="{{activityLabel}}">{{activityLabel}}</span>{{/if}}
            <span class="roster-status">
                {{#if pendingRoll}}
                <i class="fas fa-dice-d20 roster-roll-pending" title="Awaiting roll"></i>
                {{else if rolledResult}}
                <i class="fas fa-check-circle roster-roll-done" title="Rolled: {{rolledResult}}"></i>
                {{else if exhaustion}}
                <i class="fas fa-skull roster-exhaustion" title="Exhaustion {{exhaustion}}"></i>
                {{else if (eq source 'player')}}
                <i class="fas fa-check-circle roster-resolved" title="Activity chosen"></i>
                {{else if (eq source 'gm')}}
                <i class="fas fa-crown roster-gm-override" title="GM Override"></i>
                {{else}}
                <i class="fas fa-clock roster-waiting" title="Waiting"></i>
                {{/if}}
            </span>
        </div>
        {{/each}}
    </div>

    {{!-- GM Chip: right --}}
    <div class="roster-chip gm-chip {{#if gmRosterChip.isAfk}}afk{{/if}}"
        data-roster-id="gm" title="{{gmRosterChip.fullName}}">
        {{#if gmRosterChip.isAfk}}
        <span class="roster-afk-portrait"><i class="fas fa-mug-hot"></i></span>
        {{else}}
        <span class="roster-gm-icon"><i class="fas fa-dice-d20"></i></span>
        {{/if}}
        <span class="roster-name">{{gmRosterChip.name}}</span>
        <span class="roster-status">
            {{#if gmRosterChip.pendingRoll}}
            <i class="fas fa-dice-d20 roster-roll-pending" title="GM must roll"></i>
            {{else if gmRosterChip.rolledResult}}
            <i class="fas fa-check-circle roster-roll-done" title="Rolled"></i>
            {{/if}}
        </span>
    </div>
</div>
{{/if}}

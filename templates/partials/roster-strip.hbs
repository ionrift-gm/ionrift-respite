{{!-- Roster strip: selection + activity; .afk + fa-mug-hot badge (same language as TABLE AFK panel) --}}
{{#if roster.length}}
<div class="roster-strip">
    <div class="roster-players">
        {{#each roster}}
        <div class="roster-chip {{#if isSelected}}selected{{/if}} {{source}} {{#unless isOwner}}not-owned{{/unless}} {{#if isAfk}}afk{{/if}} {{#if mealStatus}}meal-{{mealStatus.state}}{{/if}}"
            data-roster-id="{{id}}" data-tooltip="{{fullName}}">
            <span class="roster-portrait-wrap">
                <img class="roster-portrait" src="{{img}}" alt="{{name}}">
                {{#if isAfk}}<span class="roster-afk-mug" aria-hidden="true"><i class="fas fa-mug-hot"></i></span>{{/if}}
                {{#if isBeddedDown}}<span class="roster-zzz" aria-hidden="true">Zzz</span>{{/if}}
            </span>
            <span class="roster-name">{{name}}</span>
            {{#if activityLabel}}<span class="roster-activity-label" data-tooltip="{{activityLabel}}">{{activityLabel}}</span>{{/if}}
            <span class="roster-status">
                {{#if (eq rollMode 'force-pass')}}
                <i class="fas fa-check roster-roll-force-pass" data-tooltip="Auto-pass (no roll needed)"></i>
                {{else if (eq rollMode 'force-fail')}}
                <i class="fas fa-times roster-roll-force-fail" data-tooltip="Auto-fail (no roll needed)"></i>
                {{else if pendingRoll}}
                <i class="fas fa-dice-d20 roster-roll-pending" data-tooltip="Awaiting roll{{#if (eq rollMode 'advantage')}} · Advantage{{else if (eq rollMode 'disadvantage')}} · Disadvantage{{/if}}"></i>
                {{#if (eq rollMode 'advantage')}}<i class="fas fa-angle-up roster-roll-adv" aria-hidden="true"></i>{{/if}}
                {{#if (eq rollMode 'disadvantage')}}<i class="fas fa-angle-down roster-roll-dis" aria-hidden="true"></i>{{/if}}
                {{else if rolledResult}}
                <i class="fas fa-check-circle roster-roll-done" data-tooltip="Rolled: {{rolledResult}}"></i>
                {{else if exhaustion}}
                <i class="fas fa-skull roster-exhaustion" data-tooltip="Exhaustion {{exhaustion}}"></i>
                {{else if (eq source 'player')}}
                <i class="fas fa-check-circle roster-resolved" data-tooltip="Activity chosen"></i>
                {{else if (eq source 'gm')}}
                <i class="fas fa-crown roster-gm-override" data-tooltip="GM Override"></i>
                {{else}}
                <i class="fas fa-clock roster-waiting" data-tooltip="Waiting"></i>
                {{/if}}
            </span>
            {{#if mealStatus}}
            <span class="roster-meal-status {{mealStatus.state}}" data-tooltip="{{mealStatus.tooltip}}">
                {{#if mealStatus.submitted}}
                <i class="fas fa-check-circle" aria-hidden="true"></i><span class="rms-label">sent</span>
                {{else}}
                <i class="fas fa-drumstick-bite {{#if mealStatus.foodOk}}ok{{else}}miss{{/if}}" aria-hidden="true"></i>
                <i class="fas fa-tint {{#if mealStatus.waterOk}}ok{{else}}miss{{/if}}" aria-hidden="true"></i>
                {{/if}}
            </span>
            {{/if}}
        </div>
        {{/each}}
    </div>
</div>
{{/if}}

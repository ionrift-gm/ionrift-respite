{{!-- Workbench identify: Detect Magic, casters, scan, focus/taste, submit, acknowledgement (station dialog + short rest) --}}
<div class="station-workbench-identify-embed station-identify-embed identify-tab"
     data-workbench-actor-id="{{workbenchIdentifyActorId}}">
    <div class="station-identify-toolbar">
        {{#if canShowDetectMagicScanButton}}
        <button type="button" class="btn-detect-magic" data-action="stationDetectMagicScan"
            {{#if detectMagicScanButtonTitle}}title="{{detectMagicScanButtonTitle}}"{{/if}}>
            <i class="fas fa-eye" aria-hidden="true"></i>
            <span class="btn-detect-magic-text">{{detectMagicScanButtonLabel}}</span>
        </button>
        {{/if}}
    </div>
    {{#if identifyCasters.length}}
    <div class="identify-caster-advisory">
        <i class="fas fa-hat-wizard"></i>
        {{#each identifyCasters}}{{#unless @first}}, {{/unless}}{{name}}{{/each}}
        can cast Identify (ritual, free)
    </div>
    {{/if}}
    {{#if detectMagicCasters.length}}
    <div class="identify-caster-advisory detect-magic-advisory">
        <i class="fas fa-eye"></i>
        {{#each detectMagicCasters}}{{#unless @first}}, {{/unless}}{{name}}{{/each}}
        can cast Detect Magic for the group aura pass
    </div>
    {{/if}}

    {{#if isShortRestWorkbench}}
    <p class="wb-ident-hint">From the open character sheet, drag unidentified items to Focus (one non-potion) or Potions. Submit applies all staged changes. GM: roster strip picks whose bench is active.</p>
    {{else}}
    <p class="wb-ident-hint">From this sheet's inventory, drag to Focus (one non-potion) or Potions. Submit applies all staged changes.</p>
    {{/if}}
    <div class="identify-scroll-area station-identify-scroll wb-ident-scroll">
    <div class="meal-drop-columns wb-ident-drop-columns">
        <div class="meal-panel wb-ident-gear-panel{{#if workbenchFocusExhausted}} wb-ident-exhausted{{/if}}">
            <span class="panel-label">Focus
                {{#if workbenchFocusExhausted}}<span class="wb-ident-used-badge">Used</span>{{/if}}
            </span>
            <div class="wb-ident-gear-slot-wrap">
                <div class="meal-drop-zone wb-ident-drop-zone gear-focus-drop-zone {{#if workbenchGearChip}}filled{{/if}}
                    {{#if workbenchFocusExhausted}}wb-ident-zone-blocked{{/if}}"
                    data-wb-zone="gear"
                    title="{{#if workbenchFocusExhausted}}Focus identify already used this rest{{else}}Drop one non-potion item from the character sheet here. Click the circle to clear.{{/if}}">
                    <div class="drop-zone-silhouette">
                        {{#if workbenchGearChip}}
                        <img src="{{workbenchGearChip.img}}" alt="" class="drop-zone-item-icon" onerror="this.onerror=null;this.src='icons/svg/mystery-man.svg'">
                        {{else}}
                        <i class="fas fa-hand-holding drop-zone-gear-sil"></i>
                        {{/if}}
                    </div>
                </div>
            </div>
        </div>
        <div class="meal-panel wb-ident-potion-panel">
            <span class="panel-label">Potions</span>
            <div class="wb-ident-potion-slot-wrap">
                <div class="meal-drop-zone wb-ident-drop-zone potion-taste-drop-zone {{#if workbenchPotionChips.length}}filled{{/if}}"
                     data-wb-zone="potion" title="Drop potions from the character sheet here to add tastes.">
                    <div class="drop-zone-silhouette">
                        {{#if workbenchPotionChips.length}}
                        <span class="wb-ident-potion-count">{{workbenchPotionChips.length}}</span>
                        {{else}}
                        <i class="fas fa-flask drop-zone-potion-sil"></i>
                        {{/if}}
                    </div>
                </div>
            </div>
            {{#if workbenchPotionChips.length}}
            <div class="wb-ident-chip-row">
                {{#each workbenchPotionChips}}
                <button type="button" class="wb-ident-chip-btn" data-action="workbenchIdentifyRemovePotion" data-item-id="{{itemId}}" title="Remove from list">
                    <img src="{{img}}" alt="" class="wb-ident-chip-img" onerror="this.onerror=null;this.src='icons/svg/mystery-man.svg'">
                    <span>{{label}}</span>
                    <i class="fas fa-times wb-ident-chip-x" aria-hidden="true"></i>
                </button>
                {{/each}}
            </div>
            {{/if}}
        </div>
    </div>
    <div class="station-meal-submit-row wb-ident-submit-row">
        <button type="button" class="station-meal-submit-btn" data-action="submitWorkbenchIdentify"
            data-workbench-actor-id="{{workbenchIdentifyActorId}}"
            {{#if workbenchSubmitLocked}}disabled{{/if}}>Submit identify</button>
    </div>
    </div>

    {{#if workbenchIdentifyAcknowledgement}}
    <div class="wb-ident-ack-overlay" role="dialog" aria-modal="true">
        <div class="wb-ident-ack-card wb-ident-ack-fx">
            <div class="wb-ident-ack-title" id="wb-ident-ack-heading"><i class="fas fa-scroll"></i> Revelation</div>
            <p class="wb-ident-ack-lead">Names and properties resolve for this rest.</p>
            {{#each workbenchIdentifyAcknowledgement.items}}
            <div class="wb-ident-ack-row">
                <img src="{{img}}" alt="" class="wb-ident-ack-img" onerror="this.onerror=null;this.src='icons/svg/mystery-man.svg'">
                <div class="wb-ident-ack-meta">
                    <span class="wb-ident-ack-name">{{name}}</span>
                    {{#if requiresAttunement}}<span class="magic-attune-hint">Requires attunement</span>{{/if}}
                </div>
            </div>
            {{/each}}
            <button type="button" class="station-meal-submit-btn wb-ident-ack-btn" data-action="dismissWorkbenchIdentifyAck"
                data-workbench-actor-id="{{workbenchIdentifyActorId}}"
                {{#unless workbenchAckRevealReady}} disabled title="Brief pause before you continue"{{/unless}}>
                {{#if workbenchAckRevealReady}}Continue{{else}}Wait...{{/if}}
            </button>
        </div>
    </div>
    {{/if}}
</div>

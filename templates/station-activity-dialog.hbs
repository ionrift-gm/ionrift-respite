                             title="{{label}}: ×{{available}} carried, {{totalPints}}p pourable">
                            <img src="{{icon}}" alt="{{label}}" class="meal-inv-card-icon" draggable="false">
                            <span class="meal-inv-card-qty meal-inv-card-qty--water">
                                <span class="meal-inv-qty-stack">×{{available}}</span>
                                <span class="meal-inv-qty-pints">{{totalPints}}p</span>
                            </span>
                            <span class="meal-inv-card-name">{{name}}</span>
                        </div>
                        {{/each}}
                    </div>
                </div>
                {{else}}
                <div class="panel-no-inventory">
                    <i class="fas fa-tint"></i>
                    <span>No water in inventory</span>
                </div>
                {{/if}}
            </div>
        </div>
        </div>
        <div class="station-meal-submit-row">

    {{/if}}
    {{/if}}
    {{/unless}}
    {{/if}}
    {{/if}}

    {{!-- Workbench: Identify tab (main rest Identify tab, compact) --}}
    {{#if showStationTabs}}
    {{#if stationIdentifyHub}}
    {{#if (eq stationPanelTab "identify")}}
    {{> workbenchIdentifyEmbed}}
    {{/if}}
    {{/if}}
    {{/if}}

    {{/if}}{{!-- end dialogState === "list" --}}
</div>

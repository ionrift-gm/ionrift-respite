                    <span class="meal-panel-heading-title"><i class="fas fa-tint" aria-hidden="true"></i> Water</span>
                    <span class="meal-panel-req-note">{{waterRequired}} pints needed</span>
                </div>
                {{#if hasWater}}
                <div class="water-pool-target meal-drop-zone water-drop-zone{{#if waterSufficient}} water-pool-target--complete{{/if}}"
                     data-character-id="{{characterId}}" data-slot="water" data-slot-index="0"{{#if waterSufficient}} data-pool-full="true"{{/if}}>
                    <div class="drop-zone-silhouette">
                        {{#if waterSufficient}}
                        <i class="fas fa-check-circle water-pool-complete-icon" aria-hidden="true"></i>
                        {{else}}
                        <i class="fas fa-tint drop-zone-goblet"></i>
                        {{/if}}
                    </div>
                    <span class="meal-drop-hint-text">{{#if waterSufficient}}Water needs met{{else}}drop water here{{/if}}</span>
                </div>
                <div class="water-pool-bar" data-target="{{waterRequired}}" data-filled="{{waterFilledCount}}">
                    {{#each waterPoolSegments}}
                    <div class="water-pool-segment {{#if filled}}filled{{/if}}"></div>
                    {{/each}}
                </div>
                <div class="water-pool-status">
                    {{#if waterSufficient}}
                    <span class="pool-status-ok"><i class="fas fa-check"></i> {{waterFilledCount}}/{{waterRequired}} pints — Hydrated</span>
                    {{else if waterFilledCount}}
                    <span class="pool-status-partial">{{waterFilledCount}} of {{waterRequired}} pints</span>
                    {{else}}
                    <span class="pool-status-empty">0 of {{waterRequired}} pints</span>
                    {{/if}}
                </div>
                {{#if waterPoolSources.length}}

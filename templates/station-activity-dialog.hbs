    {{/unless}}
    {{/if}}
    {{/if}}
    {{/if}}

    {{!-- Rations tab (campfire + cooking station) --}}
    {{#if showStationTabs}}
    {{#if (eq stationPanelTab "meal")}}
    <div class="station-meal-embed">
        {{#if mealCard}}
        {{#if mealCardNeedsEssence}}
        <p class="station-essence-hint"><i class="fas fa-bolt" aria-hidden="true"></i> Essence slots: use the main rest window if this character needs them.</p>
        {{/if}}
        {{#with mealCard}}
        {{#if (or allDaysConsumed playerSubmitted)}}
        <div class="meal-summary-status">
            <span class="meal-summary-stat {{#if foodSufficient}}stat-ok{{else}}stat-warn{{/if}}">
                <i class="fas {{#if foodSufficient}}fa-check-circle{{else}}fa-drumstick-bite{{/if}}"></i>
                {{#if foodSufficient}}Fed{{else}}Hungry{{/if}}
            </span>
            <span class="meal-summary-stat {{#if waterSufficient}}stat-ok{{else}}stat-warn{{/if}}">
                <i class="fas {{#if waterSufficient}}fa-check-circle{{else}}fa-tint-slash{{/if}}"></i>
                {{#if waterSufficient}}Hydrated{{else}}Thirsty{{/if}}
            </span>
        </div>
        {{else}}
        <div class="meal-drop-columns">
            <div class="meal-panel food-panel {{#unless hasFood}}panel-empty{{/unless}}">
                {{#if hasFood}}
                {{#each foodSlots}}
                <div class="meal-drop-header-row">
                    <div class="meal-drop-zone food-drop-zone {{#if filled}}filled{{/if}}"
                         data-character-id="{{../characterId}}" data-slot="food" data-slot-index="{{index}}">
                        <div class="drop-zone-silhouette">
                            {{#if filled}}
                            {{#each ../foodOptions}}
                            {{#if (eq ../selected value)}}
                            <img src="{{icon}}" alt="" class="drop-zone-item-icon">
                            {{/if}}
                            {{/each}}
                            {{else}}
                            <i class="fas fa-drumstick-bite drop-zone-plate"></i>
                            {{/if}}
                        </div>
                    </div>
                    <div class="meal-drop-label">
                        {{#if filled}}
                        {{#each ../foodOptions}}
                        {{#if (eq ../selected value)}}
                        <span class="meal-drop-item-name">{{name}}</span>
                        <span class="meal-drop-item-qty">×{{available}}</span>
                        {{/if}}
                        {{/each}}
                        {{else}}
                        <span class="meal-drop-hint-text">drag from below</span>
                        {{/if}}
                    </div>
                </div>
                {{/each}}
                <div class="meal-inventory-tray-scroll">
                    <div class="meal-inventory-grid food-tray">
                        {{#each foodOptions}}
                        <div class="meal-inv-card" draggable="true"
                             data-item-id="{{value}}"
                             data-slot="food"
                             data-available="{{available}}"
                             data-character-id="{{../characterId}}"
                             title="{{label}}">
                            <img src="{{icon}}" alt="{{label}}" class="meal-inv-card-icon" draggable="false">
                            <span class="meal-inv-card-qty">×{{available}}</span>
                            <span class="meal-inv-card-name">{{name}}</span>
                        </div>
                        {{/each}}
                    </div>
                </div>
                {{else}}
                <div class="panel-no-inventory">
                    <i class="fas fa-drumstick-bite"></i>
                    <span>No rations in inventory</span>
                </div>
                {{/if}}
            </div>
            <div class="meal-panel water-panel {{#unless hasWater}}panel-empty{{/unless}}">
                {{#if hasWater}}
                {{#each waterSlots}}
                <div class="meal-drop-header-row">
                    <div class="meal-drop-zone water-drop-zone {{#if filled}}filled{{/if}}"
                         data-character-id="{{../characterId}}" data-slot="water" data-slot-index="{{index}}">
                        <div class="drop-zone-silhouette">
                            {{#if filled}}
                            {{#each ../waterOptions}}
                            {{#if (eq ../selected value)}}
                            <img src="{{icon}}" alt="" class="drop-zone-item-icon">
                            {{/if}}
                            {{/each}}
                            {{else}}
                            <i class="fas fa-tint drop-zone-goblet"></i>
                            {{/if}}
                        </div>
                    </div>
                    <div class="meal-drop-label">
                        {{#if filled}}
                        {{#each ../waterOptions}}
                        {{#if (eq ../selected value)}}
                        <span class="meal-drop-item-name">{{name}}</span>
                        <span class="meal-drop-item-qty">×{{available}}</span>
                        {{/if}}
                        {{/each}}
                        {{else}}
                        <span class="meal-drop-hint-text">drag from below</span>
                        {{/if}}
                    </div>
                </div>
                {{/each}}
                <div class="meal-inventory-tray-scroll">
                    <div class="meal-inventory-grid water-tray">
                        {{#each waterOptions}}
                        <div class="meal-inv-card" draggable="true"
                             data-item-id="{{value}}"
                             data-slot="water"
                             data-available="{{available}}"
                             data-character-id="{{../characterId}}"
                             title="{{label}}">
                            <img src="{{icon}}" alt="{{label}}" class="meal-inv-card-icon" draggable="false">
                            <span class="meal-inv-card-qty">×{{available}}</span>
                            <span class="meal-inv-card-name">{{name}}</span>
                        </div>
                        {{/each}}
                    </div>
                </div>
                {{else}}
                <div class="panel-no-inventory">
                    <i class="fas fa-tint"></i>
                    <span>No water in inventory</span>
                </div>
                {{/if}}
            </div>
        </div>
        <div class="station-meal-submit-row">
            <button type="button" class="station-meal-submit-btn" data-action="submitStationRations">Submit rations</button>
        </div>
        {{/if}}
        {{/with}}
        {{else}}
        <p class="station-no-activities">Rations data is not ready yet. Reopen from the station or use the main rest panel.</p>
        {{/if}}
    </div>
    {{/if}}
    {{/if}}


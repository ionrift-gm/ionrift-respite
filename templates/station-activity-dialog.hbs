                <span class="comfort-factor-badge active">
                    <i class="fas fa-fire"></i> {{campPersonalCard.fireFactorRow.tierLabel}}
                </span>
            </div>
            {{/if}}
        </div>
        <div class="comfort-hero-recovery">

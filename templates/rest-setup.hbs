{{!-- Ionrift Respite: Rest Setup Template (ApplicationV2) --}}
{{!-- Dual-mode: GM has full control, Players see shared campsite view --}}

<form class="respite-form">

    {{!-- Phase Indicator: pips and label come from phaseSteps, which only --}}
    {{!-- includes phases that actually run this rest (skipped travel/meal/events --}}
    {{!-- drop out so the dot count matches the real flow). --}}
    <div class="respite-phase-header">
        <div class="phase-indicator">
            {{#each phaseSteps}}
            <div class="phase-dot {{#if active}}active{{/if}} {{#if complete}}complete{{/if}}"></div>
            {{/each}}
        </div>
        <span class="phase-label">{{phaseLabel}}</span>

        {{#if isGM}}
        <button type="button" class="btn-abandon-rest" data-action="abandonRest" title="Cancel this rest for all players">
            <i class="fas fa-times"></i> Abandon Rest
        </button>
        {{/if}}
    </div>

    {{!-- Camp Status Bar: persistent across all phases post-setup --}}
    {{#if campStatus}}
    {{#unless (eq phase 'activity')}}
    {{#unless (eq phase 'camp')}}
    <div class="camp-status-bar">
        {{!-- Comfort badge removed: the Camp Comfort section below covers this --}}
        {{#if campStatus.weather}}
        {{#unless (eq campStatus.weather "clear")}}
        <span class="camp-status-chip weather-chip" title="{{campStatus.weatherTooltip}}">
            <i class="fas fa-cloud-sun-rain"></i> {{campStatus.weatherLabel}}
        </span>
        {{/unless}}
        {{/if}}
        {{#each campStatus.activeShelters}}
        <span class="camp-status-chip shelter-chip shelter-chip-{{id}}" title="{{tooltip}}">
            <i class="{{icon}}"></i> {{name}}
        </span>
        {{/each}}
        {{#unless campStatus.hasTent}}
        {{#unless safeRestSpot}}
        <span class="camp-status-chip shelter-chip absent" title="No tent pitched. The whole camp is exposed to weather penalties and lower encounter safety.">
            <i class="fas fa-campground"></i> No Tent
        </span>
        {{else}}
        <span class="camp-status-chip shelter-chip absent" title="No tent pitched. Weather flavor only in a safe rest spot.">
            <i class="fas fa-campground"></i> No Tent
        </span>
        {{/unless}}
        {{/unless}}
        {{!-- Fire badge removed: the fire section below covers this --}}
    </div>
    {{/unless}}
    {{/unless}}
    {{/if}}


    {{!-- =============== SETUP PHASE =============== --}}
    {{#if (eq phase 'setup')}}
    <div class="phase-banner">
        <img src="{{terrainBanner}}" alt="" style="object-position: {{terrainBannerPos}}" onerror="this.onerror=null;this.src='{{terrainBannerFallback}}'">
    </div>

    {{#if isGM}}
    {{#if emptyParty}}
    <div class="respite-setup">
        <div class="respite-empty-party-hint">
            <i class="fas fa-users-slash"></i>
            <p>No player-owned characters found.</p>
            <p>Create or import characters and assign them to players, then reopen Respite.</p>
        </div>
    </div>
    {{else}}
    <div class="respite-setup">



        {{!-- Scene: Rest Type + Environment + Weather --}}
        <div class="scene-grid">
            <div class="form-group scene-rest-type">
                <label>Rest Type</label>
                <div class="rest-type-row">
                    <div class="rest-type-toggle">
                        <button type="button" class="rest-type-btn {{#unless (eq selectedRestType 'short')}}active{{/unless}}"
                            data-rest-type="long">
                            <i class="fas fa-moon"></i> Long Rest
                        </button>
                        <button type="button" class="rest-type-btn {{#if (eq selectedRestType 'short')}}active{{/if}}"
                            data-rest-type="short">
                            <i class="fas fa-mug-hot"></i> Short Rest
                        </button>
                        <input type="hidden" name="restType" value="{{#if (eq selectedRestType 'short')}}short{{else}}long{{/if}}">
                    </div>
                    {{#unless isShortRest}}
                    <label class="safe-rest-spot-toggle {{#if safeRestSpot}}is-active{{/if}}" title="No encounter risk. Skips night events, comfort penalties, and camp defense. Activities, cooking, and identification only.">
                        <i class="fas fa-shield-halved" aria-hidden="true"></i>
                        <span class="safe-rest-spot-label">Safe Rest</span>
                        <span class="safe-rest-switch"><input type="checkbox" name="safeRestSpot" value="1" {{#if safeRestSpot}}checked{{/if}}><span class="safe-rest-slider"></span></span>
                    </label>
                    {{/unless}}
                </div>
            </div>

            {{#unless isShortRest}}
            <hr class="setup-divider scene-grid-full">

            <div class="form-group scene-environment">
                <label title="{{terrainPreview}}">Environment:</label>
                <select name="terrain">
                    {{#each terrainOptionGroups}}
                    <optgroup label="{{group}}">
                        {{#each options}}
                        <option value="{{value}}" {{#if (eq value ../../selectedTerrain)}}selected{{/if}}>{{label}}</option>
                        {{/each}}
                    </optgroup>
                    {{/each}}
                </select>
            </div>
            {{/unless}}
            {{#unless isShortRest}}
            <div class="form-group scene-weather {{#if safeRestSpot}}scene-weather-flavor{{/if}}">
                <label>Weather:</label>
                <select name="weather">
                    {{#each weatherOptions}}
                    <option value="{{value}}" title="{{hint}}" {{#if (eq value ../defaultWeather)}}selected{{/if}}>{{label}}</option>
                    {{/each}}
                </select>
            </div>
            {{/unless}}
        </div>

        {{#unless isShortRest}}
        <div class="setup-status-line" title="Summary of terrain and weather effects">{{setupStatusLine}}</div>
        <hr class="setup-divider">
        {{/unless}}

        {{#if restConfigBadges.length}}
        {{#unless isShortRest}}
        <div class="rest-config-summary" title="What this rest includes, based on module settings.">
            {{#each restConfigBadges}}
            <span class="rest-config-badge {{#if on}}is-on{{else}}is-off{{/if}}" title="{{tooltip}}">
                <i class="{{icon}}"></i> {{label}}
            </span>
            {{/each}}
        </div>
        {{/unless}}
        {{/if}}

        {{!-- Advanced Drawer (collapsed by default) --}}
        <details class="scene-advanced-drawer">
            <summary class="scene-advanced-toggle">
                <i class="fas fa-cog"></i> Advanced
            </summary>
            <div class="scene-advanced-body">
                {{!-- Party Roster --}}
                {{#if rosterInfo}}
                <div class="roster-indicator">
                    <div class="roster-indicator-portraits">
                        {{#each rosterInfo.portraits}}
                        <img class="roster-indicator-portrait" src="{{img}}" alt="{{name}}" title="{{name}}">
                        {{/each}}
                        {{#if rosterInfo.overflow}}
                        <span class="roster-indicator-overflow">+{{rosterInfo.overflow}}</span>
                        {{/if}}
                    </div>
                    <span class="roster-indicator-label">{{rosterInfo.count}} characters</span>
                    <button type="button" class="roster-indicator-edit" onclick="const App = game.ionrift?.library?.PartyRosterApp; if (App) new App().render(true); else ui.notifications.warn('Party Roster requires ionrift-library.');" title="Edit Party Roster">
                        <i class="fas fa-pencil-alt"></i>
                    </button>
                </div>
                {{/if}}
                {{#if trackFood}}
                <div class="days-since-rest-block">
                    <div class="days-since-rest-row">
                        <span class="days-label"><i class="fas fa-calendar-day"></i> Days Since Last Rest</span>
                        <div class="days-stepper">
                            <button type="button" class="days-btn" data-action="adjustDaysSinceRest" data-delta="-1" {{#if (eq daysSinceLastRest 1)}}disabled{{/if}}>−</button>
                            <span class="days-value">{{daysSinceLastRest}}</span>
                            <button type="button" class="days-btn" data-action="adjustDaysSinceRest" data-delta="1" {{#if (gte daysSinceLastRest 9)}}disabled{{/if}}>+</button>
                        </div>
                    </div>
                    <span class="days-hint"><i class="fas fa-book"></i> Characters can only benefit from one long rest per 24 hours. (PHB p.186)</span>
                    {{#if (gte daysSinceLastRest 2)}}
                    <span class="days-hint warning"><i class="fas fa-exclamation-triangle"></i> {{daysSinceLastRest}} days without rest. Characters are treated as having gone without food and water for that duration.</span>
                    {{/if}}
                </div>
                {{/if}}
                <div class="form-group scene-rest-mode-override">
                    <label>Rest Interface</label>
                    <select name="restInterfaceMode">
                        {{#each restModeOptions}}
                        <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                        {{/each}}
                    </select>
                    <span class="comfort-hint">How the table runs this rest. One window keeps everything in this panel; camp stations drops pieces on the scene for players to move tokens to.</span>
                </div>
            </div>
        </details>

    </div>
    <div class="respite-action-bar">
        {{#if isShortRest}}
        <button type="button" class="btn-primary" data-action="beginShortRest">
            <i class="fas fa-mug-hot"></i> Begin Short Rest
        </button>
        {{else}}
        <button type="button" class="btn-primary" data-action="beginRest">
            <i class="fas fa-campground"></i> Begin Rest
        </button>
        {{/if}}
    </div>
    {{/if}} {{!-- /emptyParty --}}
    {{else}}
    {{!-- Player: waiting for GM to start --}}
    <div class="respite-setup">
        <div class="respite-waiting-message">
            <i class="fas fa-campground"></i>
            <p>The GM is preparing the campsite...</p>
        </div>
    </div>
    {{/if}}
    {{/if}}

    {{!-- =============== TRAVEL RESOLUTION PHASE =============== --}}
    {{#if (eq phase 'travel')}}
    <div class="phase-banner">
        <img src="{{terrainBanner}}" alt="" style="object-position: {{terrainBannerPos}}" onerror="this.onerror=null;this.src='{{terrainBannerFallback}}'">
    </div>

    {{#if travelContext}}
    <div class="respite-travel-phase {{#if travelContext.travelSkipRecommended}}travel-skip-mode{{else}}{{#unless travelContext.hasTravelOptions}}travel-disabled{{/unless}}{{/if}}">
        {{#if isGM}}
        <div class="travel-header">
            <i class="fas fa-hiking"></i>
            <span>Travel Resolution: {{travelContext.terrainLabel}}</span>
        </div>
        {{/if}}

        {{!-- ═══ SKIP ACKNOWLEDGMENT (no forage/hunt) ═══ --}}
        {{#if travelContext.travelSkipRecommended}}
        <div class="travel-skip-notice">
            <p class="travel-skip-reason">{{travelContext.disabledReason}}</p>
        </div>
        {{#if isGM}}
        <div class="respite-action-bar">
            <button type="button" class="btn-primary travel-skip-pulse" data-action="skipTravelPhase">
                <i class="fas fa-forward"></i> Continue
            </button>
        </div>
        {{else}}
        <div class="travel-player-info">
            <i class="fas fa-hiking"></i>
            <span>The party presses on...</span>
        </div>
        {{/if}}

        {{else}}
        {{#if travelContext.hasTravelOptions}}

        {{!-- ═══ GM VIEW ═══ --}}
        {{#if isGM}}
        <div class="travel-dc-bar">
            {{#if travelContext.canForage}}
            {{#if travelContext.forageDisabled}}
            <span class="travel-dc-chip travel-dc-chip--muted" title="{{travelContext.forageDisabledTooltip}}">
                <i class="fas fa-seedling"></i> Forage unavailable
            </span>
            {{else}}
            <span class="travel-dc-chip">
                <i class="fas fa-seedling"></i> Forage DC {{travelContext.forageDC}}
                {{#if travelContext.forageGMAdj}}
                <span class="encounter-chip"><i class="fas fa-wrench"></i> GM {{travelContext.forageGMAdj}}</span>
                {{/if}}
                <span class="encounter-gm-adj">
                    <button type="button" class="encounter-adj-btn" data-action="adjustGlobalDC" data-activity="forage" data-delta="-1" title="Reduce Forage DC">−</button>
                    <button type="button" class="encounter-adj-btn" data-action="adjustGlobalDC" data-activity="forage" data-delta="1" title="Increase Forage DC">+</button>
                </span>
            </span>
            {{/if}}
            {{/if}}
            {{#if travelContext.canHunt}}
            <span class="travel-dc-chip">
                <i class="fas fa-crosshairs"></i> Hunt DC {{travelContext.huntDC}}
                {{#if travelContext.huntGMAdj}}
                <span class="encounter-chip"><i class="fas fa-wrench"></i> GM {{travelContext.huntGMAdj}}</span>
                {{/if}}
                <span class="encounter-gm-adj">
                    <button type="button" class="encounter-adj-btn" data-action="adjustGlobalDC" data-activity="hunt" data-delta="-1" title="Reduce Hunt DC">−</button>
                    <button type="button" class="encounter-adj-btn" data-action="adjustGlobalDC" data-activity="hunt" data-delta="1" title="Increase Hunt DC">+</button>
                </span>
            </span>
            {{/if}}
        </div>

        {{!-- Multi-day tabs --}}
        {{#if travelContext.isMultiDay}}
        <div class="travel-day-tabs">
            {{#each travelContext.days}}
            <button type="button" class="travel-day-tab {{#if isActive}}active{{/if}} {{#if resolved}}resolved{{/if}}" data-action="switchTravelDay" data-day="{{day}}">
                {{#if resolved}}<i class="fas fa-check"></i>{{/if}}
                Day {{day}}{{#if isFinalDay}} <i class="fas fa-campground" title="Arrival day, scouting available"></i>{{/if}}
            </button>
            {{/each}}
        </div>
        {{/if}}

        {{!-- Active day content --}}
        {{#each travelContext.days}}
        {{#if isActive}}
        <div class="travel-day-section" data-day="{{day}}">

            {{#if isFinalDay}}
            {{#if ../travelContext.canScout}}
            <div class="travel-scout-notice">
                <i class="fas fa-campground"></i> Arrival at this site. Scouting, rest, foraging, and making camp are all in play. Resolve the day below to see who did what.
            </div>
            {{/if}}
            {{/if}}

            <div class="travel-character-list">
                {{#each characters}}
                <div class="travel-character-row {{#if (eq status 'resolved')}}resolved{{/if}} {{#if confirmed}}player-confirmed{{/if}} {{#if awaitingPlayerResponse}}row-awaiting{{/if}}">
                    <img class="travel-portrait" src="{{img}}" alt="{{name}}" />
                    <div class="travel-char-info">
                        <span class="travel-char-name">{{name}}{{#if confirmed}}<span class="travel-confirmed-pick">{{#if (eq activity 'forage')}}<i class="fas fa-seedling"></i> Forage
                        {{else if (eq activity 'hunt')}}<i class="fas fa-crosshairs"></i> Hunt
                        {{else if (eq activity 'scout')}}<i class="fas fa-binoculars"></i> Scout
                        {{else}}<span class="travel-other-emoji" aria-hidden="true">&#127969;</span> Other{{/if}} <i class="fas fa-check travel-confirmed-icon" title="Player locked in"></i></span>{{else}}<span class="travel-pending-pick" title="Not confirmed yet">{{#if (eq activity 'forage')}}<i class="fas fa-seedling"></i> Forage
                        {{else if (eq activity 'hunt')}}<i class="fas fa-crosshairs"></i> Hunt
                        {{else if (eq activity 'scout')}}<i class="fas fa-binoculars"></i> Scout
                        {{else}}<span class="travel-other-emoji" aria-hidden="true">&#127969;</span> Other{{/if}}</span>{{/if}}</span>
                        <span class="travel-char-mod">Survival {{survivalMod}}</span>
                    </div>

                    {{#if result}}
                    <div class="travel-gm-result-cell">
                    <div class="travel-result {{#if (eq result.activity 'other')}}other{{else if result.nat20}}nat20{{else if result.nat1}}nat1{{else if result.success}}success{{else if (eq result.activity 'scout')}}scout{{else}}failure{{/if}}">
                        {{#if (eq result.activity 'other')}}<i class="fas fa-dice-d20"></i> {{result.total}} vs DC {{result.dc}} {{#if result.success}}✓{{else}}✗{{/if}}
                        {{else if (eq result.activity 'scout')}}<i class="fas fa-binoculars"></i> Scouted ({{result.total}})
                        {{else if result.nat20}}<i class="fas fa-star"></i> Nat 20!
                        {{else if result.nat1}}<i class="fas fa-skull"></i> Nat 1!
                        {{else if result.exceptional}}<i class="fas fa-award"></i> Exceptional
                        {{else if result.success}}<i class="fas fa-check"></i> Success
                        {{else}}<i class="fas fa-times"></i> Failed{{/if}}
                        {{#unless (eq result.activity 'scout')}}{{#unless (eq result.activity 'other')}}<span class="travel-roll-total">({{result.total}})</span>{{/unless}}{{/unless}}
                    </div>
                    {{#if (eq result.activity 'forage')}}
                    {{#if result.items.length}}
                    <div class="travel-gm-yield-badges" aria-label="Foraged">
                        {{#each result.items}}
                        <span class="travel-item-badge travel-item-badge--forage"><i class="fas fa-leaf"></i> {{quantity}}x {{#if itemData.name}}{{itemData.name}}{{else}}{{itemRef}}{{/if}}</span>
                        {{/each}}
                    </div>
                    {{else}}
                    <div class="travel-gm-yield-nothing">Nothing found.</div>
                    {{/if}}
                    {{/if}}
                    {{#if (eq result.activity 'hunt')}}
                    {{#if result.items.length}}
                    <div class="travel-gm-yield-badges" aria-label="Hunted">
                        {{#each result.items}}
                        <span class="travel-item-badge travel-item-badge--hunt"><i class="fas fa-drumstick-bite"></i> {{quantity}}x {{#if itemData.name}}{{itemData.name}}{{else}}{{itemRef}}{{/if}}</span>
                        {{/each}}
                    </div>
                    {{else}}
                    {{#unless result.success}}
                    <div class="travel-gm-yield-nothing">Nothing found.</div>
                    {{/unless}}
                    {{/if}}
                    {{/if}}
                    {{#if result.mishap}}
                    <div class="travel-mishap--in-cell">
                        <i class="fas fa-exclamation-triangle"></i> {{result.mishap.description}}
                        {{#if result.mishap.appliedSummaries.length}}
                        <div class="travel-mishap-effect-badges" aria-label="Applied effects">
                            {{#each result.mishap.appliedSummaries}}
                            <span class="travel-mishap-effect-badge">{{this}}</span>
                            {{/each}}
                        </div>
                        {{/if}}
                    </div>
                    {{/if}}
                    </div>

                    {{else if (eq status 'rolled')}}
                    <span class="travel-result success"><i class="fas fa-check"></i> Rolled {{total}}</span>

                    {{else if requested}}
                    <div class="travel-gm-activity-pick">
                    <span class="travel-pending-label"><i class="fas fa-paper-plane"></i> Sent</span>
                    {{#if awaitingPlayerResponse}}<span class="travel-player-await" title="Waiting for a roll"><i class="fas fa-circle-notch fa-spin"></i></span>{{/if}}
                    <button type="button" class="btn-roll-for-player travel-fallback" data-action="rollTravelForPlayer" data-actor-id="{{id}}" data-day="{{../day}}" title="Roll on their behalf">
                        <i class="fas fa-dice"></i>
                    </button>
                    </div>

                    {{else if otherLockedIn}}
                    <div class="travel-gm-activity-pick travel-gm-other-locked">
                        <span class="travel-gm-other-locked-label" title="Other, confirmed for this day"><span class="travel-other-emoji" aria-hidden="true">&#127969;</span> Other</span>
                        <span class="travel-gm-confirmed-badge" title="Locked in as Other"><i class="fas fa-check"></i></span>
                    </div>

                    {{else}}
                    {{!-- Uncommitted: GM can change activities. Plain Other: Confirm until locked (see otherLockedIn). --}}
                    <div class="travel-gm-activity-pick">
                    <select class="travel-activity-select" data-actor-id="{{id}}" data-day="{{../day}}">
                        <option value="nothing" {{#if (eq activity 'nothing')}}selected{{/if}}>🏕️ Other</option>
                        {{#if ../../travelContext.canForage}}<option value="forage" {{#if ../../travelContext.forageDisabled}}disabled title="{{../../travelContext.forageDisabledTooltip}}" class="travel-option-disabled"{{/if}} {{#if (eq activity 'forage')}}selected{{/if}}>🌿 Forage</option>{{/if}}
                        {{#if ../../travelContext.canHunt}}<option value="hunt" {{#if (eq activity 'hunt')}}selected{{/if}}>🎯 Hunt</option>{{/if}}
                        {{#if ../canScout}}<option value="scout" {{#if (eq activity 'scout')}}selected{{/if}}>🔭 Scout</option>{{/if}}
                    </select>
                    {{#if awaitingPlayerResponse}}<span class="travel-player-await" title="Waiting for this character"><i class="fas fa-circle-notch fa-spin"></i></span>{{/if}}
                    {{#if (eq activity 'nothing')}}
                    <button type="button" class="travel-gm-confirm-for-btn" data-action="confirmTravelForPlayer" data-actor-id="{{id}}" data-day="{{../day}}" title="Confirm Other on their behalf (absent player)">
                        <i class="fas fa-check"></i> Confirm
                    </button>
                    {{else}}
                    <button type="button" class="btn-roll-for-player travel-gm-direct-roll" data-action="rollTravelForPlayer" data-actor-id="{{id}}" data-day="{{../day}}" title="Roll on their behalf (absent player)">
                        <i class="fas fa-dice"></i>
                    </button>
                    {{/if}}
                    </div>
                    {{/if}}
                </div>
                {{/each}}
            </div>

            {{!-- Day action bar: single contextual button that morphs through the flow --}}
            <div class="respite-action-bar travel-day-resolve-bar">
                {{#if resolved}}
                <span class="travel-day-resolved-label"><i class="fas fa-check"></i> Day {{day}} resolved</span>
                {{else}}
                <div class="travel-resolve-day-wrap">
                {{#if allRollsIn}}
                <button type="button" class="btn-primary travel-resolve-day-btn" data-action="resolveTravelDay" data-day="{{day}}">
                    <i class="fas fa-check"></i> Resolve Day {{day}}
                </button>
                {{else}}
                <button type="button" class="btn-primary travel-resolve-day-btn disabled" data-day="{{day}}" disabled
                    title="Unlocks when every party member has rolled or confirmed.">
                    <i class="fas fa-lock"></i> Waiting on travel rolls
                </button>
                {{/if}}
                </div>
                {{#unless allRollsIn}}
                <button type="button" class="travel-skip-link" data-action="skipTravelPhase" title="Skip remaining travel and continue">
                    <i class="fas fa-forward"></i> Skip Travel
                </button>
                {{/unless}}
                {{/if}}
            </div>
        </div>
        {{/if}}
        {{/each}}

        {{!-- GM Scouting debrief panel --}}
        {{#if scoutingDebrief}}
        <div class="travel-scouting-debrief {{scoutingDebrief.tier}}">
            <div class="travel-scouting-header">
                <i class="fas fa-binoculars"></i>
                <strong>Scouting: {{scoutingDebrief.tierLabel}}</strong>
                {{#if scoutingDebrief.comfortBonus}}<span class="scouting-effect">Comfort +{{scoutingDebrief.comfortBonus}}</span>{{/if}}
                {{#if scoutingDebrief.encounterCampModLabel}}<span class="scouting-effect">Night check mod {{scoutingDebrief.encounterCampModLabel}}</span>{{/if}}
            </div>
            <p class="travel-scouting-gm-advisory">Scouting roll is blind to the players. Describe what the scout found.</p>

            {{!-- Scout roster --}}
            <div class="travel-scout-roster {{#if scoutingDebrief.multipleScouts}}multi{{/if}}">
                {{#each scoutingDebrief.scouts}}
                <div class="travel-scout-entry {{#if isBest}}best{{/if}}">
                    <span class="scout-name">{{actorName}}</span>
                    <span class="scout-total">{{total}}</span>
                    {{#if isBest}}<span class="scout-best-badge">★ Best</span>{{/if}}
                    {{#if narrative}}
                    <div class="scout-narrative"><em>"{{narrative}}"</em></div>
                    {{/if}}
                </div>
                {{/each}}
            </div>

            {{#if scoutingDebrief.gmHint}}
            <div class="travel-scouting-gm-hint">
                <i class="fas fa-exclamation-triangle"></i> {{scoutingDebrief.gmHint}}
            </div>
            {{/if}}
            {{#if scoutingDebrief.isNat1}}
            <div class="travel-scouting-gm-hint danger">
                <i class="fas fa-skull-crossbones"></i> A hidden complication will trigger during the event phase. The players believe this is a good campsite.
            </div>
            {{/if}}
        </div>
        {{/if}}

        {{!-- Global travel action bar: multi-day only, after all days resolved --}}
        {{#if travelContext.fullyResolved}}
        {{#if travelContext.isMultiDay}}
        <div class="respite-action-bar travel-global-actions">
            <button type="button" class="btn-primary" data-action="skipTravelPhase">
                <i class="fas fa-arrow-right"></i> Continue to Activities
            </button>
        </div>
        {{/if}}
        {{/if}}

        {{!-- ═══ PLAYER VIEW ═══ --}}
        {{else}}
        <div class="travel-player-view">

            {{!-- Priority 1: Debrief (results received from GM) --}}
            {{#if travelDebrief}}
            <div class="travel-player-info">
                <i class="fas fa-scroll"></i>
                <span>Travel results are in.</span>
            </div>
            <div class="travel-debrief-section">
                {{#each travelDebrief}}
                <div class="travel-debrief-entry {{#if result.success}}success{{else if result.nat20}}nat20{{else if result.nat1}}nat1{{else}}failure{{/if}}">
                    <div class="travel-debrief-header">
                        {{#if result.nat20}}<i class="fas fa-star"></i>{{else if result.nat1}}<i class="fas fa-skull"></i>{{else if result.success}}<i class="fas fa-check"></i>{{else}}<i class="fas fa-times"></i>{{/if}}
                        <strong>{{result.actorName}}</strong>
                        <span class="debrief-activity">
                            {{#if (eq activity 'forage')}}🌿 Foraged{{else if (eq activity 'hunt')}}🎯 Hunted{{else}}Rolled{{/if}}
                        </span>
                        <span class="debrief-total">({{result.total}})</span>
                    </div>
                    {{#if result.items.length}}
                    <div class="travel-debrief-items">
                        {{#each result.items}}
                        <span class="travel-item-badge"><i class="fas fa-leaf"></i> {{quantity}}x {{#if itemData.name}}{{itemData.name}}{{else}}{{itemRef}}{{/if}}</span>
                        {{/each}}
                    </div>
                    {{/if}}
                    {{#if result.mishap}}
                    <div class="travel-debrief-mishap">
                        <i class="fas fa-exclamation-triangle"></i> {{result.mishap.description}}
                    </div>
                    {{/if}}
                    {{#unless result.success}}
                    {{#unless result.items.length}}
                    <div class="travel-debrief-nothing">
                        <span>Nothing found.</span>
                    </div>
                    {{/unless}}
                    {{/unless}}
                    {{#if result.success}}
                    {{#if (eq activity 'forage')}}
                    {{#unless result.items.length}}
                    <div class="travel-debrief-nothing">
                        <span>Nothing found.</span>
                    </div>
                    {{/unless}}
                    {{/if}}
                    {{/if}}
                </div>
                {{/each}}
            </div>

            {{#if travelScoutingDone}}
            <div class="travel-player-scout-summary">
                <i class="fas fa-binoculars"></i>
                <span>Your scouts have surveyed the area. The GM will describe the campsite before the party settles in.</span>
            </div>
            {{/if}}

            {{#if travelFullyResolved}}
            <div class="travel-player-info travel-waiting-gm">
                <i class="fas fa-hourglass-half"></i>
                <span>Waiting for the GM to continue...</span>
            </div>
            {{/if}}

            {{!-- Priority 2: Roll requests from GM --}}
            {{else if pendingTravelRoll.activities.length}}
            <div class="travel-player-info">
                <i class="fas fa-dice-d20"></i>
                <span>The GM has called for travel rolls.</span>
            </div>
            <div class="travel-roll-section">
                {{#each pendingTravelRoll.activities}}
                {{#if isOwner}}
                <div class="travel-roll-prompt {{#if rolled}}rolled{{/if}}">
                    <div class="travel-roll-info">
                        <strong>{{actorName}}: {{activityLabel}}</strong>
                        <span class="travel-roll-skill">{{skillName}}{{#if dc}} DC {{dc}}{{/if}}</span>
                    </div>
                    {{#if rolled}}
                    <span class="travel-roll-result pending">
                        <i class="fas fa-spinner fa-spin"></i> Awaiting...
                    </span>
                    {{else}}
                    <button type="button" class="btn-primary btn-travel-roll" data-action="rollTravelCheck" data-actor-id="{{actorId}}" data-day="{{day}}">
                        <i class="fas fa-dice-d20"></i> Roll
                    </button>
                    {{/if}}
                </div>
                {{/if}}
                {{/each}}
            </div>

            {{!-- Priority 3: Declaration phase --}}
            {{else if travelContext.hasTravelOptions}}

            <div class="travel-player-info">
                <i class="fas fa-hiking"></i>
                <span>{{travelContext.terrainLabel}}: {{#if travelContext.isMultiDay}}{{travelContext.totalDays}} days of travel{{else}}What did you do while travelling?{{/if}}</span>
            </div>

            {{#each travelContext.days}}
            {{#if isActive}}
            <div class="travel-day-section" data-day="{{day}}">
                {{#if ../travelContext.isMultiDay}}
                <div class="travel-day-label">Day {{day}}{{#if isFinalDay}}, Arrival{{/if}}</div>
                {{/if}}

                {{!-- Owned characters: hero cards --}}
                {{#each characters}}
                {{#if isOwner}}
                <div class="travel-hero-card {{#if confirmed}}confirmed{{/if}} {{#if rolled}}rolled{{/if}}">
                    <img class="travel-hero-portrait" src="{{img}}" alt="{{name}}" />
                    <div class="travel-hero-info">
                        <span class="travel-hero-name">{{name}}</span>
                        <span class="travel-hero-meta">
                            <span class="travel-hero-mod">{{survivalMod}} Survival</span>{{#if showLastHint}}<span class="travel-last-hint">Last: {{lastActivity}}</span>{{/if}}
                        </span>
                        {{#unless rolled}}{{#unless confirmed}}
                        <span class="travel-activity-desc">{{activityFlavor}}</span>
                        {{/unless}}{{/unless}}
                    </div>
                    {{#if rolled}}
                    <span class="travel-rolled-badge">
                        <i class="fas fa-dice-d20"></i>
                        {{#if (eq declaration 'forage')}}Foraging{{else if (eq declaration 'hunt')}}Hunting{{else if (eq declaration 'scout')}}Scouting{{else}}Other{{/if}}
                    </span>
                    {{else if confirmed}}
                    <span class="travel-confirmed-label">
                        {{#if (eq declaration 'forage')}}🌿 Forage
                        {{else if (eq declaration 'hunt')}}🎯 Hunt
                        {{else if (eq declaration 'scout')}}🔭 Scout
                        {{else}}🏕️ Other{{/if}}
                        <i class="fas fa-check"></i>
                    </span>
                    {{else}}
                    <select class="travel-player-select" data-actor-id="{{id}}" data-day="{{../day}}">
                        <option value="nothing" {{#if (eq declaration 'nothing')}}selected{{/if}}>🏕️ Other</option>
                        {{#if ../../travelContext.canForage}}<option value="forage" {{#if ../../travelContext.forageDisabled}}disabled title="{{../../travelContext.forageDisabledTooltip}}" class="travel-option-disabled"{{/if}} {{#if (eq declaration 'forage')}}selected{{/if}}>🌿 Forage</option>{{/if}}
                        {{#if ../../travelContext.canHunt}}<option value="hunt" {{#if (eq declaration 'hunt')}}selected{{/if}}>🎯 Hunt</option>{{/if}}
                        {{#if ../canScout}}<option value="scout" {{#if (eq declaration 'scout')}}selected{{/if}}>🔭 Scout</option>{{/if}}
                    </select>
                    {{#if (eq declaration 'nothing')}}
                    <button type="button" class="travel-confirm-btn" data-actor-id="{{id}}" data-day="{{../day}}" title="Lock in choice">
                        <i class="fas fa-check"></i>
                    </button>
                    {{else}}
                    <button type="button" class="travel-self-roll-btn btn-primary" data-action="selfRollTravelCheck" data-actor-id="{{id}}" data-day="{{../day}}" data-activity="{{declaration}}" data-dc="{{#if (eq declaration 'hunt')}}{{../../travelContext.huntDC}}{{else if (eq declaration 'scout')}}0{{else}}{{../../travelContext.forageDC}}{{/if}}">
                        <i class="fas fa-dice-d20"></i> Roll
                    </button>
                    {{/if}}
                    {{/if}}
                </div>
                {{/if}}
                {{/each}}

                {{!-- Other characters: compact grid --}}
                <div class="travel-party-grid">
                    {{#each characters}}
                    {{#unless isOwner}}
                    <div class="travel-grid-card {{#if confirmed}}confirmed{{/if}} {{#if declarationIcon}}active{{/if}} {{#if (eq declaration 'nothing')}}active-other{{/if}}" title="{{name}}{{#if confirmed}}, locked in{{/if}}">
                        <div class="travel-grid-portrait-wrap">
                            <img class="travel-grid-portrait" src="{{img}}" alt="{{name}}" />
                            {{#if confirmed}}<i class="fas fa-check travel-grid-confirmed-badge"></i>{{/if}}
                        </div>
                        <span class="travel-grid-name">{{name}}</span>
                        <span class="travel-grid-activity{{#unless declarationIcon}}{{#if (eq declaration 'nothing')}} travel-activity-other{{else}} idle{{/if}}{{/unless}}">
                            {{#if declarationIcon}}<i class="fas {{declarationIcon}}"></i>{{else}}<i class="fas fa-campground" title="Other"></i>{{/if}}
                        </span>
                        {{#if declarationLabel}}
                        <span class="travel-grid-label">{{declarationLabel}}</span>
                        {{else}}
                        <span class="travel-grid-label">Other</span>
                        {{/if}}
                    </div>
                    {{/unless}}
                    {{/each}}
                </div>
            </div>
            {{/if}}
            {{/each}}

            {{else}}
            <div class="travel-player-info">
                <i class="fas fa-hiking"></i>
                <span>Waiting for the GM...</span>
            </div>
            {{/if}}
        </div>
        {{/if}}

        {{else}}

        {{!-- ═══ TERRAIN DISABLED ═══ --}}
        <div class="travel-disabled-notice">
            <i class="fas fa-ban"></i>
            <span>{{travelContext.disabledReason}}</span>
        </div>

        {{#with (lookup travelContext.days 0)}}
        <div class="travel-character-list">
            {{#each characters}}
            <div class="travel-character-row travel-row-disabled">
                <img class="travel-portrait" src="{{img}}" alt="{{name}}" />
                <div class="travel-char-info">
                    <span class="travel-char-name">{{name}}</span>
                </div>
                <span class="travel-activity-disabled">-</span>
            </div>
            {{/each}}
        </div>
        {{/with}}

        {{#if isGM}}
        <div class="respite-action-bar">
            <button type="button" class="btn-primary" data-action="skipTravelPhase">
                <i class="fas fa-arrow-right"></i> Continue to Activities
            </button>
        </div>
        {{/if}}

        {{/if}} {{!-- /hasTravelOptions --}}
        {{/if}} {{!-- /travelSkipRecommended --}}
    </div>
    {{/if}}

    {{/if}}

    {{!-- =============== MAKE CAMP PHASE =============== --}}
    {{#if (eq phase 'camp')}}

    {{!-- TotM: inline Make Camp panel (no canvas required) --}}
    {{#if isTheaterMode}}
    <div class="phase-banner">
        <img src="{{terrainBanner}}" alt="" style="object-position: {{terrainBannerPos}}" onerror="this.onerror=null;this.src='{{terrainBannerFallback}}'">
    </div>
    {{> rosterStrip}}
    <div class="totm-camp-layout">

        {{#unless safeRestSpot}}
        {{!-- LEFT: Personal Comfort (character-contextual) --}}
        <div class="totm-camp-comfort-panel">

            {{#if campPersonalSelected}}
            {{!-- ── Compact gear grid (2×2 icon tiles) ─────────────────── --}}
            <div class="totm-camp-factors-heading">Your Gear</div>
            <div class="totm-camp-factors-grid">
                <div class="totm-factor-tile {{#if campPersonalSelected.hasBedroll}}present{{else}}missing{{/if}}"
                     title="{{#if campPersonalSelected.hasBedroll}}+1 personal comfort{{else}}Comfort stays at camp level{{/if}}">
                    <i class="fas fa-bed totm-factor-tile-icon" aria-hidden="true"></i>
                    <span class="totm-factor-tile-label">Bedroll</span>
                    {{#if campPersonalSelected.hasBedroll}}
                    <span class="totm-factor-tile-status present"><i class="fas fa-check" aria-hidden="true"></i></span>
                    {{else}}
                    <span class="totm-factor-tile-status missing"><i class="fas fa-times" aria-hidden="true"></i></span>
                    {{/if}}
                </div>
                <div class="totm-factor-tile {{#if campPersonalSelected.hasTent}}present{{else}}missing{{/if}}"
                     title="{{#if campPersonalSelected.hasTent}}Weather shield active{{else}}No weather shield{{/if}}">
                    <i class="fas fa-campground totm-factor-tile-icon" aria-hidden="true"></i>
                    <span class="totm-factor-tile-label">Tent</span>
                    {{#if campPersonalSelected.hasTent}}
                    <span class="totm-factor-tile-status present"><i class="fas fa-check" aria-hidden="true"></i></span>
                    {{else}}
                    <span class="totm-factor-tile-status missing"><i class="fas fa-times" aria-hidden="true"></i></span>
                    {{/if}}
                </div>
                <div class="totm-factor-tile {{#if campPersonalSelected.hasMessKit}}present{{else}}missing{{/if}}"
                     title="{{#if campPersonalSelected.hasMessKit}}Exhaustion-save advantage{{else}}Lose exhaustion-save advantage{{/if}}">
                    <i class="fas fa-utensils totm-factor-tile-icon" aria-hidden="true"></i>
                    <span class="totm-factor-tile-label">Mess Kit</span>
                    {{#if campPersonalSelected.hasMessKit}}
                    <span class="totm-factor-tile-status present"><i class="fas fa-check" aria-hidden="true"></i></span>
                    {{else}}
                    <span class="totm-factor-tile-status missing"><i class="fas fa-times" aria-hidden="true"></i></span>
                    {{/if}}
                </div>
                <div class="totm-factor-tile fire {{#if campFireIsLit}}present{{else if campColdCampDecided}}cold{{else}}missing{{/if}}"
                     title="{{#if campFireIsLit}}{{#each campFirePickerLevels}}{{#if selected}}{{label}}: {{fireTierPlain id}}{{/if}}{{/each}}{{else if campColdCampDecided}}Cold camp: no fire, −1 comfort, −2 encounter DC{{else}}No fire lit yet{{/if}}">
                    <i class="fas fa-fire totm-factor-tile-icon" aria-hidden="true"></i>
                    <span class="totm-factor-tile-label">Fire</span>
                    {{#if campFireIsLit}}
                    <span class="totm-factor-tile-status fire-active">🔥</span>
                    {{else if campColdCampDecided}}
                    <span class="totm-factor-tile-status cold"><i class="fas fa-moon" aria-hidden="true"></i></span>
                    {{else}}
                    <span class="totm-factor-tile-status missing"><i class="fas fa-times" aria-hidden="true"></i></span>
                    {{/if}}
                </div>
            </div>

            {{!-- Comfort + recovery card ─────────────────────────── --}}
            <div class="totm-rest-card comfort-{{campPersonalSelected.personalComfort}}">
                <div class="totm-rest-card-header comfort-{{campPersonalSelected.personalComfort}}" title="{{comfortHint campPersonalSelected.personalComfort}}">
                    <span class="totm-rest-card-title">{{campPersonalSelected.personalComfortLabel}}</span>
                    <span class="totm-rest-card-subtitle">Your Rest</span>
                </div>
                <div class="totm-rest-card-body">
                    {{!-- HP chip --}}
                    <span class="totm-rest-chip {{#if campPersonalSelected.recovery.hpFull}}success{{else}}warning{{/if}}">
                        <i class="fas fa-heart" aria-hidden="true"></i>
                        {{campPersonalSelected.recovery.hpLabel}}
                    </span>
                    {{!-- HD chip --}}
                    <span class="totm-rest-chip {{#if campPersonalSelected.recovery.hdSeverity}}{{campPersonalSelected.recovery.hdSeverity}}{{else}}success{{/if}}">
                        <i class="fas fa-cube" aria-hidden="true"></i>
                        {{campPersonalSelected.recovery.hdLabel}}
                    </span>
                    {{!-- Exhaustion chip --}}
                    {{#if campPersonalSelected.recovery.exhaustionDC}}
                    <span class="totm-rest-chip {{campPersonalSelected.recovery.exhaustionSeverity}}">
                        <i class="fas fa-exclamation-triangle" aria-hidden="true"></i>
                        {{campPersonalSelected.recovery.exhaustionLabel}}
                    </span>
                    {{else}}
                    <span class="totm-rest-chip success">
                        <i class="fas fa-shield-alt" aria-hidden="true"></i>
                        No exhaustion risk
                    </span>
                    {{/if}}
                </div>
            </div>

            {{else}}
            {{!-- ── No character selected: show party camp comfort ──────── --}}
            <div class="totm-camp-comfort-hero">
                <span class="totm-camp-comfort-label">Camp Comfort</span>
                <span class="totm-camp-comfort-tier-big comfort-{{campScanData.campComfort}}" title="{{comfortHint campScanData.campComfort}}">
                    {{campScanData.campComfortLabel}}
                </span>
            </div>
            {{#if mapComfortLine}}
            <p class="totm-camp-comfort-reason">{{mapComfortLine}}</p>
            {{/if}}
            <p class="totm-camp-no-selection">Select a character portrait above to see their personal comfort breakdown.</p>
            {{/if}}

        </div>
        {{else}}
        <div class="totm-camp-comfort-panel totm-safe-rest-note">
            <p class="totm-safe-rest-hint"><i class="fas fa-shield-alt" aria-hidden="true"></i> Safe rest spot: no comfort tiers or encounter pressure. Fire counts as lit for cooking.</p>
        </div>
        {{/unless}}

        {{!-- RIGHT: Campfire ceremony --}}
        <div class="totm-camp-fire-panel {{#if campFireIsLit}}fire-lit{{/if}} {{#if campColdCampDecided}}cold-camp{{/if}}">
            <div class="totm-camp-fire-header">
                <span class="totm-camp-fire-title"><i class="fas fa-fire" aria-hidden="true"></i> Campfire</span>
                {{#if campFireIsLit}}
                <span class="totm-camp-fire-status lit"><i class="fas fa-circle" aria-hidden="true"></i> {{campFireLabel}}</span>
                {{else if campColdCampDecided}}
                <span class="totm-camp-fire-status cold"><i class="fas fa-moon" aria-hidden="true"></i> Cold camp</span>
                {{else}}
                <span class="totm-camp-fire-status unlit"><i class="fas fa-circle" aria-hidden="true"></i> Unlit</span>
                {{/if}}
            </div>

            {{#unless safeRestSpot}}
            {{#if campFireIsLit}}
            {{!-- Fire is committed: show only the tier description --}}
            {{#each campFirePickerLevels}}
            {{#if selected}}
            <p class="totm-fire-segment-desc">{{> fireTierBody}}</p>
            {{/if}}
            {{/each}}
            {{else}}
            {{!-- Fire tier segmented control (Option C: All-in-one Strip) --}}
            <div class="totm-fire-segment-wrap">
                <div class="totm-fire-segments" role="radiogroup" aria-label="Fire intensity tiers">
                    {{!-- Cold Camp segment: only visible when fire is NOT yet lit --}}
                    {{#unless campFireIsLit}}
                    <button type="button"
                            class="totm-fire-segment cold-camp {{#if campColdCampDecided}}selected{{else}}{{#if campPreviewIsColdCamp}}selected{{/if}}{{/if}}"
                            data-tier="cold_camp"
                            {{#if campColdCampDecided}}aria-checked="true"{{else}}{{#if campPreviewIsColdCamp}}aria-checked="true"{{else}}aria-checked="false"{{/if}}{{/if}}
                            role="radio"
                            {{#unless campColdCampDecided}}
                            data-action="previewCampFireLevel" data-fire-level="cold_camp"
                            {{/unless}}>
                        <i class="fas fa-moon" aria-hidden="true"></i>
                        <span class="totm-fire-segment-label">Cold Camp</span>
                        <span class="totm-fire-segment-cost">No fire</span>
                    </button>
                    {{/unless}}
                    {{!-- Fire tier segments: Embers, Campfire, Bonfire --}}
                    {{#each campFirePickerLevels}}
                    <button type="button"
                            class="totm-fire-segment {{#if selected}}selected{{/if}} {{#if disabled}}{{#unless @root.isGM}}disabled{{/unless}}{{/if}}"
                            data-tier="{{id}}"
                            {{#if disabled}}{{#unless @root.isGM}}disabled{{/unless}} title="{{disabledReason}}"{{/if}}
                            {{#if selected}}aria-checked="true"{{else}}aria-checked="false"{{/if}}
                            role="radio"
                            {{#unless selected}}
                            {{#unless @root.campFireIsLit}}
                            data-action="previewCampFireLevel" data-fire-level="{{id}}"
                            {{/unless}}
                            {{/unless}}>
                        <span class="totm-fire-segment-label">{{label}}</span>
                        <span class="totm-fire-segment-cost">{{costLabel}}</span>
                    </button>
                    {{/each}}
                </div>
                {{!-- Show selected tier description --}}
                {{#each campFirePickerLevels}}
                {{#if selected}}
                <p class="totm-fire-segment-desc">{{> fireTierBody}}</p>
                {{/if}}
                {{/each}}
                {{!-- Cold camp description --}}
                {{#unless campFireIsLit}}
                {{#if campColdCampDecided}}
                <p class="totm-fire-segment-desc">No fire tonight. <span class="fire-penalty">−1 comfort.</span> <span class="fire-benefit">Harder to detect (lower encounter chance).</span> No cooking.</p>
                {{else if campPreviewIsColdCamp}}
                <p class="totm-fire-segment-desc">No fire tonight. <span class="fire-penalty">−1 comfort.</span> <span class="fire-benefit">Harder to detect (lower encounter chance).</span> No cooking.</p>
                {{/if}}
                {{/unless}}

                {{!-- ═══ FIRE BILL: Itemized requirements ═══ --}}
                {{#unless campFireIsLit}}
                {{#unless campColdCampDecided}}
                {{#unless campPreviewIsColdCamp}}
                <div class="totm-fire-bill">
                    {{!-- Line 1: Firewood cost --}}
                    <div class="totm-fire-bill-line {{#if campHasEnoughFirewood}}met{{else}}unmet{{/if}}">
                        {{#if campHasEnoughFirewood}}
                        <i class="fas fa-check" aria-hidden="true"></i>
                        {{else}}
                        <i class="fas fa-times" aria-hidden="true"></i>
                        {{/if}}
                        <span>{{campSelectedFirewoodCost}} firewood needed</span>
                        <span class="totm-fire-bill-detail">(party has {{campPartyFirewood}})</span>
                    </div>
                    {{!-- Line 2: Lighter availability --}}
                    <div class="totm-fire-bill-line {{#if campCanLight}}met{{else}}unmet{{/if}}">
                        {{#if campCanLight}}
                        <i class="fas fa-check" aria-hidden="true"></i>
                        <span class="totm-fire-bill-lighter" title="{{campFireLighterNames}}">
                            {{campFireLighters.length}} can light it
                        </span>
                        {{else}}
                        <i class="fas fa-times" aria-hidden="true"></i>
                        <span>No tinderbox or fire cantrip</span>
                        {{/if}}
                    </div>

                    {{!-- Action row: GM or player --}}
                    {{#if isGM}}
                    <button type="button" class="totm-fire-light-btn gm-light-submit"
                            data-action="campLightFire"
                            data-actor-id="__gm__"
                            data-method="Tinderbox"
                            title="Optional - players with gear see their own Light button. Use this as a GM override.">
                        <i class="fas fa-fire" aria-hidden="true"></i> Light it for them
                    </button>
                    {{else if campViewerCanLight}}
                    {{#each campFireLighters}}{{#if this.isViewerActor}}
                    <button type="button" class="totm-fire-light-btn player-light-submit"
                            data-action="campLightFire"
                            data-actor-id="{{this.actorId}}"
                            data-method="{{this.method}}">
                        <i class="fas fa-fire" aria-hidden="true"></i> Light
                    </button>
                    {{/if}}{{/each}}
                    {{else}}
                    <p class="totm-fire-bill-hint">
                        {{#if campFireLighters.length}}
                        Waiting for {{campFireLighterNames}} or the GM to light it.
                        {{else}}
                        Choose cold camp, or ask the GM.
                        {{/if}}
                    </p>
                    {{/if}}
                </div>
                {{/unless}}
                {{/unless}}
                {{/unless}}
            </div>
            {{/if}} {{!-- /campFireIsLit else --}}

            {{!-- Firewood pledges (after fire is lit) --}}
            {{#if campFireIsLit}}
            {{#if campFirewoodPledgeList.length}}
            <div class="totm-fire-pledges">
                <span class="totm-fire-pledges-label">Firewood pledged:</span>
                {{#each campFirewoodPledgeList}}
                <span class="totm-fire-pledge-entry">{{actorName}} ({{count}})</span>
                {{/each}}
            </div>
            {{/if}}
            {{/if}}
            {{else}}
            <p class="totm-fire-safe-note"><i class="fas fa-fire" aria-hidden="true"></i> Campfire counts as lit for cooking. No firewood spend and no encounter modifier.</p>
            {{/unless}}

            {{#if campFireIsLit}}
            {{!-- Cooking note: only campfire and bonfire support cooking, not embers --}}
            {{#if (or (eq campCurrentFireLevel "campfire") (eq campCurrentFireLevel "bonfire"))}}
            <p class="totm-fire-cooking-note">
                <i class="fas fa-utensils" aria-hidden="true"></i>
                Cooking and brewing available in the activity phase.
            </p>
            {{/if}}
            {{/if}}


        </div>
    </div>

    {{!-- Proceed footer (TotM) --}}
    {{#if isGM}}
    <div class="totm-camp-footer">
        {{#if (or safeRestSpot campFireIsLit campColdCampDecided)}}
        <button type="button" class="btn-primary totm-camp-proceed"
                data-action="proceedFromTotmCamp">
            <i class="fas fa-arrow-right" aria-hidden="true"></i> Proceed to Activities
        </button>
        {{else if campPreviewIsColdCamp}}
        <button type="button" class="btn-primary totm-camp-proceed cold-camp-confirm"
                data-action="campColdCamp">
            <i class="fas fa-moon" aria-hidden="true"></i> Confirm Cold Camp &amp; Proceed
        </button>
        {{else}}
        <button type="button" class="btn-primary totm-camp-proceed disabled" disabled>
            <i class="fas fa-lock" aria-hidden="true"></i> Light the fire or choose cold camp
        </button>
        {{/if}}
    </div>
    {{else}}
    <div class="totm-camp-footer">
        <span class="totm-camp-player-wait">
            <i class="fas fa-campground" aria-hidden="true"></i>
            {{#if (or safeRestSpot campFireIsLit campColdCampDecided)}}
            Camp is set. Waiting for the GM to proceed.
            {{else}}
            Setting up camp...
            {{/if}}
        </span>
    </div>
    {{/if}}

    {{!-- Spatial mode fallback --}}
    {{else}}
    <div class="camp-minimal-shell camp-phase-shell">
    {{#if showArtNudge}}
    <div class="art-nudge-banner">
        <div class="art-nudge-content">
            <i class="fas fa-palette art-nudge-icon"></i>
            <div class="art-nudge-text">
                {{#if artNudgeIsUpdate}}
                <span class="art-nudge-title">A newer art pack is available.</span>
                <span class="art-nudge-subtitle">Update to get station token art for workstations and camp gear.</span>
                {{else}}
                <span class="art-nudge-title">Camp art is using placeholder icons.</span>
                <span class="art-nudge-subtitle">Import the art pack for terrain and station art.</span>
                {{/if}}
            </div>
        </div>
        <div class="art-nudge-actions">
            <button type="button" data-action="openArtPackPatreon" class="art-nudge-btn">
                <i class="fas fa-external-link-alt"></i> {{#if artNudgeIsUpdate}}Get Update{{else}}Get Art Pack{{/if}}
            </button>
            <button type="button" data-action="openArtPackImport" class="art-nudge-btn primary">
                <i class="fas fa-file-import"></i> {{#if artNudgeIsUpdate}}Update Art Pack{{else}}Import Art Pack{{/if}}
            </button>
            <button type="button" data-action="dismissArtNudge" class="art-nudge-dismiss" title="Dismiss">
                <i class="fas fa-times"></i>
            </button>
        </div>
        <label class="art-nudge-suppress">
            <input type="checkbox" class="art-nudge-suppress-checkbox" />
            Don't show again
        </label>
    </div>
    {{/if}}
    {{#if campfirePlaced}}
    <p class="camp-minimal-lead glass-ui">Use the <strong>campfire</strong> on the map: light the fire, cold camp, or add fuel. Supply tokens show where stations appear after the fire is going.</p>
    {{else}}
    <p class="camp-minimal-lead glass-ui">
        {{#if isGM}}A preview follows the pointer. Click the map to drop the pit, or right-click / <kbd>Esc</kbd> to cancel.{{else}}The GM is placing the campfire.{{/if}}
    </p>
    {{/if}}
    {{#if isGM}}
    {{#if campPitPlacementCancelled}}
    <div class="camp-pit-retry glass-ui">
        <p>Placement was cancelled. Place the pit when ready.</p>
        <button type="button" class="btn-primary" data-action="retryCampPitPlacement"><i class="fas fa-map-pin"></i> Place campfire pit</button>
    </div>
    {{/if}}
    {{/if}}
    </div>
    {{#if isGM}}<div class="respite-action-bar camp-minimal-action"><span class="phase-waiting-label"><i class="fas fa-compass"></i> Map first</span></div>
    {{else}}<div class="respite-action-bar camp-minimal-action"><span class="phase-waiting-label"><i class="fas fa-campground"></i> Check the map</span></div>
    {{/if}}
    {{/if}}{{!-- /isTheaterMode --}}
    {{/if}}


    {{!-- =============== ACTIVITY PHASE =============== --}}
    {{#if (eq phase 'activity')}}
    <div class="phase-banner">
        <img src="{{terrainBanner}}" alt="" style="object-position: {{terrainBannerPos}}" onerror="this.onerror=null;this.src='{{terrainBannerFallback}}'">
    </div>
    {{> rosterStrip}}

    {{#unless isTheaterMode}}
    {{#if postStationChoiceReview}}
    <div class="station-choice-review-bar">
        <span class="station-choice-review-text">
            <i class="fas fa-map-marker-alt" aria-hidden="true"></i>
            Activity saved from the map. Review here or return to the canvas.
        </span>
        <button type="button" class="btn-secondary" data-action="exitStationChoiceReview">
            <i class="fas fa-arrow-left" aria-hidden="true"></i> Back to map
        </button>
    </div>
    {{/if}}
    {{/unless}}

    {{!-- Subtle separator between roster and tabs (DC shown in footer for GM) --}}
    <div class="roster-tab-fade"></div>

    {{!-- TotM: either the detail view (activity inspected) or the tabbed interface --}}
    {{#if isTheaterMode}}
    {{#if totmDetailPanel}}
    {{!-- Detail view: full-width, replaces the grid while an activity is being confirmed --}}
    <div class="totm-detail-view">
        <div class="totm-detail-header">
            <button type="button" class="totm-detail-back"
                    data-action="{{#if totmDetailPanel.isCrafting}}craftClose{{else}}cancelTotmFollowUp{{/if}}"
                    aria-label="Back to activities">
                <i class="fas fa-arrow-left" aria-hidden="true"></i>
            </button>
            <i class="{{totmDetailPanel.icon}} totm-detail-icon" aria-hidden="true"></i>
            <div class="totm-detail-titles">
                <span class="totm-detail-name">{{totmDetailPanel.name}}</span>
                <span class="totm-detail-actor">
                    <img src="{{totmDetailPanel.actorPortrait}}" alt="" class="totm-detail-portrait">
                    {{totmDetailPanel.actorName}}
                </span>
            </div>
        </div>

        {{#if totmDetailPanel.isCrafting}}
        {{!-- ═══════════ INLINE CRAFTING (TotM): uses station split-panel layout ═══════════ --}}
        {{#with totmDetailPanel.crafting}}
        <div class="crafting-picker station-crafting-panel crafting-split totm-crafting-embed{{#if rollPending}} station-crafting-panel--roll-pending{{/if}}">
            {{#if rollPending}}
            <div class="crafting-roll-blocking-overlay" role="status" aria-live="polite">
                <i class="fas fa-spinner fa-spin" aria-hidden="true"></i>
                <span>Waiting for the roll to finish...</span>
            </div>
            {{/if}}
            {{!-- ═══════════ AFTER CRAFTING ═══════════ --}}
            {{#if hasCrafted}}
            <div class="crafting-section crafting-result crafting-result-hero {{#if craftingResult.success}}result-success{{else}}result-failure{{/if}}">
                <div class="craft-result-hero">
                    <div class="craft-result-icon-wrap {{#if craftingResult.success}}glow-success{{else}}glow-failure{{/if}}">
                        {{#if craftingResult.success}}
                        <img src="{{craftingResult.output.img}}" alt="{{craftingResult.output.name}}" class="craft-result-icon">
                        {{else}}
                        <i class="fas fa-times craft-result-fail-icon"></i>
                        {{/if}}
                    </div>
                    {{#if craftingResult.success}}
                    <div class="craft-result-item-name">{{craftingResult.output.name}}{{#if craftingResult.output.quantity}} <span class="craft-result-qty">(×{{craftingResult.output.quantity}})</span>{{/if}}</div>
                    <div class="craft-result-badge badge-success"><i class="fas fa-check"></i> Crafted Successfully</div>
                    {{else}}
                    <div class="craft-result-item-name">{{craftingResult.recipeName}}</div>
                    <div class="craft-result-badge badge-failure"><i class="fas fa-times"></i> Crafting Failed</div>
                    {{/if}}
                </div>
                <div class="craft-result-divider"></div>
                <div class="craft-result-details">
                    <div class="craft-result-detail-row">
                        <i class="fas fa-dice-d20"></i>
                        <span>Rolled <strong>{{craftingResult.roll}}</strong> vs DC <strong>{{craftingResult.dc}}</strong></span>
                        <span class="risk-tag risk-{{craftingResult.riskTier}}">{{craftingResult.riskTier}}</span>
                    </div>
                    <div class="craft-result-detail-row narrative">
                        <i class="fas fa-feather-alt"></i>
                        <span>{{craftingResult.narrative}}</span>
                    </div>
                    {{#if craftingResult.ingredientsConsumed}}
                    <div class="craft-result-detail-row consumed">
                        <i class="fas fa-fire"></i>
                        <span>Ingredients consumed</span>
                    </div>
                    {{else}}
                    <div class="craft-result-detail-row preserved">
                        <i class="fas fa-shield-alt"></i>
                        <span>Ingredients preserved</span>
                    </div>
                    {{/if}}
                </div>

                {{#if craftingResult.isPartyMeal}}
                {{#if craftingResult.success}}
                <div class="feast-roster-section">
                    <div class="feast-roster-portraits">
                        {{#each craftingResult.partyRoster}}
                        <div class="feast-portrait {{#if alreadyWellFed}}already-fed{{else}}will-eat{{/if}}"
                             title="{{name}}{{#if alreadyWellFed}}: already Well Fed, goes to inventory{{else}}: will eat now{{/if}}">
                            <img src="{{img}}" alt="{{name}}" class="feast-portrait-img">
                            <span class="feast-portrait-badge">
                                {{#if alreadyWellFed}}
                                <i class="fas fa-box-open"></i>
                                {{else}}
                                <i class="fas fa-check"></i>
                                {{/if}}
                            </span>
                        </div>
                        {{/each}}
                    </div>
                    <span class="feast-roster-label">Feeds {{craftingResult.partyRoster.length}} party members</span>
                </div>
                {{/if}}
                {{/if}}
            </div>

            {{#if craftingResult.isPartyMeal}}
            {{#if craftingResult.success}}
            {{#unless craftingResult.partyMealDispositionDone}}
            <div class="feast-footer-actions">
                <button type="button" class="btn-secondary feast-keep-btn" data-action="craftClose">
                    <i class="fas fa-box"></i> Keep in inventory
                </button>
                <button type="button" class="btn-feast-serve" data-action="feastServeNow">
                    <i class="fas fa-utensils"></i> Serve Now
                </button>
            </div>
            {{else}}
            <div class="crafting-done-message">
                <i class="fas fa-utensils"></i> Serving complete. The shared dish is gone from the cook's inventory.
            </div>
            {{/unless}}
            {{else}}
            <div class="crafting-done-message">
                <i class="fas fa-moon"></i> Crafting complete for this rest.
            </div>
            {{/if}}
            {{else}}
            <div class="crafting-done-message">
                <i class="fas fa-moon"></i> Crafting complete for this rest.
            </div>
            {{/if}}

            {{else}}
            {{!-- ═══════════ SPLIT PANEL LAYOUT ═══════════ --}}
            <div class="crafting-split-body">

                {{!-- ── LEFT PANEL: Recipe List ── --}}
                <div class="crafting-list-panel">
                    <div class="crafting-list-heading">
                        <i class="fas fa-scroll"></i> Recipes
                    </div>
                    {{#if available.length}}
                    <div class="recipe-list recipe-list-compact">
                        {{#each available}}
                        <div class="recipe-card recipe-card-compact {{#if isSelected}}selected{{/if}}" data-action="craftSelectRecipe"
                            data-recipe-id="{{id}}">
                            <img src="{{outputImg}}" alt="{{name}}" class="recipe-icon recipe-icon-compact">
                            <div class="recipe-info">
                                <div class="recipe-name">{{name}}</div>
                                <div class="recipe-brief">
                                    {{#each ingredientList}}
                                    <span class="ingredient-pill met">{{required}}x {{name}}</span>
                                    {{/each}}
                                </div>
                            </div>
                        </div>
                        {{/each}}
                    </div>
                    {{else}}
                    <div class="crafting-empty">No recipes available with current ingredients.</div>
                    {{/if}}

                    {{!-- Missing Recipes --}}
                    {{#if partial.length}}
                    <div class="missing-toggle" data-action="craftToggleMissing">
                        <i class="fas fa-caret-{{#if showMissing}}down{{else}}right{{/if}}"></i>
                        Missing ({{partial.length}})
                    </div>
                    {{#if showMissing}}
                    <div class="missing-recipes">
                        {{#each partial}}
                        <div class="recipe-card recipe-card-compact partial">
                            <img src="{{outputImg}}" alt="{{name}}" class="recipe-icon-sm">
                            <div class="recipe-info">
                                <div class="recipe-name">{{name}}</div>
                                <div class="recipe-brief">
                                    {{#each ingredientList}}
                                    <span class="ingredient-pill {{#if met}}met{{else}}unmet{{/if}}">{{required}}x {{name}}</span>
                                    {{/each}}
                                </div>
                            </div>
                        </div>
                        {{/each}}
                    </div>
                    {{/if}}
                    {{/if}}
                </div>

                {{!-- ── RIGHT PANEL: Detail + Action ── --}}
                <div class="crafting-detail-panel">

                    {{!-- Hero Card: Selected Recipe --}}
                    {{#if selectedRecipe}}
                    <div class="recipe-hero">
                        <div class="recipe-hero-header">
                            <img src="{{selectedRecipe.outputImg}}" alt="{{selectedRecipe.name}}" class="recipe-hero-icon">
                            <div class="recipe-hero-titles">
                                <h3 class="recipe-hero-name">{{selectedRecipe.name}}</h3>
                                <div class="recipe-hero-dc-row">
                                    <span class="recipe-hero-dc"><i class="fas fa-dice-d20"></i> DC {{selectedRecipe.dcDisplay}}</span>
                                    {{#if selectedRecipe.dcBreakdown.hasModifiers}}
                                    <span class="dc-base-hint">{{selectedRecipe.dcBreakdown.base}} base</span>
                                    {{#each selectedRecipe.dcBreakdown.factors}}
                                    <span class="dc-factor-pill dc-factor-{{sign}}">{{label}}</span>
                                    {{/each}}
                                    {{/if}}
                                </div>
                                {{#if selectedRecipe.isPartyMeal}}
                                <span class="recipe-hero-badge badge-party-meal"><i class="fas fa-users"></i> Feeds the Party</span>
                                {{/if}}
                            </div>
                        </div>
                        {{#if selectedRecipe.description}}
                        <p class="recipe-hero-description">{{selectedRecipe.description}}</p>
                        {{/if}}

                        {{!-- Ingredient tokens --}}
                        <div class="recipe-hero-ingredients">
                            {{#each selectedRecipe.ingredientList}}
                            <div class="hero-ingredient-token {{#if met}}met{{else}}unmet{{/if}}" title="{{required}}x {{name}} (have {{available}})">
                                <img src="{{img}}" alt="{{name}}" class="hero-ingredient-icon">
                                <span class="hero-ingredient-qty">{{required}}</span>
                                <span class="hero-ingredient-name">{{name}}</span>
                            </div>
                            {{/each}}
                        </div>

                        {{!-- Buff preview --}}
                        {{#if selectedRecipe.buffPreview}}
                        <div class="recipe-hero-buff">
                            <span class="hero-buff-pill">
                                <i class="fas fa-magic"></i>
                                {{selectedRecipe.buffPreview.label}}
                                {{#if selectedRecipe.buffPreview.formula}}= {{selectedRecipe.buffPreview.formula}}{{/if}}
                            </span>
                            <span class="hero-buff-duration">{{selectedRecipe.buffPreview.duration}}</span>
                            {{#if (eq selectedRecipe.buffPreview.target "party")}}
                            <span class="hero-buff-target"><i class="fas fa-users"></i> Party</span>
                            {{/if}}
                        </div>
                        {{/if}}

                        {{!-- Satiation badges --}}
                        {{#if selectedRecipe.satiates.length}}
                        <div class="recipe-hero-satiates">
                            {{#each selectedRecipe.satiates}}
                            <span class="hero-satiate-badge satiate-{{this}}">
                                {{#if (eq this "food")}}<i class="fas fa-drumstick-bite"></i> Food{{/if}}
                                {{#if (eq this "water")}}<i class="fas fa-tint"></i> Water{{/if}}
                            </span>
                            {{/each}}
                            {{#if selectedRecipe.isWellFed}}
                            <span class="hero-satiate-badge satiate-wellfed"><i class="fas fa-heart"></i> Well Fed</span>
                            {{/if}}
                        </div>
                        {{/if}}

                        {{!-- Ambitious teaser --}}
                        {{#if isAmbitiousSelected}}
                        {{#if selectedRecipe.ambitiousName}}
                        <div class="recipe-hero-ambitious">
                            <i class="fas fa-fire-alt"></i>
                            <span>On success: <strong>{{selectedRecipe.ambitiousName}}</strong></span>
                        </div>
                        {{/if}}
                        {{/if}}
                    </div>
                    {{else}}
                    {{!-- Empty state --}}
                    <div class="recipe-hero recipe-hero-empty">
                        <div class="recipe-hero-placeholder">
                            <i class="fas fa-utensils"></i>
                            <span>Select a recipe to see details</span>
                        </div>
                    </div>
                    {{/if}}

                    {{!-- Step 2: Choose Approach --}}
                    <div class="crafting-step crafting-step-approach">
                        <div class="step-label"><span class="step-num">2</span> Choose Your Approach</div>
                        <div class="risk-selector">
                            {{#each riskTiers}}
                            <button type="button" class="btn-risk {{#if selected}}selected{{/if}}" data-action="craftSelectRisk"
                                data-risk="{{id}}">
                                <div class="risk-label">{{label}}</div>
                                <div class="risk-hint">{{hint}}</div>
                            </button>
                            {{/each}}
                        </div>
                    </div>

                    {{!-- Commitment Summary + Craft Button --}}
                    {{#if commitSummary}}
                    <div class="craft-commit-panel">
                        <div class="commit-header">Ready to Craft</div>
                        <div class="commit-visual-flow">
                            <div class="commit-inputs">
                                {{#each commitSummary.ingredients}}
                                <div class="commit-item-token" title="{{quantity}}x {{name}}">
                                    <img src="{{img}}" alt="{{name}}">
                                    <span class="commit-item-qty">{{quantity}}</span>
                                </div>
                                {{/each}}
                            </div>
                            <div class="commit-flow-arrow"><i class="fas fa-long-arrow-alt-right"></i></div>
                            <div class="commit-output-token" title="{{commitSummary.outputName}}">
                                <img src="{{commitSummary.outputImg}}" alt="{{commitSummary.outputName}}">
                                <span class="commit-output-name">{{commitSummary.outputName}}</span>
                            </div>
                        </div>
                        <div class="commit-details">
                            <span class="commit-detail">
                                <i class="fas fa-dice-d20"></i> {{commitSummary.skill}} vs DC {{commitSummary.dc}}
                                {{#if commitSummary.dcBreakdown.hasModifiers}}
                                <span class="commit-dc-factors">
                                    <span class="commit-dc-base">{{commitSummary.dcBreakdown.base}}</span>
                                    {{#each commitSummary.dcBreakdown.factors}}
                                    <span class="dc-factor-pill dc-factor-{{sign}}">{{label}}</span>
                                    {{/each}}
                                </span>
                                {{/if}}
                            </span>
                            <span class="commit-detail risk-tag risk-{{commitSummary.risk}}">
                                {{commitSummary.riskLabel}}
                            </span>
                            <span class="commit-detail commit-consequence">
                                {{commitSummary.failConsequence}}
                            </span>
                        </div>
                        <button type="button" class="btn-hero-craft" data-action="craftCommit">
                            <i class="fas fa-hammer"></i><span>Craft</span>
                        </button>
                    </div>
                    {{else}}
                    <div class="craft-commit-panel empty">
                        <div class="commit-placeholder">
                            <i class="fas fa-hand-pointer"></i> Select a recipe to see your crafting plan
                        </div>
                    </div>
                    {{/if}}
                </div>
            </div>

            {{/if}}

            {{!-- Footer --}}
            <div class="crafting-footer">
                <button type="button" class="btn-secondary" data-action="craftClose">
                    {{#if hasCrafted}}Close{{else}}Cancel{{/if}}
                </button>
            </div>
        </div>
        {{/with}}

        {{else}}
        {{!-- ═══════════ STANDARD ACTIVITY DETAIL ═══════════ --}}
        {{#if totmDetailPanel.description}}
        <p class="totm-detail-description">{{totmDetailPanel.description}}</p>
        {{/if}}
        {{#if totmDetailPanel.advisory}}
        <div class="totm-detail-advisory {{#if totmDetailPanel.advisoryUrgent}}urgent{{/if}}">
            <i class="fas {{#if totmDetailPanel.advisoryUrgent}}fa-exclamation-circle{{else}}fa-info-circle{{/if}}" aria-hidden="true"></i>
            {{totmDetailPanel.advisory}}
        </div>
        {{/if}}
        {{#if totmDetailPanel.outcomeHints.length}}
        <ul class="totm-detail-outcomes">
            {{#each totmDetailPanel.outcomeHints}}
            <li class="totm-outcome-hint {{this.type}}">
                <i class="fas fa-chevron-right" aria-hidden="true"></i>
                {{this.text}}
            </li>
            {{/each}}
        </ul>
        {{/if}}
        {{#if totmDetailPanel.armorHint}}
        <div class="totm-detail-armor-hint {{totmDetailPanel.armorHint.type}}">
            <i class="fas {{#if (eq totmDetailPanel.armorHint.type "positive")}}fa-shield-alt{{else}}fa-exclamation-triangle{{/if}}" aria-hidden="true"></i>
            {{totmDetailPanel.armorHint.text}}
        </div>
        {{/if}}
        {{#if totmDetailPanel.checkLabel}}
        <div class="totm-detail-check">
            <i class="fas fa-dice-d20" aria-hidden="true"></i>
            {{totmDetailPanel.checkLabel}}
        </div>
        {{else}}
        <div class="totm-detail-check totm-detail-nocheck">
            <i class="fas fa-check-circle" aria-hidden="true"></i>
            No check required
        </div>
        {{/if}}
        {{#if totmDetailPanel.followUpData}}
        <div class="totm-detail-followup">
            <label class="followup-label">{{totmDetailPanel.followUpData.label}}</label>
            {{#if (eq totmDetailPanel.followUpData.type "partyMember")}}
            <select class="followup-select totm-followup-select">
                {{#each totmDetailPanel.followUpData.options}}
                <option value="{{value}}" {{#if isSelected}}selected{{/if}}>{{label}}</option>
                {{/each}}
            </select>
            {{else if (eq totmDetailPanel.followUpData.type "radio")}}
            <div class="followup-radios">
                {{#each totmDetailPanel.followUpData.options}}
                <label class="followup-radio-label">
                    <input type="radio" name="totm-followup-input" value="{{value}}"
                        class="totm-followup-radio" {{#if isSelected}}checked{{/if}}>
                    {{label}}
                </label>
                {{/each}}
            </div>
            {{else if (eq totmDetailPanel.followUpData.type "select")}}
            {{#if totmDetailPanel.followUpData.goldInfo}}
            <div class="followup-gold-hint">
                <i class="fas fa-coins" aria-hidden="true"></i> {{totmDetailPanel.followUpData.goldInfo}}
            </div>
            {{/if}}
            <select class="followup-select totm-followup-select">
                {{#each totmDetailPanel.followUpData.options}}
                <option value="{{value}}" {{#if isSelected}}selected{{/if}} {{#if isDisabled}}disabled{{/if}}>{{label}}</option>
                {{/each}}
            </select>
            {{else if (eq totmDetailPanel.followUpData.type "actorItem")}}
            {{#if totmDetailPanel.followUpData.slotInfo}}
            <div class="attunement-slots">
                <i class="fas fa-gem" aria-hidden="true"></i> Attunement slots: {{totmDetailPanel.followUpData.slotInfo}}
            </div>
            {{/if}}
            <select class="followup-select totm-followup-select">
                {{#each totmDetailPanel.followUpData.options}}
                <option value="{{value}}" {{#if isSelected}}selected{{/if}}>{{label}}</option>
                {{/each}}
            </select>
            {{/if}}
        </div>
        {{/if}}
        {{#if totmDetailPanel.armorWarning}}
        <div class="armor-advisory {{#if totmDetailPanel.armorWarning.isDoffed}}doffed{{/if}}" title="{{totmDetailPanel.armorWarning.hint}}">
            <i class="fas fa-shield-alt"></i>
            <span class="armor-advisory-text">
                {{#if totmDetailPanel.armorWarning.isDoffed}}
                {{totmDetailPanel.armorWarning.name}} removed for rest
                {{else}}
                {{totmDetailPanel.armorWarning.name}} ({{totmDetailPanel.armorWarning.type}}) - don time: {{totmDetailPanel.armorWarning.donTime}}
                {{/if}}
            </span>
            <button type="button" class="btn-armor-toggle"
                data-actor-id="{{totmDetailPanel.armorWarning.actorId}}"
                data-item-id="{{totmDetailPanel.armorWarning.itemId}}"
                data-is-doffed="{{totmDetailPanel.armorWarning.isDoffed}}"
                title="{{#if totmDetailPanel.armorWarning.isDoffed}}Re-equip armor{{else}}Remove armor for rest{{/if}}">
                {{#if totmDetailPanel.armorWarning.isDoffed}}
                <i class="fas fa-shield-alt"></i> Don
                {{else}}
                <i class="fas fa-bed"></i> Doff
                {{/if}}
            </button>
        </div>
        {{/if}}
        <div class="totm-detail-actions">
            <button type="button" class="totm-detail-confirm-btn" data-action="confirmTotmFollowUp">
                <i class="fas fa-check" aria-hidden="true"></i> Confirm Activity
            </button>
        </div>
        {{/if}} {{!-- /isCrafting --}}
    </div>
    {{else}}
    {{!-- Tab bar --}}
    <div class="totm-tab-bar">
        <button type="button" class="totm-tab {{#if (eq totmActiveTab 'activities')}}active{{/if}}"
                data-action="switchTotmTab" data-totm-tab="activities">
            <i class="fas fa-running" aria-hidden="true"></i> Activities
        </button>
        <button type="button" class="totm-tab {{#if (eq totmActiveTab 'identify')}}active{{/if}}"
                data-action="switchTotmTab" data-totm-tab="identify">
            <i class="fas fa-search" aria-hidden="true"></i> Identify
        </button>
        {{#unless safeRestSpot}}

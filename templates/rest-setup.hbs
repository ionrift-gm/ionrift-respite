{{!-- Ionrift Respite: Rest Setup Template (ApplicationV2) --}}
{{!-- Dual-mode: GM has full control, Players see shared campsite view --}}

<form class="respite-form">

    {{!-- Phase Indicator --}}
    <div class="respite-phase-header">
        <div class="phase-indicator">
            <div
                class="phase-dot {{#if (eq phase 'setup')}}active{{/if}} {{#if (or (eq phase 'travel') (eq phase 'camp') (eq phase 'activity') (eq phase 'reflection') (eq phase 'events') (eq phase 'resolve'))}}complete{{/if}}">
            </div>
            <div
                class="phase-dot {{#if (eq phase 'travel')}}active{{/if}} {{#if (or (eq phase 'camp') (eq phase 'activity') (eq phase 'reflection') (eq phase 'events') (eq phase 'resolve'))}}complete{{/if}}">
            </div>
            <div
                class="phase-dot {{#if (eq phase 'camp')}}active{{/if}} {{#if (or (eq phase 'activity') (eq phase 'reflection') (eq phase 'events') (eq phase 'resolve'))}}complete{{/if}}">
            </div>
            <div
                class="phase-dot {{#if (eq phase 'activity')}}active{{/if}} {{#if (or (eq phase 'reflection') (eq phase 'events') (eq phase 'resolve'))}}complete{{/if}}">
            </div>
            <div
                class="phase-dot {{#if (eq phase 'reflection')}}active{{/if}} {{#if (or (eq phase 'events') (eq phase 'resolve'))}}complete{{/if}}">
            </div>
            <div class="phase-dot {{#if (eq phase 'events')}}active{{/if}} {{#if (eq phase 'resolve')}}complete{{/if}}">
            </div>
            <div class="phase-dot {{#if (eq phase 'resolve')}}active{{/if}}"></div>
        </div>
        <span class="phase-label">
            {{#if (eq phase 'setup')}}Setup{{/if}}
            {{#if (eq phase 'travel')}}Travel{{/if}}
            {{#if (eq phase 'camp')}}Make Camp{{/if}}
            {{#if (eq phase 'activity')}}Activities{{/if}}
            {{#if (eq phase 'reflection')}}Campfire{{/if}}
            {{#if (eq phase 'events')}}Events{{/if}}
            {{#if (eq phase 'resolve')}}Resolution{{/if}}
        </span>

        {{#if isGM}}
        <button type="button" class="btn-abandon-rest" data-action="abandonRest" title="Cancel this rest for all players">
            <i class="fas fa-times"></i> Abandon Rest
        </button>
        {{/if}}
    </div>

    {{!-- Camp Status Bar: persistent across all phases post-setup --}}
    {{#if campStatus}}
    {{#unless (eq phase 'activity')}}
    {{#unless (eq phase 'camp')}}
    <div class="camp-status-bar">
        {{!-- Comfort badge removed: the Camp Comfort section below covers this --}}
        {{#if campStatus.weather}}
        {{#unless (eq campStatus.weather "clear")}}
        <span class="camp-status-chip weather-chip" title="{{campStatus.weatherTooltip}}">
            <i class="fas fa-cloud-sun-rain"></i> {{campStatus.weatherLabel}}
        </span>
        {{/unless}}
        {{/if}}
        {{#each campStatus.activeShelters}}
        <span class="camp-status-chip shelter-chip shelter-chip-{{id}}" title="{{tooltip}}">
            <i class="{{icon}}"></i> {{name}}
        </span>
        {{/each}}
        {{#unless campStatus.hasTent}}
        <span class="camp-status-chip shelter-chip absent" title="No tent: exposed to weather penalties">
            <i class="fas fa-campground"></i> Tent
        </span>
        {{/unless}}
        {{!-- Fire badge removed: the fire section below covers this --}}
    </div>
    {{/unless}}
    {{/unless}}
    {{/if}}


    {{!-- =============== SETUP PHASE =============== --}}
    {{#if (eq phase 'setup')}}
    <div class="phase-banner">
        <img src="{{terrainBanner}}" alt="" style="object-position: {{terrainBannerPos}}" onerror="this.onerror=null;this.src='{{terrainBannerFallback}}'">
    </div>

    {{#if isGM}}
    {{#if emptyParty}}
    <div class="respite-setup">
        <div class="respite-empty-party-hint">
            <i class="fas fa-users-slash"></i>
            <p>No player-owned characters found.</p>
            <p>Create or import characters and assign them to players, then reopen Respite.</p>
        </div>
    </div>
    {{else}}
    <div class="respite-setup">

        {{!-- Party Roster Indicator --}}
        {{#if rosterInfo}}
        <div class="roster-indicator">
            <div class="roster-indicator-portraits">
                {{#each rosterInfo.portraits}}
                <img class="roster-indicator-portrait" src="{{img}}" alt="{{name}}" title="{{name}}">
                {{/each}}
                {{#if rosterInfo.overflow}}
                <span class="roster-indicator-overflow">+{{rosterInfo.overflow}}</span>
                {{/if}}
            </div>
            <span class="roster-indicator-label">{{rosterInfo.count}} characters</span>
            <button type="button" class="roster-indicator-edit" onclick="const App = game.ionrift?.library?.PartyRosterApp; if (App) new App().render(true); else ui.notifications.warn('Party Roster requires ionrift-library.');" title="Edit Party Roster">
                <i class="fas fa-pencil-alt"></i>
            </button>
        </div>
        {{/if}}

        {{!-- Scene: Rest Type + Environment + Weather --}}
        <div class="scene-grid">
            <div class="form-group scene-rest-type">
                <label>Rest Type</label>
                <div class="rest-type-toggle">
                    <button type="button" class="rest-type-btn {{#unless (eq selectedRestType 'short')}}active{{/unless}}"
                        data-rest-type="long">
                        <i class="fas fa-moon"></i> Long Rest
                    </button>
                    <button type="button" class="rest-type-btn {{#if (eq selectedRestType 'short')}}active{{/if}}"
                        data-rest-type="short">
                        <i class="fas fa-mug-hot"></i> Short Rest
                    </button>
                    <input type="hidden" name="restType" value="{{#if (eq selectedRestType 'short')}}short{{else}}long{{/if}}">
                </div>
            </div>
            {{#unless isShortRest}}
            <div class="form-group scene-environment">
                <label>Environment</label>
                <select name="terrain">
                    {{#each terrainOptions}}
                    <option value="{{value}}" {{#if (eq value ../selectedTerrain)}}selected{{/if}}>{{label}}</option>
                    {{/each}}
                </select>
                <span class="terrain-hint" id="terrain-hint">{{terrainPreview}}</span>
            </div>
            {{/unless}}
            {{!-- Weather: only shown for Long Rest --}}
            {{#unless isShortRest}}
            <div class="form-group scene-weather">
                <label>Weather</label>
                <select name="weather">
                    {{#each weatherOptions}}
                    <option value="{{value}}" title="{{hint}}" {{#if (eq value ../defaultWeather)}}selected{{/if}}>{{label}}</option>
                    {{/each}}
                </select>
                {{#each weatherOptions}}
                {{#if (eq value ../defaultWeather)}}
                <span class="weather-hint">{{hint}}</span>
                {{/if}}
                {{/each}}
            </div>
            {{/unless}}
        </div>

        {{!-- Advanced Drawer (collapsed by default) --}}
        <details class="scene-advanced-drawer">
            <summary class="scene-advanced-toggle">
                <i class="fas fa-cog"></i> Advanced
            </summary>
            <div class="scene-advanced-body">
                {{#if trackFood}}
                <div class="days-since-rest-block">
                    <div class="days-since-rest-row">
                        <span class="days-label"><i class="fas fa-calendar-day"></i> Days Since Last Rest</span>
                        <div class="days-stepper">
                            <button type="button" class="days-btn" data-action="adjustDaysSinceRest" data-delta="-1" {{#if (eq daysSinceLastRest 1)}}disabled{{/if}}>−</button>
                            <span class="days-value">{{daysSinceLastRest}}</span>
                            <button type="button" class="days-btn" data-action="adjustDaysSinceRest" data-delta="1" {{#if (gte daysSinceLastRest 9)}}disabled{{/if}}>+</button>
                        </div>
                    </div>
                    <span class="days-hint"><i class="fas fa-book"></i> Characters can only benefit from one long rest per 24 hours. (PHB p.186)</span>
                    {{#if (gte daysSinceLastRest 2)}}
                    <span class="days-hint warning"><i class="fas fa-exclamation-triangle"></i> {{daysSinceLastRest}} days without rest. Characters are treated as having gone without food and water for that duration.</span>
                    {{/if}}
                </div>
                {{/if}}
                {{#if scoutingAvailable}}
                <div class="scouting-toggle-block">
                    <label class="scouting-toggle-label">
                        <input type="checkbox" name="scoutingAllowed" {{#if scoutingAllowed}}checked{{/if}} />
                        <i class="fas fa-binoculars"></i>
                        <span>Allow scouting during travel</span>
                    </label>
                    <span class="scouting-toggle-hint">When enabled, characters can scout for a campsite during travel. Scouting adjusts encounter risk.</span>
                </div>
                {{/if}}
                <div class="form-group scene-comfort-override">
                    <label>Comfort Override</label>
                    <select name="comfort">
                        {{#each comfortOptions}}
                        <option value="{{value}}" title="{{hint}}" {{#if (eq value ../defaultComfort)}}selected{{/if}}>{{label}}</option>
                        {{/each}}
                    </select>
                    <span class="comfort-hint">Override the comfort derived from player gear. Leave at terrain default unless you have a reason to change it.</span>
                </div>
            </div>
        </details>

    </div>
    <div class="respite-action-bar">
        {{#if isShortRest}}
        <button type="button" class="btn-primary" data-action="beginShortRest">
            <i class="fas fa-mug-hot"></i> Begin Short Rest
        </button>
        {{else}}
        <button type="button" class="btn-primary" data-action="beginRest">
            <i class="fas fa-campground"></i> Begin Rest
        </button>
        {{/if}}
    </div>
    {{/if}} {{!-- /emptyParty --}}
    {{else}}
    {{!-- Player: waiting for GM to start --}}
    <div class="respite-setup">
        <div class="respite-waiting-message">
            <i class="fas fa-campground"></i>
            <p>The GM is preparing the campsite...</p>
        </div>
    </div>
    {{/if}}
    {{/if}}

    {{!-- =============== TRAVEL RESOLUTION PHASE =============== --}}
    {{#if (eq phase 'travel')}}
    <div class="phase-banner">
        <img src="{{terrainBanner}}" alt="" style="object-position: {{terrainBannerPos}}" onerror="this.onerror=null;this.src='{{terrainBannerFallback}}'">
    </div>

    {{#if travelContext}}
    <div class="respite-travel-phase {{#if travelContext.travelSkipRecommended}}travel-skip-mode{{else}}{{#unless travelContext.hasTravelOptions}}travel-disabled{{/unless}}{{/if}}">
        {{#if isGM}}
        <div class="travel-header">
            <i class="fas fa-hiking"></i>
            <span>Travel Resolution: {{travelContext.terrainLabel}}</span>
        </div>
        {{/if}}

        {{!-- ═══ SKIP ACKNOWLEDGMENT (no forage/hunt) ═══ --}}
        {{#if travelContext.travelSkipRecommended}}
        <div class="travel-skip-notice">
            <p class="travel-skip-reason">{{travelContext.disabledReason}}</p>
        </div>
        {{#if isGM}}
        <div class="respite-action-bar">
            <button type="button" class="btn-primary travel-skip-pulse" data-action="skipTravelPhase">
                <i class="fas fa-forward"></i> Continue
            </button>
        </div>
        {{else}}
        <div class="travel-player-info">
            <i class="fas fa-hiking"></i>
            <span>The party presses on...</span>
        </div>
        {{/if}}

        {{else}}
        {{#if travelContext.hasTravelOptions}}

        {{!-- ═══ GM VIEW ═══ --}}
        {{#if isGM}}
        <div class="travel-dc-bar">
            {{#if travelContext.canForage}}
            <span class="travel-dc-chip">
                <i class="fas fa-seedling"></i> Forage DC {{travelContext.forageDC}}
                {{#if travelContext.forageGMAdj}}
                <span class="encounter-chip"><i class="fas fa-wrench"></i> GM {{travelContext.forageGMAdj}}</span>
                {{/if}}
                <span class="encounter-gm-adj">
                    <button type="button" class="encounter-adj-btn" data-action="adjustGlobalDC" data-activity="forage" data-delta="-1" title="Reduce Forage DC">−</button>
                    <button type="button" class="encounter-adj-btn" data-action="adjustGlobalDC" data-activity="forage" data-delta="1" title="Increase Forage DC">+</button>
                </span>
            </span>
            {{/if}}
            {{#if travelContext.canHunt}}
            <span class="travel-dc-chip">
                <i class="fas fa-crosshairs"></i> Hunt DC {{travelContext.huntDC}}
                {{#if travelContext.huntGMAdj}}
                <span class="encounter-chip"><i class="fas fa-wrench"></i> GM {{travelContext.huntGMAdj}}</span>
                {{/if}}
                <span class="encounter-gm-adj">
                    <button type="button" class="encounter-adj-btn" data-action="adjustGlobalDC" data-activity="hunt" data-delta="-1" title="Reduce Hunt DC">−</button>
                    <button type="button" class="encounter-adj-btn" data-action="adjustGlobalDC" data-activity="hunt" data-delta="1" title="Increase Hunt DC">+</button>
                </span>
            </span>
            {{/if}}
        </div>

        {{!-- Multi-day tabs --}}
        {{#if travelContext.isMultiDay}}
        <div class="travel-day-tabs">
            {{#each travelContext.days}}
            <button type="button" class="travel-day-tab {{#if isActive}}active{{/if}} {{#if resolved}}resolved{{/if}}" data-action="switchTravelDay" data-day="{{day}}">
                {{#if resolved}}<i class="fas fa-check"></i>{{/if}}
                Day {{day}}{{#if isFinalDay}} <i class="fas fa-campground" title="Arrival day, scouting available"></i>{{/if}}
            </button>
            {{/each}}
        </div>
        {{/if}}

        {{!-- Active day content --}}
        {{#each travelContext.days}}
        {{#if isActive}}
        <div class="travel-day-section" data-day="{{day}}">

            {{#if isFinalDay}}
            {{#if ../travelContext.canScout}}
            <div class="travel-scout-notice">
                <i class="fas fa-campground"></i> Arrival at this site. Scouting, rest, foraging, and making camp are all in play. Resolve the day below to see who did what.
            </div>
            {{/if}}
            {{/if}}

            <div class="travel-character-list">
                {{#each characters}}
                <div class="travel-character-row {{#if (eq status 'resolved')}}resolved{{/if}} {{#if confirmed}}player-confirmed{{/if}} {{#if awaitingPlayerResponse}}row-awaiting{{/if}}">
                    <img class="travel-portrait" src="{{img}}" alt="{{name}}" />
                    <div class="travel-char-info">
                        <span class="travel-char-name">{{name}}{{#if confirmed}}<span class="travel-confirmed-pick">{{#if (eq activity 'forage')}}<i class="fas fa-seedling"></i> Forage
                        {{else if (eq activity 'hunt')}}<i class="fas fa-crosshairs"></i> Hunt
                        {{else if (eq activity 'scout')}}<i class="fas fa-binoculars"></i> Scout
                        {{else}}<span class="travel-other-emoji" aria-hidden="true">&#127969;</span> Other{{/if}} <i class="fas fa-check travel-confirmed-icon" title="Player locked in"></i></span>{{else}}<span class="travel-pending-pick" title="Not confirmed yet">{{#if (eq activity 'forage')}}<i class="fas fa-seedling"></i> Forage
                        {{else if (eq activity 'hunt')}}<i class="fas fa-crosshairs"></i> Hunt
                        {{else if (eq activity 'scout')}}<i class="fas fa-binoculars"></i> Scout
                        {{else}}<span class="travel-other-emoji" aria-hidden="true">&#127969;</span> Other{{/if}}</span>{{/if}}</span>
                        <span class="travel-char-mod">Survival {{survivalMod}}</span>
                    </div>

                    {{#if result}}
                    <div class="travel-gm-result-cell">
                    <div class="travel-result {{#if (eq result.activity 'other')}}other{{else if result.nat20}}nat20{{else if result.nat1}}nat1{{else if result.success}}success{{else if (eq result.activity 'scout')}}scout{{else}}failure{{/if}}">
                        {{#if (eq result.activity 'other')}}<i class="fas fa-dice-d20"></i> {{result.total}} vs DC {{result.dc}} {{#if result.success}}✓{{else}}✗{{/if}}
                        {{else if (eq result.activity 'scout')}}<i class="fas fa-binoculars"></i> Scouted ({{result.total}})
                        {{else if result.nat20}}<i class="fas fa-star"></i> Nat 20!
                        {{else if result.nat1}}<i class="fas fa-skull"></i> Nat 1!
                        {{else if result.exceptional}}<i class="fas fa-award"></i> Exceptional
                        {{else if result.success}}<i class="fas fa-check"></i> Success
                        {{else}}<i class="fas fa-times"></i> Failed{{/if}}
                        {{#unless (eq result.activity 'scout')}}{{#unless (eq result.activity 'other')}}<span class="travel-roll-total">({{result.total}})</span>{{/unless}}{{/unless}}
                    </div>
                    {{#if (eq result.activity 'forage')}}
                    {{#if result.items.length}}
                    <div class="travel-gm-yield-badges" aria-label="Foraged">
                        {{#each result.items}}
                        <span class="travel-item-badge travel-item-badge--forage"><i class="fas fa-leaf"></i> {{quantity}}x {{#if itemData.name}}{{itemData.name}}{{else}}{{itemRef}}{{/if}}</span>
                        {{/each}}
                    </div>
                    {{else}}
                    {{#unless result.success}}
                    <div class="travel-gm-yield-nothing">Nothing found.</div>
                    {{/unless}}
                    {{/if}}
                    {{/if}}
                    {{#if (eq result.activity 'hunt')}}
                    {{#if result.items.length}}
                    <div class="travel-gm-yield-badges" aria-label="Hunted">
                        {{#each result.items}}
                        <span class="travel-item-badge travel-item-badge--hunt"><i class="fas fa-drumstick-bite"></i> {{quantity}}x {{#if itemData.name}}{{itemData.name}}{{else}}{{itemRef}}{{/if}}</span>
                        {{/each}}
                    </div>
                    {{else}}
                    {{#unless result.success}}
                    <div class="travel-gm-yield-nothing">Nothing found.</div>
                    {{/unless}}
                    {{/if}}
                    {{/if}}
                    {{#if result.mishap}}
                    <div class="travel-mishap--in-cell">
                        <i class="fas fa-exclamation-triangle"></i> {{result.mishap.description}}
                        {{#if result.mishap.appliedSummaries.length}}
                        <div class="travel-mishap-effect-badges" aria-label="Applied effects">
                            {{#each result.mishap.appliedSummaries}}
                            <span class="travel-mishap-effect-badge">{{this}}</span>
                            {{/each}}
                        </div>
                        {{/if}}
                    </div>
                    {{/if}}
                    </div>

                    {{else if (eq status 'rolled')}}
                    <span class="travel-result success"><i class="fas fa-check"></i> Rolled {{total}}</span>

                    {{else if requested}}
                    <div class="travel-gm-activity-pick">
                    <span class="travel-pending-label"><i class="fas fa-paper-plane"></i> Sent</span>
                    {{#if awaitingPlayerResponse}}<span class="travel-player-await" title="Waiting for a roll"><i class="fas fa-circle-notch fa-spin"></i></span>{{/if}}
                    <button type="button" class="btn-roll-for-player travel-fallback" data-action="rollTravelForPlayer" data-actor-id="{{id}}" data-day="{{../day}}" title="Roll on their behalf">
                        <i class="fas fa-dice"></i>
                    </button>
                    </div>

                    {{else if otherLockedIn}}
                    <div class="travel-gm-activity-pick travel-gm-other-locked">
                        <span class="travel-gm-other-locked-label" title="Other, confirmed for this day"><span class="travel-other-emoji" aria-hidden="true">&#127969;</span> Other</span>
                        <span class="travel-gm-confirmed-badge" title="Locked in as Other"><i class="fas fa-check"></i></span>
                    </div>

                    {{else}}
                    {{!-- Uncommitted: GM can change activities. Plain Other: Confirm until locked (see otherLockedIn). --}}
                    <div class="travel-gm-activity-pick">
                    <select class="travel-activity-select" data-actor-id="{{id}}" data-day="{{../day}}">
                        <option value="nothing" {{#if (eq activity 'nothing')}}selected{{/if}}>🏕️ Other</option>
                        {{#if ../../travelContext.canForage}}<option value="forage" {{#if (eq activity 'forage')}}selected{{/if}}>🌿 Forage</option>{{/if}}
                        {{#if ../../travelContext.canHunt}}<option value="hunt" {{#if (eq activity 'hunt')}}selected{{/if}}>🎯 Hunt</option>{{/if}}
                        {{#if ../canScout}}<option value="scout" {{#if (eq activity 'scout')}}selected{{/if}}>🔭 Scout</option>{{/if}}
                    </select>
                    {{#if awaitingPlayerResponse}}<span class="travel-player-await" title="Waiting for this character"><i class="fas fa-circle-notch fa-spin"></i></span>{{/if}}
                    {{#if (eq activity 'nothing')}}
                    <button type="button" class="travel-gm-confirm-for-btn" data-action="confirmTravelForPlayer" data-actor-id="{{id}}" data-day="{{../day}}" title="Confirm Other on their behalf (absent player)">
                        <i class="fas fa-check"></i> Confirm
                    </button>
                    {{else}}
                    <button type="button" class="btn-roll-for-player travel-gm-direct-roll" data-action="rollTravelForPlayer" data-actor-id="{{id}}" data-day="{{../day}}" title="Roll on their behalf (absent player)">
                        <i class="fas fa-dice"></i>
                    </button>
                    {{/if}}
                    </div>
                    {{/if}}
                </div>
                {{/each}}
            </div>

            {{!-- Day action bar: Resolve always shown when day open; disabled until allRollsIn --}}
            <div class="respite-action-bar travel-day-resolve-bar">
                {{#if resolved}}
                <span class="travel-day-resolved-label"><i class="fas fa-check"></i> Day {{day}} resolved</span>
                {{else}}
                <div class="travel-resolve-day-wrap">
                <button type="button" class="btn-primary travel-resolve-day-btn" data-action="resolveTravelDay" data-day="{{day}}"
                    {{#unless allRollsIn}}disabled title="Unlocks when every party member has rolled or confirmed."{{/unless}}>
                    <i class="fas fa-check"></i> Resolve Day {{day}}
                </button>
                {{#unless allRollsIn}}
                <span class="travel-waiting-label travel-resolve-pending-hint"><i class="fas fa-hourglass-half"></i> Still pending</span>
                {{/unless}}
                </div>
                {{/if}}
            </div>
        </div>
        {{/if}}
        {{/each}}

        {{!-- GM Scouting debrief panel --}}
        {{#if scoutingDebrief}}
        <div class="travel-scouting-debrief {{scoutingDebrief.tier}}">
            <div class="travel-scouting-header">
                <i class="fas fa-binoculars"></i>
                <strong>Scouting: {{scoutingDebrief.tierLabel}}</strong>
                {{#if scoutingDebrief.comfortBonus}}<span class="scouting-effect">Comfort +{{scoutingDebrief.comfortBonus}}</span>{{/if}}
                {{#if scoutingDebrief.encounterCampModLabel}}<span class="scouting-effect">Night check mod {{scoutingDebrief.encounterCampModLabel}}</span>{{/if}}
            </div>
            <p class="travel-scouting-gm-advisory">Scouting roll is blind to the players. Describe what the scout found.</p>

            {{!-- Scout roster --}}
            <div class="travel-scout-roster {{#if scoutingDebrief.multipleScouts}}multi{{/if}}">
                {{#each scoutingDebrief.scouts}}
                <div class="travel-scout-entry {{#if isBest}}best{{/if}}">
                    <span class="scout-name">{{actorName}}</span>
                    <span class="scout-total">{{total}}</span>
                    {{#if isBest}}<span class="scout-best-badge">★ Best</span>{{/if}}
                    {{#if narrative}}
                    <div class="scout-narrative"><em>"{{narrative}}"</em></div>
                    {{/if}}
                </div>
                {{/each}}
            </div>

            {{#if scoutingDebrief.gmHint}}
            <div class="travel-scouting-gm-hint">
                <i class="fas fa-exclamation-triangle"></i> {{scoutingDebrief.gmHint}}
            </div>
            {{/if}}
            {{#if scoutingDebrief.isNat1}}
            <div class="travel-scouting-gm-hint danger">
                <i class="fas fa-skull-crossbones"></i> A hidden complication will trigger during the event phase. The players believe this is a good campsite.
            </div>
            {{/if}}
        </div>
        {{/if}}

        {{!-- Global travel action bar --}}
        <div class="respite-action-bar travel-global-actions">
            {{#if travelContext.fullyResolved}}
            <button type="button" class="btn-primary" data-action="skipTravelPhase">
                <i class="fas fa-arrow-right"></i> Continue to Activities
            </button>
            {{else}}
            <button type="button" data-action="skipTravelPhase">
                <i class="fas fa-forward"></i> Skip Travel
            </button>
            {{/if}}
        </div>

        {{!-- ═══ PLAYER VIEW ═══ --}}
        {{else}}
        <div class="travel-player-view">

            {{!-- Priority 1: Debrief (results received from GM) --}}
            {{#if travelDebrief}}
            <div class="travel-player-info">
                <i class="fas fa-scroll"></i>
                <span>Travel results are in.</span>
            </div>
            <div class="travel-debrief-section">
                {{#each travelDebrief}}
                <div class="travel-debrief-entry {{#if result.success}}success{{else if result.nat20}}nat20{{else if result.nat1}}nat1{{else}}failure{{/if}}">
                    <div class="travel-debrief-header">
                        {{#if result.nat20}}<i class="fas fa-star"></i>{{else if result.nat1}}<i class="fas fa-skull"></i>{{else if result.success}}<i class="fas fa-check"></i>{{else}}<i class="fas fa-times"></i>{{/if}}
                        <strong>{{result.actorName}}</strong>
                        <span class="debrief-activity">
                            {{#if (eq activity 'forage')}}🌿 Foraged{{else if (eq activity 'hunt')}}🎯 Hunted{{else}}Rolled{{/if}}
                        </span>
                        <span class="debrief-total">({{result.total}})</span>
                    </div>
                    {{#if result.items.length}}
                    <div class="travel-debrief-items">
                        {{#each result.items}}
                        <span class="travel-item-badge"><i class="fas fa-leaf"></i> {{quantity}}x {{itemData.name}}</span>
                        {{/each}}
                    </div>
                    {{/if}}
                    {{#if result.mishap}}
                    <div class="travel-debrief-mishap">
                        <i class="fas fa-exclamation-triangle"></i> {{result.mishap.description}}
                    </div>
                    {{/if}}
                    {{#unless result.success}}
                    {{#unless result.items}}
                    <div class="travel-debrief-nothing">
                        <span>Nothing found.</span>
                    </div>
                    {{/unless}}
                    {{/unless}}
                </div>
                {{/each}}
            </div>

            {{#if travelScoutingDone}}
            <div class="travel-player-scout-summary">
                <i class="fas fa-binoculars"></i>
                <span>Your scouts have surveyed the area. The GM will describe the campsite before the party settles in.</span>
            </div>
            {{/if}}

            {{#if travelFullyResolved}}
            <div class="travel-player-info travel-waiting-gm">
                <i class="fas fa-hourglass-half"></i>
                <span>Waiting for the GM to continue...</span>
            </div>
            {{/if}}

            {{!-- Priority 2: Roll requests from GM --}}
            {{else if pendingTravelRoll.activities.length}}
            <div class="travel-player-info">
                <i class="fas fa-dice-d20"></i>
                <span>The GM has called for travel rolls.</span>
            </div>
            <div class="travel-roll-section">
                {{#each pendingTravelRoll.activities}}
                {{#if isOwner}}
                <div class="travel-roll-prompt {{#if rolled}}rolled{{/if}}">
                    <div class="travel-roll-info">
                        <strong>{{actorName}}: {{activityLabel}}</strong>
                        <span class="travel-roll-skill">{{skillName}}{{#if dc}} DC {{dc}}{{/if}}</span>
                    </div>
                    {{#if rolled}}
                    <span class="travel-roll-result pending">
                        <i class="fas fa-spinner fa-spin"></i> Awaiting...
                    </span>
                    {{else}}
                    <button type="button" class="btn-primary btn-travel-roll" data-action="rollTravelCheck" data-actor-id="{{actorId}}" data-day="{{day}}">
                        <i class="fas fa-dice-d20"></i> Roll
                    </button>
                    {{/if}}
                </div>
                {{/if}}
                {{/each}}
            </div>

            {{!-- Priority 3: Declaration phase --}}
            {{else if travelContext.hasTravelOptions}}

            <div class="travel-player-info">
                <i class="fas fa-hiking"></i>
                <span>{{travelContext.terrainLabel}}: {{#if travelContext.isMultiDay}}{{travelContext.totalDays}} days of travel{{else}}What did you do while travelling?{{/if}}</span>
            </div>

            {{#each travelContext.days}}
            {{#if isActive}}
            <div class="travel-day-section" data-day="{{day}}">
                {{#if ../travelContext.isMultiDay}}
                <div class="travel-day-label">Day {{day}}{{#if isFinalDay}}, Arrival{{/if}}</div>
                {{/if}}

                {{!-- Owned characters: hero cards --}}
                {{#each characters}}
                {{#if isOwner}}
                <div class="travel-hero-card {{#if confirmed}}confirmed{{/if}} {{#if rolled}}rolled{{/if}}">
                    <img class="travel-hero-portrait" src="{{img}}" alt="{{name}}" />
                    <div class="travel-hero-info">
                        <span class="travel-hero-name">{{name}}</span>
                        <span class="travel-hero-meta">
                            <span class="travel-hero-mod">{{survivalMod}} Survival</span>{{#if showLastHint}}<span class="travel-last-hint">Last: {{lastActivity}}</span>{{/if}}
                        </span>
                        {{#unless rolled}}{{#unless confirmed}}
                        <span class="travel-activity-desc">{{activityFlavor}}</span>
                        {{/unless}}{{/unless}}
                    </div>
                    {{#if rolled}}
                    <span class="travel-rolled-badge">
                        <i class="fas fa-dice-d20"></i>
                        {{#if (eq declaration 'forage')}}Foraging{{else if (eq declaration 'hunt')}}Hunting{{else if (eq declaration 'scout')}}Scouting{{else}}Other{{/if}}
                    </span>
                    {{else if confirmed}}
                    <span class="travel-confirmed-label">
                        {{#if (eq declaration 'forage')}}🌿 Forage
                        {{else if (eq declaration 'hunt')}}🎯 Hunt
                        {{else if (eq declaration 'scout')}}🔭 Scout
                        {{else}}🏕️ Other{{/if}}
                        <i class="fas fa-check"></i>
                    </span>
                    {{else}}
                    <select class="travel-player-select" data-actor-id="{{id}}" data-day="{{../day}}">
                        <option value="nothing" {{#if (eq declaration 'nothing')}}selected{{/if}}>🏕️ Other</option>
                        {{#if ../../travelContext.canForage}}<option value="forage" {{#if (eq declaration 'forage')}}selected{{/if}}>🌿 Forage</option>{{/if}}
                        {{#if ../../travelContext.canHunt}}<option value="hunt" {{#if (eq declaration 'hunt')}}selected{{/if}}>🎯 Hunt</option>{{/if}}
                        {{#if ../canScout}}<option value="scout" {{#if (eq declaration 'scout')}}selected{{/if}}>🔭 Scout</option>{{/if}}
                    </select>
                    {{#if (eq declaration 'nothing')}}
                    <button type="button" class="travel-confirm-btn" data-actor-id="{{id}}" data-day="{{../day}}" title="Lock in choice">
                        <i class="fas fa-check"></i>
                    </button>
                    {{else}}
                    <button type="button" class="travel-self-roll-btn btn-primary" data-action="selfRollTravelCheck" data-actor-id="{{id}}" data-day="{{../day}}" data-activity="{{declaration}}" data-dc="{{#if (eq declaration 'hunt')}}{{../../travelContext.huntDC}}{{else if (eq declaration 'scout')}}0{{else}}{{../../travelContext.forageDC}}{{/if}}">
                        <i class="fas fa-dice-d20"></i> Roll
                    </button>
                    {{/if}}
                    {{/if}}
                </div>
                {{/if}}
                {{/each}}

                {{!-- Other characters: compact grid --}}
                <div class="travel-party-grid">
                    {{#each characters}}
                    {{#unless isOwner}}
                    <div class="travel-grid-card {{#if confirmed}}confirmed{{/if}} {{#if declarationIcon}}active{{/if}} {{#if (eq declaration 'nothing')}}active-other{{/if}}" title="{{name}}{{#if confirmed}}, locked in{{/if}}">
                        <div class="travel-grid-portrait-wrap">
                            <img class="travel-grid-portrait" src="{{img}}" alt="{{name}}" />
                            {{#if confirmed}}<i class="fas fa-check travel-grid-confirmed-badge"></i>{{/if}}
                        </div>
                        <span class="travel-grid-name">{{name}}</span>
                        <span class="travel-grid-activity{{#unless declarationIcon}}{{#if (eq declaration 'nothing')}} travel-activity-other{{else}} idle{{/if}}{{/unless}}">
                            {{#if declarationIcon}}<i class="fas {{declarationIcon}}"></i>{{else}}<i class="fas fa-campground" title="Other"></i>{{/if}}
                        </span>
                        {{#if declarationLabel}}
                        <span class="travel-grid-label">{{declarationLabel}}</span>
                        {{else}}
                        <span class="travel-grid-label">Other</span>
                        {{/if}}
                    </div>
                    {{/unless}}
                    {{/each}}
                </div>
            </div>
            {{/if}}
            {{/each}}

            {{else}}
            <div class="travel-player-info">
                <i class="fas fa-hiking"></i>
                <span>Waiting for the GM...</span>
            </div>
            {{/if}}
        </div>
        {{/if}}

        {{else}}

        {{!-- ═══ TERRAIN DISABLED ═══ --}}
        <div class="travel-disabled-notice">
            <i class="fas fa-ban"></i>
            <span>{{travelContext.disabledReason}}</span>
        </div>

        {{#with (lookup travelContext.days 0)}}
        <div class="travel-character-list">
            {{#each characters}}
            <div class="travel-character-row travel-row-disabled">
                <img class="travel-portrait" src="{{img}}" alt="{{name}}" />
                <div class="travel-char-info">
                    <span class="travel-char-name">{{name}}</span>
                </div>
                <span class="travel-activity-disabled">-</span>
            </div>
            {{/each}}
        </div>
        {{/with}}

        {{#if isGM}}
        <div class="respite-action-bar">
            <button type="button" class="btn-primary" data-action="skipTravelPhase">
                <i class="fas fa-arrow-right"></i> Continue to Activities
            </button>
        </div>
        {{/if}}

        {{/if}} {{!-- /hasTravelOptions --}}
        {{/if}} {{!-- /travelSkipRecommended --}}
    </div>
    {{/if}}

    {{/if}}

    {{!-- =============== MAKE CAMP PHASE =============== --}}
    {{#if (eq phase 'camp')}}
    <div class="camp-minimal-shell camp-phase-shell">
    {{#if campfirePlaced}}
    <p class="camp-minimal-lead glass-ui">Use the <strong>campfire</strong> on the map: light the fire, cold camp, or add fuel. Supply tokens show where stations appear after the fire is going.</p>
    {{else}}
    <p class="camp-minimal-lead glass-ui">
        {{#if isGM}}A preview follows the pointer. Click the map to drop the pit, or right-click / <kbd>Esc</kbd> to cancel.{{else}}The GM is placing the campfire.{{/if}}
    </p>
    {{/if}}
    {{#if isGM}}
    {{#if campPitPlacementCancelled}}
    <div class="camp-pit-retry glass-ui">
        <p>Placement was cancelled. Place the pit when ready.</p>
        <button type="button" class="btn-primary" data-action="retryCampPitPlacement"><i class="fas fa-map-pin"></i> Place campfire pit</button>
    </div>
    {{/if}}
    {{/if}}
    </div>
    {{#if isGM}}<div class="respite-action-bar camp-minimal-action"><span class="phase-waiting-label"><i class="fas fa-compass"></i> Map first</span></div>
    {{else}}<div class="respite-action-bar camp-minimal-action"><span class="phase-waiting-label"><i class="fas fa-campground"></i> Check the map</span></div>
    {{/if}}
    {{/if}}

    {{!-- =============== ACTIVITY PHASE =============== --}}
    {{#if (eq phase 'activity')}}
    <div class="phase-banner">
        <img src="{{terrainBanner}}" alt="" style="object-position: {{terrainBannerPos}}" onerror="this.onerror=null;this.src='{{terrainBannerFallback}}'">
    </div>
    {{> rosterStrip}}

    {{#if postStationChoiceReview}}
    <div class="station-choice-review-bar">
        <span class="station-choice-review-text">
            <i class="fas fa-map-marker-alt" aria-hidden="true"></i>
            Activity saved from the map. Review here or return to the canvas.
        </span>
        <button type="button" class="btn-secondary" data-action="exitStationChoiceReview">
            <i class="fas fa-arrow-left" aria-hidden="true"></i> Back to map
        </button>
    </div>
    {{/if}}

    {{!-- Collapsed camp summary: no comfort or fire here (banner and map; chips often disagreed). Encounter DC and tent when relevant. --}}
    {{#if (or encounterBar campStatus.hasTent)}}
    <div class="camp-status-summary camp-collapsed-bar">
        <div class="camp-collapsed-chips">
            {{#if encounterBar}}
            <span class="camp-collapsed-chip" title="Encounter DC">
                <i class="fas fa-shield-alt"></i> DC {{encounterBar.effectiveDC}}
            </span>
            {{/if}}
            {{#if campStatus.hasTent}}
            <span class="camp-collapsed-chip gear-present" title="Tent pitched"><i class="fas fa-campground"></i></span>
            {{/if}}
        </div>
    </div>
    {{/if}}

    {{#if activityPhasePlayerOverview}}
    <div class="activity-phase-layout">
        <div class="respite-activities activity-phase-player-overview-wrap">
            <div class="player-overview-heading">
                <i class="fas fa-users" aria-hidden="true"></i>
                <span>Party progress</span>
            </div>
            <p class="player-overview-lead">Use camp map stations to choose activities{{#if activityPhasePlayerOverview.trackFood}} and meal rations{{/if}}.</p>
            <div class="player-overview-stat">
                <span class="player-overview-label">Party members with an activity</span>
                <span class="player-overview-value">{{activityPhasePlayerOverview.resolvedCount}} / {{activityPhasePlayerOverview.totalCharacters}}</span>
            </div>
            <div class="player-overview-progress-track" role="progressbar"
                aria-valuenow="{{activityPhasePlayerOverview.resolvedCount}}"
                aria-valuemin="0"
                aria-valuemax="{{activityPhasePlayerOverview.totalCharacters}}">
                <div class="player-overview-progress-fill" style="width: {{activityPhasePlayerOverview.activityProgressPercent}}%;"></div>
            </div>
            {{#if activityPhasePlayerOverview.trackFood}}
            <div class="player-overview-stat">
                <span class="player-overview-label">Party members with rations</span>
                <span class="player-overview-value">{{activityPhasePlayerOverview.mealRationsSubmitted}} / {{activityPhasePlayerOverview.totalCharacters}}</span>
            </div>
            <div class="player-overview-progress-track player-overview-progress-track--meal" role="progressbar"
                aria-valuenow="{{activityPhasePlayerOverview.mealRationsSubmitted}}"
                aria-valuemin="0"
                aria-valuemax="{{activityPhasePlayerOverview.totalCharacters}}">
                <div class="player-overview-progress-fill" style="width: {{activityPhasePlayerOverview.mealRationsProgressPercent}}%;"></div>
            </div>
            {{/if}}
            {{#if activityPhasePlayerOverview.allResolved}}
            {{#if isGM}}
            <div class="respite-action-bar">
                <button type="button" class="btn-primary" data-action="submitActivities">
                    <i class="fas fa-arrow-right"></i> Settle In
                </button>
            </div>
            {{else}}
            <p class="player-overview-note"><i class="fas fa-hourglass-half" aria-hidden="true"></i> Everyone has an activity. Waiting on the GM to advance.</p>
            {{/if}}
            {{/if}}
        </div>
    </div>
    {{/if}}
    {{/if}}

    {{!-- =============== MEAL PHASE =============== --}}
    {{#if (eq phase 'meal')}}
    <div class="phase-banner">
        <img src="{{terrainBanner}}" alt="" style="object-position: {{terrainBannerPos}}" onerror="this.onerror=null;this.src='{{terrainBannerFallback}}'">
    </div>
    {{> rosterStrip}}
    <div class="activity-phase-layout">
    <div class="respite-meal-phase">
        <div class="meal-phase-header">
            <h3><i class="fas fa-utensils"></i> Rations</h3>
            {{#if mealTerrainNote}}
            <div class="meal-terrain-note"><i class="fas fa-info-circle"></i> {{mealTerrainNote}}</div>
            {{/if}}
        </div>

        {{#if isGM}}
        <div class="meal-days-info">
            <span class="meal-days-label"><i class="fas fa-calendar-day"></i> {{daysSinceLastRest}} day{{#unless (eq daysSinceLastRest 1)}}s{{/unless}} since last rest</span>
        </div>
        {{/if}}

        {{!-- Multi-day sustenance progress bar (uses first card's data since all share totalDays) --}}
        {{#with (lookup mealCards 0)}}
        {{#if isMultiDay}}
        <div class="sustenance-progress-container">
            <span class="sustenance-progress-label">Sustenance Progress</span>
            <div class="sustenance-progress">
                {{#each daySegments}}
                <div class="sustenance-segment {{status}}">
                    {{#if (eq status "completed")}}<i class="fas fa-check"></i>{{/if}}
                    Day {{day}}
                </div>
                {{/each}}
            </div>
        </div>
        {{/if}}
        {{/with}}

        {{#if (and (not isGM) mealSubmitted)}}
        {{!-- Post-submission: replace meal cards with summary --}}
        <div class="meal-submitted-summary">
            <h4><i class="fas fa-scroll"></i> Meal Summary</h4>
            {{#each mealCards}}
            <div class="meal-summary-card">
                <div class="meal-summary-header">
                    <img src="{{actorImg}}" alt="{{actorName}}" class="meal-portrait">
                    <span class="meal-actor-name">{{actorName}}</span>
                    {{#if isMultiDay}}
                    <span class="meal-summary-days">{{consumedDaysCount}}/{{totalDays}} days</span>
                    {{/if}}
                </div>
                <div class="meal-summary-status">
                    <span class="meal-summary-stat {{#if foodSufficient}}stat-ok{{else}}stat-warn{{/if}}">
                        <i class="fas {{#if foodSufficient}}fa-check-circle{{else}}fa-drumstick-bite{{/if}}"></i>
                        {{#if foodSufficient}}Fed{{else}}Hungry{{/if}} ({{foodFilledCount}}/{{foodRequired}})
                    </span>
                    <span class="meal-summary-stat {{#if waterSufficient}}stat-ok{{else}}stat-warn{{/if}}">
                        <i class="fas {{#if waterSufficient}}fa-check-circle{{else}}fa-tint-slash{{/if}}"></i>
                        {{#if waterSufficient}}Hydrated{{else}}Thirsty{{/if}} ({{waterFilledCount}}/{{waterRequired}})
                    </span>
                </div>
                {{#each advisories}}
                <div class="meal-advisory {{level}}">
                    <i class="{{icon}}"></i> {{message}}
                </div>
                {{/each}}
            </div>
            {{/each}}
            {{#if dehydrationResults.length}}
            <div class="meal-results-panel">
                <h4><i class="fas fa-utensils"></i> Rations Outcome</h4>
                {{#each dehydrationResults}}
                {{#if pending}}
                <div class="meal-result-row result-pending">
                    <i class="fas fa-hourglass-half"></i>
                    <strong>{{actorName}}</strong>
                    - awaiting CON save (DC {{dc}})...
                </div>
                {{else}}
                <div class="meal-result-row {{#if passed}}result-pass{{else}}result-fail{{/if}}">
                    <i class="fas {{#if passed}}fa-check-circle{{else}}fa-skull{{/if}}"></i>
                    <strong>{{actorName}}</strong>
                    {{#if reason}}
                        - {{reason}}
                    {{else}}
                        {{#if passed}}
                            passes ({{total}} vs DC {{dc}})
                        {{else}}
                            fails ({{total}} vs DC {{dc}}) - gains 1 exhaustion
                        {{/if}}
                    {{/if}}
                </div>
                {{/if}}
                {{/each}}
            </div>
            {{/if}}
            <div class="respite-action-bar">
                <span class="phase-waiting-label"><i class="fas fa-hourglass-half"></i> Waiting for GM to proceed...</span>
            </div>
        </div>
        {{else}}
        <div class="meal-cards">
        {{#each mealCards}}
            <div class="meal-card" data-character-id="{{characterId}}">
                <div class="meal-card-header">
                    <img src="{{actorImg}}" alt="{{actorName}}" class="meal-portrait">
                    <span class="meal-actor-name">{{actorName}}</span>
                </div>

                {{#if (or allDaysConsumed playerSubmitted)}}
                {{#if playerSubmitted}}
                <div class="meal-submitted-badge" style="font-size:0.75rem;color:rgba(180,220,255,0.7);margin-bottom:0.3rem;">
                    <i class="fas fa-check"></i> Submitted by player
                </div>
                {{/if}}
                <div class="meal-summary-status" style="margin: 0.4rem 0;">
                    <span class="meal-summary-stat {{#if foodSufficient}}stat-ok{{else}}stat-warn{{/if}}">
                        <i class="fas {{#if foodSufficient}}fa-check-circle{{else}}fa-drumstick-bite{{/if}}"></i>
                        {{#if foodSufficient}}Fed{{else}}Hungry{{/if}} ({{foodFilledCount}}/{{foodRequired}})
                    </span>
                    <span class="meal-summary-stat {{#if waterSufficient}}stat-ok{{else}}stat-warn{{/if}}">
                        <i class="fas {{#if waterSufficient}}fa-check-circle{{else}}fa-tint-slash{{/if}}"></i>
                        {{#if waterSufficient}}Hydrated{{else}}Thirsty{{/if}} ({{waterFilledCount}}/{{waterRequired}})
                    </span>
                </div>
                {{else}}
                <div class="meal-drop-columns">
                    {{!-- Food panel --}}
                    <div class="meal-panel food-panel {{#unless hasFood}}panel-empty{{/unless}}">
                        <span class="panel-label">Food{{#if (gt foodRequired 1)}} ({{foodFilledCount}} of {{foodRequired}}){{/if}}</span>
                        {{#if hasFood}}
                        <div class="food-plates-row">
                        {{#each foodSlots}}
                        <div class="food-plate-slot">
                            <div class="meal-drop-zone food-drop-zone {{#if filled}}filled{{/if}}{{#if locked}} locked{{/if}}"
                                 data-character-id="{{../characterId}}" data-slot="food" data-slot-index="{{index}}"{{#if locked}} data-locked="true"{{/if}}>
                                <div class="drop-zone-silhouette">
                                    {{#if filled}}
                                    {{#each ../foodOptions}}
                                    {{#if (eq ../selected value)}}
                                    <img src="{{icon}}" alt="{{label}}" class="drop-zone-item-icon">
                                    {{/if}}
                                    {{/each}}
                                    {{else}}
                                    <i class="fas fa-drumstick-bite drop-zone-plate"></i>
                                    {{/if}}
                                </div>
                            </div>
                        </div>
                        {{/each}}
                        </div>
                        <span class="panel-item-name">
                            {{#unless foodSufficient}}
                            <span class="panel-empty-hint">{{#if (gt foodRequired 1)}}Drag to fill {{foodRequired}} plates{{else}}Drag food here{{/if}}</span>
                            {{/unless}}
                        </span>
                        <div class="meal-inventory-tray food-tray">
                            {{#each foodOptions}}
                            <div class="meal-inv-item" draggable="true"
                                 data-item-id="{{value}}"
                                 data-slot="food"
                                 data-available="{{available}}"
                                 data-character-id="{{../characterId}}"
                                 title="{{label}}">
                                <img src="{{icon}}" alt="{{label}}" class="meal-inv-icon">
                                <span class="meal-inv-qty">{{label}}</span>
                            </div>
                            {{/each}}
                        </div>
                        {{else}}
                        <div class="panel-no-inventory">
                            <i class="fas fa-drumstick-bite"></i>
                            <span>No rations in inventory</span>
                        </div>
                        {{/if}}
                    </div>

                    {{!-- Water panel --}}
                    <div class="meal-panel water-panel {{#unless hasWater}}panel-empty{{/unless}}">
                        <span class="panel-label">Water{{#if (gt waterRequired 1)}} ({{waterFilledCount}} of {{waterRequired}}){{/if}}</span>
                        {{#if hasWater}}
                        <div class="water-goblets-row">
                        {{#each waterSlots}}
                        <div class="water-goblet-slot">
                            <div class="meal-drop-zone water-drop-zone {{#if filled}}filled{{/if}}{{#if locked}} locked{{/if}}"
                                 data-character-id="{{../characterId}}" data-slot="water" data-slot-index="{{index}}"{{#if locked}} data-locked="true"{{/if}}>
                                <div class="drop-zone-silhouette">
                                    {{#if filled}}
                                    {{#each ../waterOptions}}
                                    {{#if (eq ../selected value)}}
                                    <img src="{{icon}}" alt="{{label}}" class="drop-zone-item-icon">
                                    {{/if}}
                                    {{/each}}
                                    {{else}}
                                    <i class="fas fa-tint drop-zone-goblet"></i>
                                    {{/if}}
                                </div>
                            </div>
                        </div>
                        {{/each}}
                        </div>
                        <span class="panel-item-name">
                            {{#unless waterSufficient}}
                            <span class="panel-empty-hint">{{#if (gt waterRequired 1)}}Drag to fill {{waterRequired}} goblets{{else}}Drag water here{{/if}}</span>
                            {{/unless}}
                        </span>
                        <div class="meal-inventory-tray water-tray">
                            {{#each waterOptions}}
                            <div class="meal-inv-item" draggable="true"
                                 data-item-id="{{value}}"
                                 data-slot="water"
                                 data-available="{{available}}"
                                 data-character-id="{{../characterId}}"
                                 title="{{label}}">
                                <img src="{{icon}}" alt="{{label}}" class="meal-inv-icon">
                                <span class="meal-inv-qty">{{label}}</span>
                            </div>
                            {{/each}}
                        </div>
                        {{else}}
                        <div class="panel-no-inventory">
                            <i class="fas fa-tint"></i>
                            <span>No water in inventory</span>
                        </div>
                        {{/if}}
                    </div>
                </div>
                {{/if}}

                {{!-- Advisories (shown for submitted cards so GM sees warnings; hidden in consumed state) --}}
                {{#unless (and allDaysConsumed (not playerSubmitted))}}
                {{#each advisories}}
                {{#unless (eq level 'info')}}
                <div class="meal-advisory {{level}}">
                    <i class="{{icon}}"></i> {{message}}
                </div>
                {{/unless}}
                {{/each}}
                {{/unless}}
            </div>
        {{/each}}
        </div>

        {{!-- Dehydration save results panel (visible to all) --}}
        {{#if dehydrationResults.length}}
        <div class="meal-results-panel">
            <h4><i class="fas fa-utensils"></i> Rations Outcome</h4>
            {{#each dehydrationResults}}
            {{#if pending}}
            <div class="meal-result-row result-pending">
                <i class="fas fa-hourglass-half"></i>
                <strong>{{actorName}}</strong>
                - awaiting CON save (DC {{dc}})...
            </div>
            {{else}}
            <div class="meal-result-row {{#if passed}}result-pass{{else}}result-fail{{/if}}">
                <i class="fas {{#if passed}}fa-check-circle{{else}}fa-skull{{/if}}"></i>
                <strong>{{actorName}}</strong>
                {{#if reason}}
                    - {{reason}}
                {{else}}
                    {{#if passed}}
                        passes ({{total}} vs DC {{dc}})
                    {{else}}
                        fails ({{total}} vs DC {{dc}}) - gains 1 exhaustion
                    {{/if}}
                {{/if}}
            </div>
            {{/if}}
            {{/each}}
        </div>
        {{/if}}

        {{#if isGM}}
        <div class="respite-action-bar">
            {{#if allMealsConsumed}}
            {{#if mealProcessed}}
                {{#if pendingDehydrationSaves}}
                    {{#if allDehydrationResolved}}
                    <button type="button" class="btn-primary" data-action="proceedFromMeal">
                        <i class="fas fa-fire"></i> Proceed to Reflection
                    </button>
                    {{else}}
                    <button type="button" class="btn-primary" disabled>
                        <i class="fas fa-hourglass-half"></i> Waiting for {{pendingDehydrationSaves}} CON save(s)...
                    </button>
                    {{#if hasUnresolvedSaves}}
                    <button type="button" class="btn-secondary" data-action="skipPendingSaves" title="Auto-fail all pending saves and apply exhaustion">
                        <i class="fas fa-forward"></i> Skip Pending Saves
                    </button>
                    {{/if}}
                    {{/if}}
                {{else}}
                <button type="button" class="btn-primary" data-action="proceedFromMeal">
                    <i class="fas fa-fire"></i> Proceed to Reflection
                </button>
                {{/if}}
            {{else}}
            <button type="button" class="btn-primary" data-action="proceedFromMeal">
                <i class="fas fa-dice-d20"></i> Process Rations & Checks
            </button>
            {{/if}}
            {{else}}
            {{#with (lookup mealCards 0)}}
            {{#if (and isMultiDay (not allDaysConsumed))}}
            <button type="button" class="btn-primary btn-consume-day" data-action="consumeMealDay">
                <i class="fas fa-utensils"></i> Consume Day {{currentDay}}
            </button>
            {{else if allDaysConsumed}}
            <button type="button" class="btn-primary" disabled>
                <i class="fas fa-check"></i> {{actorName}} - All days consumed
            </button>
            {{/if}}
            {{/with}}
            {{/if}}
        </div>
        {{else}}
        <div class="respite-action-bar">
                {{#with (lookup mealCards 0)}}
                {{#if (and isMultiDay (not allDaysConsumed))}}
                <button type="button" class="btn-primary btn-consume-day" data-action="consumeMealDay">
                    <i class="fas fa-utensils"></i> Consume Day {{currentDay}}
                </button>
                {{else}}
                <button type="button" class="btn-primary" data-action="submitMealChoices">
                    <i class="fas fa-utensils"></i> Submit Meals
                </button>
                {{/if}}
                {{/with}}
        </div>
        {{/if}}
        {{/if}}

    </div>
    {{!-- Campfire drawer --}}
    <div class="campfire-drawer">
        <div class="campfire-drawer-content"></div>
    </div>
    </div>{{!-- /activity-phase-layout --}}
    {{/if}}

    {{!-- =============== REFLECTION PHASE =============== --}}
    {{#if (eq phase 'reflection')}}
    <div class="phase-banner">
        <img src="{{terrainBanner}}" alt="" style="object-position: {{terrainBannerPos}}" onerror="this.onerror=null;this.src='{{terrainBannerFallback}}'">
    </div>
    {{> rosterStrip}}
    <div class="respite-reflection">
        <div class="reflection-intro">Conversation starters for the campfire. No rolls, no mechanics.</div>
        <div class="reflection-grid">
            <div class="reflection-tile">
                <div class="reflection-tile-icon"><i class="fas fa-book-open"></i></div>
                <div class="reflection-tile-label">Reflect on the Day</div>
                <div class="reflection-tile-hint">What stood out? What surprised you?</div>
            </div>
            <div class="reflection-tile">
                <div class="reflection-tile-icon"><i class="fas fa-scroll"></i></div>
                <div class="reflection-tile-label">Examine Quests</div>
                <div class="reflection-tile-hint">Review goals, update plans.</div>
            </div>
            <div class="reflection-tile">
                <div class="reflection-tile-icon"><i class="fas fa-hat-wizard"></i></div>
                <div class="reflection-tile-label">Study Lore</div>
                <div class="reflection-tile-hint">Books, clues, maps, mysteries.</div>
            </div>
            <div class="reflection-tile">
                <div class="reflection-tile-icon"><i class="fas fa-compass"></i></div>
                <div class="reflection-tile-label">Plan for Tomorrow</div>
                <div class="reflection-tile-hint">Strategy, route, marching order.</div>
            </div>
            <div class="reflection-tile">
                <div class="reflection-tile-icon"><i class="fas fa-comments"></i></div>
                <div class="reflection-tile-label">Share a Story</div>
                <div class="reflection-tile-hint">Memories, backstory, tall tales.</div>
            </div>
            <div class="reflection-tile">
                <div class="reflection-tile-icon"><i class="fas fa-shield-alt"></i></div>
                <div class="reflection-tile-label">Mend &amp; Prepare</div>
                <div class="reflection-tile-hint">Check gear, sharpen blades, patch armor.</div>
            </div>
        </div>
    </div>
    {{#if isGM}}
    <div class="respite-action-bar">
        <button type="button" class="btn-primary" data-action="proceedToEvents">
            <i class="fas fa-moon"></i> Proceed to Events
        </button>
    </div>
    {{else}}
    <div class="respite-action-bar">
        <span class="phase-waiting-label"><i class="fas fa-fire"></i> Enjoy the campfire...</span>
    </div>
    {{/if}}
    {{/if}}

    {{!-- =============== EVENTS PHASE =============== --}}
    {{#if (eq phase 'events')}}
    <div class="phase-banner">
        <img src="{{terrainBanner}}" alt="" style="object-position: {{terrainBannerPos}}" onerror="this.onerror=null;this.src='{{terrainBannerFallback}}'">
    </div>
    {{> rosterStrip}}
    <div class="respite-events">

        {{#if eventsRolled}}
        {{!-- POST-ROLL: Show event results --}}

        {{!-- Disaster Choice: nat 1 GM pick --}}
        {{#if disasterChoice}}
        <div class="respite-event-card encounter disaster-choice-card">
            <div class="event-name"><i class="fas fa-skull"></i> Natural 1 - Disaster!</div>
            <div class="event-description">
                A terrible omen. Choose how the night unfolds.
            </div>
            {{#if isGM}}
            <div class="disaster-buttons">
                {{#if disasterChoice.tree}}
                <button type="button" class="btn-disaster tree" data-action="disasterChoice" data-pick="tree">
                    <i class="fas fa-skull"></i>
                    <div class="disaster-btn-content">
                        <strong>Disaster Event</strong>
                        <span class="disaster-preview">{{disasterChoice.tree.name}}</span>
                    </div>
                </button>
                {{/if}}
                {{#if disasterChoice.encounter}}
                <button type="button" class="btn-disaster encounter" data-action="disasterChoice" data-pick="encounter">
                    <i class="fas fa-swords"></i>
                    <div class="disaster-btn-content">
                        <strong>Combat Encounter</strong>
                        <span class="disaster-preview">{{disasterChoice.encounter.name}}</span>
                    </div>
                </button>
                {{/if}}
                {{#if disasterChoice.normals.length}}
                <button type="button" class="btn-disaster normals" data-action="disasterChoice" data-pick="normals">
                    <i class="fas fa-exclamation-triangle"></i>
                    <div class="disaster-btn-content">
                        <strong>{{disasterChoice.normalsLabel}}</strong>
                        <span class="disaster-preview">
                            {{#each disasterChoice.normals}}{{name}}{{#unless @last}}, {{/unless}}{{/each}}
                        </span>
                    </div>
                </button>
                {{/if}}
                <div class="disaster-dismiss">
                    <button type="button" class="btn-override-link" data-action="disasterChoice" data-pick="dismiss">Dismiss and continue</button>
                </div>
            </div>
            {{else}}
            <div class="event-check-waiting">
                <i class="fas fa-skull"></i> Something terrible stirs. The GM is deciding...
            </div>
            {{/if}}
        </div>
        {{else}}

        {{!-- Decision Tree: Interactive choices (GM only controls, players see read-only) --}}
        {{#if activeTreeState}}
        <div class="respite-decision-tree">
            {{!-- Hidden data holder for gmGuidance text (GM only) --}}
            {{#if isGM}}
            {{#if activeTreeState.gmGuidance}}
            <div class="tree-gm-sidebar" aria-hidden="true">
                <div class="tree-gm-sidebar-body">{{activeTreeState.gmGuidance}}</div>
            </div>
            {{/if}}
            {{/if}}
            <div class="respite-event-card complication tree-active">
                <div class="event-name">
                    <span class="event-name-text"><i class="fas fa-exclamation-triangle"></i> {{activeTreeState.eventName}}</span>
                    {{#if isGM}}
                    {{#if activeTreeState.gmGuidance}}
                    <button type="button" class="tree-gm-notes-btn" data-action="toggleGmGuidance" title="GM Guidance">
                        <i class="fas fa-book-reader"></i> GM Notes
                    </button>
                    {{/if}}
                    {{/if}}
                </div>
                {{!-- Description: suppress if gmPrompt present (avoids duplicate scene-setting) --}}
                {{#unless activeTreeState.gmPrompt}}
                <div class="event-description">{{activeTreeState.description}}</div>
                {{/unless}}
            </div>


            {{!-- Tree History (previous choices) --}}
            {{#each activeTreeState.history}}
            <div class="tree-history-entry">
                <div class="tree-choice-made">
                    <i class="fas fa-arrow-right"></i>
                    <strong>{{choiceLabel}}</strong>
                    <span class="tree-result {{#if result.success}}success{{else}}failure{{/if}}">
                        {{#if result.success}}Passed{{else}}Failed{{/if}}
                        ({{result.passCount}}/{{result.rolls.length}})
                    </span>
                </div>
            </div>
            {{/each}}

            {{!-- Current Prompt and Choices (GM can interact, players see read-only) --}}
            {{#unless activeTreeState.resolved}}

            {{!-- GM Narration Hint --}}
            {{#if isGM}}
            <div class="tree-narration-hint">
                <i class="fas fa-theater-masks"></i>
                <span>Set the scene for your players. Use the prompt as a guide, present the two options, and let them decide. The DCs are for your eyes only.</span>
            </div>
            {{/if}}

            <div class="tree-prompt">
                <p>{{activeTreeState.prompt}}</p>
            </div>

            {{!-- Scene / Options divider --}}
            <div class="tree-phase-divider">
                <i class="fas fa-campground tree-phase-divider-icon"></i>
            </div>

            {{#if isGM}}
            {{!-- Stall Penalty Button (between prompt and cards) --}}
            {{#if activeTreeState.hasStallPenalty}}
            <div class="tree-stall-area">
                <button type="button" class="btn-stall-penalty" data-action="applyStallPenalty"
                    title="The mountain does not negotiate. DCs +{{activeTreeState.stallPenalty.dcBump}}, supplies lost to the delay. Can be applied multiple times.">
                    <i class="fas fa-hourglass-half"></i> Players Stalling
                </button>
                <span class="stall-hint-text">Third option bid &middot; negotiating between choices &middot; repeating answered questions</span>
                {{#if activeTreeState.stallCount}}
                <span class="stall-applied-count">
                    <i class="fas fa-exclamation-triangle"></i> Applied {{activeTreeState.stallCount}}x. DCs +{{activeTreeState.totalStallBump}}, supplies lost
                </span>
                {{/if}}
            </div>
            {{/if}}
            {{/if}}

            {{#if activeTreeState.awaitingRolls}}
            {{!-- GM: Waiting for player rolls --}}
            {{#if isGM}}
            <div class="tree-awaiting-rolls">
                {{#if activeTreeState.rollRequestSent}}
                {{!-- === PHASE 2: Request sent, awaiting results === --}}
                <div class="tree-roll-header">
                    <i class="fas fa-dice-d20"></i>
                    Awaiting Player Rolls: {{activeTreeState.pendingSkillName}} DC {{activeTreeState.pendingDC}}
                </div>
                <div class="tree-roll-dispatched-note">
                    <i class="fas fa-paper-plane"></i> Roll request dispatched. Players will see their roll button now.
                </div>
                {{else}}
                {{!-- === PHASE 1: Configure modifiers before sending === --}}
                <div class="tree-roll-header tree-roll-header--configure">
                    <i class="fas fa-sliders-h"></i>
                    Configure Roll Modifiers: {{activeTreeState.pendingSkillName}} DC {{activeTreeState.pendingDC}}
                </div>
                <div class="tree-roll-configure-note">
                    <i class="fas fa-info-circle"></i> Set modifiers per character, then send the roll request to players.
                </div>
                {{/if}}
                {{!-- Spell rulings advisory --}}
                {{#if activeTreeState.pendingChoiceSpellRulings}}
                <div class="tree-spell-rulings-advisory">
                    <i class="fas fa-hat-wizard"></i>
                    <span>{{activeTreeState.pendingChoiceSpellRulings}}</span>
                </div>
                {{/if}}
                <div class="tree-roll-tracker">
                    {{#each activeTreeState.resolvedRolls}}
                    <div class="tree-roll-entry resolved">
                        <span class="roll-name">{{name}}</span>
                        <span class="roll-total {{#if passed}}pass{{else}}fail{{/if}}">{{total}}</span>
                        <i class="fas {{#if passed}}fa-check-circle{{else}}fa-times-circle{{/if}}"></i>
                    </div>
                    {{/each}}
                    {{#each activeTreeState.pendingRollsEnriched}}
                    <div class="tree-roll-entry pending">
                        <span class="roll-name">{{name}}</span>
                        {{!-- Roll mode selector --}}
                        <select class="select-roll-mode roll-mode--{{rollMode}}"
                            data-character-id="{{id}}"
                            title="Set roll modifier for this player">
                            <option value="normal"       {{#if (eq rollMode "normal")}}selected{{/if}}>Normal</option>
                            <option value="advantage"    {{#if (eq rollMode "advantage")}}selected{{/if}}>↑ Adv</option>
                            <option value="disadvantage" {{#if (eq rollMode "disadvantage")}}selected{{/if}}>↓ Dis</option>
                            <option value="force-pass"   {{#if (eq rollMode "force-pass")}}selected{{/if}}>✓ Pass</option>
                            <option value="force-fail"   {{#if (eq rollMode "force-fail")}}selected{{/if}}>✗ Fail</option>
                        </select>
                        {{#if @root.activeTreeState.rollRequestSent}}
                        <button type="button" class="btn-roll-for-player" data-action="rollTreeForPlayer" data-character-id="{{id}}" title="Roll on their behalf">
                            <i class="fas fa-dice"></i>
                        </button>
                        {{/if}}
                    </div>
                    {{/each}}
                </div>
                <div class="tree-roll-actions">
                    {{#if activeTreeState.rollRequestSent}}
                    <button type="button" class="btn-resend-roll" data-action="resendTreeRollRequest" title="Re-send the roll request to players">
                        <i class="fas fa-paper-plane"></i> Resend
                    </button>
                    {{else}}
                    <button type="button" class="btn-send-roll-request" data-action="sendTreeRollRequest" title="Dispatch roll request to all players with current modifiers">
                        <i class="fas fa-paper-plane"></i> Send Roll Request
                    </button>
                    {{/if}}
                </div>
            </div>
            {{else}}
            {{!-- Player: Show roll buttons when tree roll is pending --}}
            {{#if @root.pendingTreeRoll}}
            <div class="tree-player-roll-area">
                <div class="tree-roll-header">
                    <i class="fas fa-dice-d20"></i>
                    {{@root.pendingTreeRoll.eventName}}: {{@root.pendingTreeRoll.skillName}} Check
                </div>
                {{#each @root.pendingTreeRoll.ownedTargets}}
                <div class="tree-roll-character">
                    {{#if rolled}}
                    <div class="tree-roll-result {{#if passed}}pass{{else}}fail{{/if}}">
                        <i class="fas {{#if passed}}fa-check-circle{{else}}fa-times-circle{{/if}}"></i>
                        <span class="roll-char-name">{{name}}</span>
                        <span class="roll-total">{{total}}</span>
                    </div>
                    {{else}}
                    {{!-- Roll mode badge (visible to player before rolling) --}}
                    {{#if (or (eq rollMode "advantage") (eq rollMode "disadvantage") (eq rollMode "force-pass") (eq rollMode "force-fail"))}}
                    <div class="roll-mode-badge roll-mode-badge--{{rollMode}}">
                        {{#if (eq rollMode "advantage")}}<i class="fas fa-chevron-double-up"></i> Roll with Advantage
                        {{else if (eq rollMode "disadvantage")}}<i class="fas fa-chevron-double-down"></i> Roll with Disadvantage
                        {{else if (eq rollMode "force-pass")}}<i class="fas fa-check"></i> Auto-Success
                        {{else if (eq rollMode "force-fail")}}<i class="fas fa-times"></i> Auto-Fail
                        {{/if}}
                    </div>
                    {{/if}}
                    {{#if (or (eq rollMode "force-pass") (eq rollMode "force-fail"))}}
                    <button type="button" class="btn-tree-roll btn-tree-roll--{{rollMode}}" data-action="rollTreeCheck" data-character-id="{{id}}">
                        {{#if (eq rollMode "force-pass")}}<i class="fas fa-check"></i> Confirm Auto-Success for {{name}}
                        {{else}}<i class="fas fa-times"></i> Confirm Auto-Failure for {{name}}
                        {{/if}}
                    </button>
                    {{else}}
                    <button type="button" class="btn-tree-roll" data-action="rollTreeCheck" data-character-id="{{id}}">
                        <i class="fas fa-dice-d20"></i> Roll for {{name}}
                    </button>
                    {{/if}}
                    {{/if}}
                </div>
                {{/each}}
            </div>
            {{else}}
            <div class="tree-waiting">
                <i class="fas fa-dice-d20"></i> Waiting for a decision...
            </div>
            {{/if}}
            {{/if}}

            {{else}}
            {{!-- Normal choice selection (not awaiting rolls) --}}
            {{#if isGM}}

            <div class="tree-choices">
                {{#each activeTreeState.options}}
                <div class="tree-choice-card">
                <button type="button" class="btn-tree-choice" data-action="resolveTreeChoice" data-choice-id="{{id}}">
                    <div class="choice-header">
                        <div class="choice-label">{{label}}</div>
                        <i class="fas fa-chevron-right choice-action-icon"></i>
                    </div>
                    {{#if description}}<div class="choice-description">{{description}}</div>{{/if}}
                    {{#if spellRulings}}<div class="choice-spell-rulings"><i class="fas fa-hat-wizard"></i>{{spellRulings}}</div>{{/if}}
                    <div class="choice-check">
                        <span class="skill-best-of">Best of</span>
                        {{#each check.skills}}
                        {{#if @index}}<span class="skill-sep">/</span>{{/if}}
                        <span class="skill-tag">{{this}}</span>
                        {{/each}}
                        <span class="skill-sep">·</span>
                        <span class="choice-dc">DC {{check.dc}}</span>
                    </div>
                </button>
                {{#if @root.isGM}}
                <div class="tree-dc-adj">
                    <button type="button" class="encounter-adj-btn" data-action="treeDcAdjDown" title="Reduce DC">−</button>
                    <button type="button" class="encounter-adj-btn" data-action="treeDcAdjUp" title="Increase DC">+</button>
                    {{#if @root.activeTreeState.treeDcAdj}}<span class="tree-dc-adj-label">GM adj: {{@root.activeTreeState.treeDcAdj}}</span>{{/if}}
                </div>
                {{/if}}
                </div>
                {{/each}}
            </div>
            {{else}}
            {{!-- Player: Waiting for GM to pick a choice --}}
            <div class="tree-waiting">
                <i class="fas fa-dice-d20"></i> The GM is making a decision...
            </div>
            {{/if}}
            {{/if}}
            {{/unless}}

            {{!-- Resolved Outcome --}}
            {{#if activeTreeState.resolved}}
            <div class="tree-resolved">
                <div class="tree-outcome-header">
                    <i class="fas fa-flag-checkered"></i> Outcome
                </div>
                <div class="tree-final-narrative">{{activeTreeState.finalNarrative}}</div>
                {{#if activeTreeState.finalEffects.length}}
                <div class="tree-effects">
                    <div class="tree-effects-header">Consequences</div>
                    {{#each activeTreeState.finalEffects}}
                    <div class="tree-effect effect-{{type}}">
                        {{#if (eq type "supply_loss")}}
                        <i class="fas fa-box-open"></i>
                        <span class="effect-label">Supply Loss</span>
                        <span class="effect-detail">{{formula}}</span>
                        {{#if description}}<span class="effect-desc">{{description}}</span>{{/if}}
                        {{else if (eq type "condition")}}
                        <i class="fas fa-skull-crossbones"></i>
                        <span class="effect-label">{{condition}}</span>
                        {{#if level}}<span class="effect-detail">level {{level}}</span>{{/if}}
                        {{#if scope}}<span class="effect-scope">({{scope}})</span>{{/if}}
                        {{else if (eq type "damage")}}
                        <i class="fas fa-heart-broken"></i>
                        <span class="effect-label">{{formula}} {{damageType}}</span>
                        {{#if description}}<span class="effect-desc">{{description}}</span>{{/if}}
                        {{else}}
                        <i class="fas fa-bolt"></i>
                        <span class="effect-label">{{description}}</span>
                        {{/if}}
                    </div>
                    {{/each}}
                </div>
                {{/if}}
                {{#if isGM}}
                <div class="tree-narration-hint">
                    <i class="fas fa-theater-masks"></i>
                    <span>Describe the outcome to your players before proceeding.</span>
                </div>
                {{/if}}
            </div>
            {{/if}}
        </div>
        {{else}}

        {{!-- Regular Events --}}
        {{#if triggeredEvents.length}}
        {{#each triggeredEvents}}
        <div class="respite-event-card {{category}} {{#if resolvedOutcome}}resolved-event {{#if (gt @root.triggeredEvents.length 1)}}collapsed{{/if}}{{/if}} {{#if (eq result 'scouting_hazard')}}scouting-hazard{{/if}} {{#if (eq result 'scouting_bonus')}}scouting-bonus{{/if}}" {{#if resolvedOutcome}}data-action="toggleResolvedEvent"{{/if}}>
            <div class="event-header">
                <div class="event-name">
                    {{#if (eq category "encounter")}}<i class="fas fa-swords"></i>
                    {{else if (eq category "complication")}}<i class="fas fa-exclamation-triangle"></i>
                    {{else if (eq category "discovery")}}<i class="fas fa-search"></i>
                    {{else}}<i class="fas fa-moon"></i>
                    {{/if}}
                    {{#if name}}{{name}}{{else}}{{#if (eq category "encounter")}}Something stirs...{{else if (eq category "complication")}}A complication arises...{{else if (eq category "discovery")}}Something catches your eye...{{else}}The night passes...{{/if}}{{/if}}
                </div>
                {{#if resolvedOutcome}}
                <span class="event-verdict-inline {{#if (eq resolvedOutcome "triumph")}}pass{{else if (eq resolvedOutcome "success")}}pass{{else if (eq resolvedOutcome "partial")}}partial{{else}}fail{{/if}}">
                    {{#if (eq resolvedOutcome "triumph")}}<i class="fas fa-check"></i> Passed{{else if (eq resolvedOutcome "success")}}<i class="fas fa-check"></i> Passed{{else if (eq resolvedOutcome "partial")}}<i class="fas fa-exclamation-triangle"></i> Partial{{else}}<i class="fas fa-times"></i> Failed{{/if}}
                </span>
                <i class="fas fa-chevron-down event-expand-toggle"></i>
                {{/if}}
                {{#if (eq result "scouting_hazard")}}<span class="event-badge hazard">Scouting Hazard</span>{{/if}}
                {{#if (eq result "scouting_bonus")}}<span class="event-badge bonus">Scouting Bonus</span>{{/if}}
            </div>
            {{#if @root.isGM}}<div class="event-description">{{narrative}}</div>{{/if}}

            {{!-- Skill Check Details --}}
            {{#if mechanical}}
            {{#if (eq mechanical.type "skill_check")}}
            <div class="event-mechanical">

                {{#if resolvedOutcome}}
                {{!-- RESOLVED: DC at top as context for the rolls --}}
                <div class="event-check-header">
                    <div class="event-dc-badge">
                        <span class="dc-label">DC</span>
                        <span class="dc-value">{{mechanical.dc}}</span>
                    </div>
                    <div class="event-check-info">
                        <strong class="check-skill-name">{{skillName}}</strong>
                        <span class="event-check-target">
                            {{#if (eq mechanical.targets "watch")}}On-duty characters{{else if (eq mechanical.targets "all")}}Entire party{{else}}On-duty characters{{/if}}
                            · Group Check (averaged)
                        </span>
                        <span class="event-check-direction">All rolls averaged against DC</span>
                    </div>
                </div>

                {{!-- Per-character results (visible to all clients) --}}
                {{#if resolvedRolls}}
                <div class="event-roll-results">
                    {{#each resolvedRolls}}
                    <div class="event-roll-line {{#if passed}}pass{{else}}fail{{/if}}">
                        <span class="roll-char-name">{{name}}</span>
                        <span class="roll-total">rolled <strong>{{total}}</strong></span>
                        <span class="roll-badge {{#if passed}}pass{{else}}fail{{/if}}">
                            {{#if passed}}<i class="fas fa-check"></i> Pass{{else}}<i class="fas fa-times"></i> Fail{{/if}}
                        </span>
                    </div>
                    {{/each}}
                    {{!-- Group average summary (group policy only) --}}
                    {{#if groupAverage}}
                    <div class="event-roll-average">
                        <span class="avg-label">Group Average:</span>
                        <strong>{{groupAverage}}</strong>
                        <span class="avg-vs">vs DC</span>
                        <strong>{{mechanical.dc}}</strong>
                    </div>
                    {{/if}}
                </div>
                {{/if}}
                <div class="event-verdict {{#if (eq resolvedOutcome "triumph")}}pass{{else if (eq resolvedOutcome "success")}}pass{{else if (eq resolvedOutcome "partial")}}partial{{else}}fail{{/if}}">
                    {{#if (eq resolvedOutcome "triumph")}}
                    <i class="fas fa-shield-alt"></i> Check Passed
                    {{else if (eq resolvedOutcome "success")}}
                    <i class="fas fa-shield-alt"></i> Check Passed
                    {{else if (eq resolvedOutcome "partial")}}
                    <i class="fas fa-exclamation-triangle"></i> Partial Success
                    {{else}}
                    <i class="fas fa-skull-crossbones"></i> Check Failed
                    {{/if}}
                </div>

                {{#if (eq resolvedOutcome "triumph")}}
                <div class="event-outcome success resolved">
                    <i class="fas fa-check-circle"></i>
                    {{#if @root.isGM}}<span>{{mechanical.onTriumph.narrative}}</span>{{else}}<span>The party rises to the occasion.</span>{{/if}}
                </div>
                {{else if (eq resolvedOutcome "success")}}
                <div class="event-outcome success resolved">
                    <i class="fas fa-check-circle"></i>
                    {{#if @root.isGM}}<span>{{mechanical.onSuccess.narrative}}</span>{{else}}<span>The party weathers the challenge.</span>{{/if}}
                </div>
                {{else if (eq resolvedOutcome "partial")}}
                <div class="event-outcome partial resolved">
                    <i class="fas fa-exclamation-circle"></i>
                    {{#if @root.isGM}}<span>{{mechanical.onPartial.narrative}}</span>{{else}}<span>Things could have gone better.</span>{{/if}}
                    {{#each mechanical.onPartial.effects}}
                    <div class="event-effect">
                        {{#if (eq type "damage")}}<i class="fas fa-heart-broken"></i> {{formula}} {{damageType}} ({{scope}})
                        {{else if (eq type "recovery_penalty")}}<i class="fas fa-bed"></i> Recovery x{{hpMultiplier}}
                        {{else if (eq type "condition")}}<i class="fas fa-skull-crossbones"></i> {{condition}}{{#if checks.length}} on {{#each checks}}{{#if @index}}, {{/if}}{{upper this}}{{/each}} checks{{/if}} {{#if duration}}({{humanDuration duration}}){{/if}}
                        {{else if (eq type "consume_resource")}}<i class="fas fa-box-open"></i> Lose {{amount}} {{resource}}
                        {{else if (eq type "item_at_risk")}}<i class="fas fa-box-open"></i> {{narrative}}
                        {{/if}}
                    </div>
                    {{/each}}
                </div>
                {{else}}
                <div class="event-outcome failure resolved">
                    <i class="fas fa-times-circle"></i>
                    {{#if @root.isGM}}<span>{{mechanical.onFailure.narrative}}</span>{{else}}<span>The situation takes a turn for the worse.</span>{{/if}}
                    {{#each mechanical.onFailure.effects}}
                    <div class="event-effect">
                        {{#if (eq type "damage")}}<i class="fas fa-heart-broken"></i> {{formula}} {{damageType}} ({{scope}})
                        {{else if (eq type "recovery_penalty")}}<i class="fas fa-bed"></i> Recovery x{{hpMultiplier}}
                        {{else if (eq type "condition")}}<i class="fas fa-skull-crossbones"></i> {{condition}}{{#if checks.length}} on {{#each checks}}{{#if @index}}, {{/if}}{{upper this}}{{/each}} checks{{/if}} {{#if duration}}({{humanDuration duration}}){{/if}}
                        {{else if (eq type "item_at_risk")}}<i class="fas fa-box-open"></i> {{narrative}}
                        {{else if (eq type "encounter")}}<i class="fas fa-swords"></i> {{description}}
                        {{else if (eq type "consume_resource")}}<i class="fas fa-box-open"></i> Lose {{amount}} {{resource}}
                        {{/if}}
                    </div>
                    {{/each}}
                </div>
                {{/if}}

                {{else}}
                {{!-- PENDING: scene > stakes > check > action --}}
                {{#if @root.isGM}}

                {{#if awaitingRolls}}
                {{!-- GM: Awaiting player rolls --}}
                <div class="event-narration-advisory">
                    <i class="fas fa-hourglass-half"></i>
                    <em>Waiting for players to roll...</em>
                </div>
                {{#if resolvedRolls.length}}
                <div class="event-roll-results">
                    {{#each resolvedRolls}}
                    <div class="event-roll-line {{#if passed}}pass{{else}}fail{{/if}}">
                        <span class="roll-char-name">{{name}}</span>
                        <span class="roll-value">{{total}}</span>
                        <i class="fas {{#if passed}}fa-check-circle{{else}}fa-times-circle{{/if}}"></i>
                    </div>
                    {{/each}}
                </div>
                {{/if}}
                {{#if pendingRolls.length}}
                <div class="event-pending-rolls">
                    {{#each pendingRolls}}
                    <div class="event-roll-line pending">
                        <span class="roll-char-name">{{lookup (lookup @root.actorLookup this) "name"}}</span>
                        <span class="roll-status"><i class="fas fa-spinner fa-spin"></i> Waiting...</span>
                        <button type="button" class="btn-roll-for-player" data-action="rollEventForPlayer" data-character-id="{{this}}" data-event-index="{{@../index}}" title="Roll on their behalf">
                            <i class="fas fa-dice"></i> Roll for them
                        </button>
                    </div>
                    {{/each}}
                </div>
                {{/if}}
                <div class="event-override-links">
                    <button type="button" class="btn-override-link" data-action="resolveSkillCheck" data-event-index="{{@index}}" data-outcome="success">Force Pass</button>
                    <button type="button" class="btn-override-link" data-action="resolveSkillCheck" data-event-index="{{@index}}" data-outcome="failure">Force Fail</button>
                </div>

                {{else}}
                {{!-- GM: Pre-request state --}}

                {{!-- 1. Narrate prompt --}}
                <div class="event-narration-advisory">
                    <i class="fas fa-theater-masks"></i>
                    <em>Narrate this for the party, then resolve below.</em>
                </div>

                {{!-- 2. Stakes preview --}}
                <div class="event-outcome-preview">
                    <div class="outcome-preview-row pass">
                        <span class="outcome-preview-label"><i class="fas fa-check-circle"></i> Pass:</span>
                        <span class="outcome-preview-text">{{mechanical.onSuccess.narrative}}</span>
                    </div>
                    {{#each mechanical.onSuccess.effects}}
                    <div class="outcome-preview-effect pass"><i class="fas fa-cog"></i> {{description}}</div>
                    {{/each}}
                    <div class="outcome-preview-row fail">
                        <span class="outcome-preview-label"><i class="fas fa-times-circle"></i> Fail:</span>
                        <span class="outcome-preview-text">{{mechanical.onFailure.narrative}}</span>
                    </div>
                    {{#each mechanical.onFailure.effects}}
                    <div class="outcome-preview-effect fail"><i class="fas fa-cog"></i> {{description}}</div>
                    {{/each}}
                </div>

                {{!-- 3. DC + skill check details --}}
                <div class="event-check-header">
                    <div class="event-dc-badge">
                        <span class="dc-label">DC</span>
                        <span class="dc-value">{{mechanical.dc}}</span>
                    </div>
                    <div class="event-check-info">
                        <strong class="check-skill-name">{{skillName}}</strong>
                        <span class="event-check-target">
                            {{#if (eq mechanical.targets "watch")}}Watch only{{else if (eq mechanical.targets "all")}}Entire party{{else}}Watch{{/if}}
                            · Group Check (averaged)
                        </span>
                        <span class="event-check-direction">All rolls averaged against DC</span>
                    </div>
                </div>
                {{#if @root.isGM}}
                <div class="event-gm-hint">
                    <i class="fas fa-info-circle"></i>
                    Averaged rolls trend toward ~10. DCs above 13 are harder, below 8 are easier than individual checks.
                </div>
                {{/if}}

                {{!-- 4. Watch roster --}}
                {{#if targetNames.length}}
                <div class="event-watch-roster">
                    <i class="fas fa-eye"></i>
                    <strong>{{#if (eq mechanical.targets "all")}}Targets:{{else}}Watch:{{/if}}</strong> {{join targetNames ", "}}
                </div>
                {{/if}}

                {{!-- 5. Action buttons --}}
                <div class="event-adjudicate-buttons">
                    <button type="button" class="btn-resolve-check" data-action="resolveSkillCheck" data-event-index="{{@index}}" data-outcome="auto"
                        {{#if @root.anyEventAwaitingRolls}}{{#unless awaitingRolls}}disabled title="Resolve the current event first"{{/unless}}{{/if}}>
                        <i class="fas fa-dice-d20"></i> Request Rolls
                    </button>
                    <div class="event-override-links">
                        <button type="button" class="btn-override-link" data-action="resolveSkillCheck" data-event-index="{{@index}}" data-outcome="success"
                            {{#if @root.anyEventAwaitingRolls}}{{#unless awaitingRolls}}disabled{{/unless}}{{/if}}>Force Pass</button>
                        <button type="button" class="btn-override-link" data-action="resolveSkillCheck" data-event-index="{{@index}}" data-outcome="failure"
                            {{#if @root.anyEventAwaitingRolls}}{{#unless awaitingRolls}}disabled{{/unless}}{{/if}}>Force Fail</button>
                    </div>
                </div>
                {{/if}}

                {{else}}
                {{!-- PLAYER: Show roll buttons or waiting state --}}
                {{#if @root.pendingEventRoll}}
                {{#if (eq @index @root.pendingEventRoll.eventIndex)}}
                {{!-- This is the event the GM requested rolls for --}}
                {{#if @root.pendingEventRoll.ownedTargets.length}}
                <div class="event-player-roll-area">
                    {{#each @root.pendingEventRoll.ownedTargets}}
                    {{#if rolled}}
                    <div class="event-roll-submitted">
                        <i class="fas fa-check"></i> {{name}} has rolled.
                    </div>
                    {{else}}
                    <button type="button" class="btn-player-roll" data-action="rollEventCheck" data-character-id="{{id}}">
                        <i class="fas fa-dice-d20"></i> Roll {{@root.pendingEventRoll.skillName}} - {{name}}
                    </button>
                    {{/if}}
                    {{/each}}
                </div>
                {{else}}
                <div class="event-check-waiting">
                    <i class="fas fa-hourglass-half"></i> Waiting for watch to roll...
                </div>
                {{/if}}
                {{else}}
                {{!-- Different event, not this one's turn --}}
                <div class="event-check-waiting">
                    <i class="fas fa-hourglass-half"></i> The GM is adjudicating...
                </div>
                {{/if}}
                {{else}}
                <div class="event-check-waiting">
                    <i class="fas fa-hourglass-half"></i> The GM is adjudicating...
                </div>
                {{/if}}
                {{/if}}
                {{/if}}
            </div>
            {{/if}}

            {{!-- Encounter Hints (GM only, after failed check) --}}
            {{#if @root.isGM}}
            {{#if (eq resolvedOutcome "failure")}}
            {{#each mechanical.onFailure.effects}}
            {{#if encounterHints}}
            <div class="event-encounter-hints">
                <div class="encounter-hint-title"><i class="fas fa-dragon"></i> Encounter Setup</div>
                {{#if encounterHints.creatureSuggestions}}
                <div class="encounter-hint"><strong>Creatures:</strong> {{join encounterHints.creatureSuggestions ", "}}</div>
                {{/if}}
                {{#if encounterHints.groupSize}}
                <div class="encounter-hint"><strong>Group:</strong> {{encounterHints.groupSize}}</div>
                {{/if}}
                {{#if encounterHints.environment}}
                <div class="encounter-hint"><strong>Environment:</strong> {{encounterHints.environment}}</div>
                {{/if}}
                {{#if encounterHints.tactics}}
                <div class="encounter-hint"><strong>Tactics:</strong> {{encounterHints.tactics}}</div>
                {{/if}}
                {{#if encounterHints.awareness}}
                <div class="encounter-hint"><strong>Awareness:</strong> {{encounterHints.awareness}}</div>
                {{/if}}
                {{#if encounterHints.loot}}
                <div class="encounter-hint"><strong>Loot:</strong> {{encounterHints.loot}}</div>
                {{/if}}
            </div>
            {{/if}}
            {{/each}}
            {{/if}}
            {{/if}}
            {{/if}}

            {{#if treeHistory}}
            <div class="tree-history-summary">
                {{#each treeHistory}}
                <span class="tree-step"><i class="fas fa-chevron-right"></i> {{choiceLabel}}: {{#if
                    result.success}}Passed{{else}}Failed{{/if}}</span>
                {{/each}}
            </div>
            {{/if}}
        </div>
        {{/each}}
        {{else}}
        <div class="respite-event-card ambient">
            <div class="event-name">Quiet Rest</div>
            <div class="event-description">The night passes without incident.</div>
        </div>
        {{/if}}

        {{#if @root.isGM}}
        <div class="event-narration-hint">
            <i class="fas fa-theater-masks"></i>
            <em>Describe the outcome to your players before proceeding.</em>
        </div>
        {{/if}}
        {{/if}}

        {{/if}} {{!-- disasterChoice --}}

        {{else}}
        {{!-- PRE-ROLL: Camp preparations then Night Watch --}}
        {{#if isGM}}

        {{!-- Camp Preparations: camp activity rolls (persists after resolve for GM narration) --}}
        {{#if pendingCampRolls.length}}
        <div class="respite-event-card ambient camp-prep-card">
            <div class="event-name"><i class="fas fa-shield-alt"></i> Camp Preparations</div>
            <div class="event-description">
                {{#if campPrepsResolved}}Describe the results to your players before the encounter check.{{else}}Waiting for camp activity rolls to resolve before the encounter check.{{/if}}
            </div>
            <div class="camp-prep-list">
                {{#each pendingCampRolls}}
                <div class="camp-prep-entry {{status}}">
                    <i class="{{icon}}"></i>
                    <span class="camp-prep-name">{{characterName}}</span>
                    <span class="camp-prep-activity">{{activityName}}</span>
                    {{#if (eq status 'pass')}}
                    <span class="camp-prep-skill">{{skillName}} DC {{dc}}</span>
                    <span class="camp-prep-result pass"><i class="fas fa-check"></i> {{total}}</span>
                    {{else if (eq status 'fail')}}
                    <span class="camp-prep-skill">{{skillName}} DC {{dc}}</span>
                    <span class="camp-prep-result fail"><i class="fas fa-times"></i> {{total}}</span>
                    {{else}}
                    {{#if requested}}
                    <span class="camp-prep-skill">{{skillName}} DC {{dc}}{{#unless (eq dc baseDC)}} <span class="camp-dc-base">(was {{baseDC}})</span>{{/unless}}</span>
                    <span class="camp-prep-result pending"><i class="fas fa-paper-plane"></i> Sent</span>
                    <button type="button" class="btn-roll-for-player camp-fallback" data-action="rollCampForPlayer" data-character-id="{{characterId}}" title="Roll on their behalf">
                        <i class="fas fa-dice"></i>
                    </button>
                    {{else}}
                    <span class="camp-prep-dc-controls">
                        <span class="camp-prep-skill">{{skillName}}</span>
                        <button type="button" class="camp-dc-btn" data-action="adjustCampDC" data-character-id="{{characterId}}" data-delta="-1" title="Lower DC">−</button>
                        <span class="camp-dc-value">DC {{dc}}{{#unless (eq dc baseDC)}} <span class="camp-dc-base">({{baseDC}})</span>{{/unless}}</span>
                        <button type="button" class="camp-dc-btn" data-action="adjustCampDC" data-character-id="{{characterId}}" data-delta="1" title="Raise DC">+</button>
                    </span>
                    <button type="button" class="camp-prep-roll-btn" data-action="requestCampRoll" data-character-id="{{characterId}}" title="Send roll request to player">
                        <i class="fas fa-dice-d20"></i>
                    </button>
                    {{/if}}
                    {{/if}}
                </div>
                {{#if narrative}}
                <div class="camp-prep-narrative {{status}}">
                    <i class="fas {{#if (eq status 'pass')}}fa-check-circle{{else}}fa-times-circle{{/if}}"></i>
                    {{narrative}}
                </div>
                {{/if}}
                {{#each effectDescriptions}}
                <div class="camp-prep-effect">
                    <i class="fas fa-cog"></i> {{this}}
                </div>
                {{/each}}
                {{/each}}
            </div>
        </div>
        {{/if}}

        {{!-- Night Watch: shown when camp preps resolved or no preps needed --}}
        {{#if campPrepsResolved}}
        <div class="respite-event-card ambient event-roll-prompt">
            <div class="event-name"><i class="fas fa-dice-d20"></i> Night Watch</div>
            <div class="event-description">
                {{#if pendingCampRolls.length}}Camp preparations complete. {{/if}}Roll a d20 against the encounter threshold to see what the night brings.
            </div>
            {{#if encounterBar}}
            <div class="event-check-header">
                <div class="event-dc-badge">
                    <span class="dc-label">DC</span>
                    <span class="dc-value">{{encounterBar.effectiveDC}}</span>
                </div>
                <div class="event-check-info">
                    <strong class="check-skill-name">Encounter Threshold</strong>
                    <span class="event-check-direction event-outcome-advisory">
                        <i class="fas fa-moon"></i> Roll {{encounterBar.effectiveDC}}+: quiet night
                    </span>
                    <span class="event-check-direction event-outcome-advisory warn">
                        <i class="fas fa-exclamation-triangle"></i> Roll below {{encounterBar.effectiveDC}}: event triggers
                    </span>
                    <span class="event-check-direction event-outcome-advisory disaster">
                        <i class="fas fa-skull"></i> Natural 1: Disaster!
                    </span>
                </div>
            </div>
            {{/if}}
        </div>
        {{/if}}

        {{else}}
        {{!-- PLAYER VIEW: activity-specific messaging --}}
        <div class="respite-event-card ambient player-activity-card">
            <div class="event-name"><i class="fas fa-moon"></i> Resting...</div>
            <div class="event-description">
                The party settles in for the night. The GM will determine what the darkness holds.
            </div>

            {{!-- Camp roll buttons for owned characters --}}
            {{#if pendingCampRoll.activities.length}}
            <div class="camp-roll-section">
                {{#each pendingCampRoll.activities}}
                <div class="camp-roll-prompt {{status}}">
                    <div class="camp-roll-info">
                        <strong>{{activityName}}</strong>
                        <span class="camp-roll-skill">{{skillName}} DC {{dc}}</span>
                    </div>
                    {{#if (eq status 'pass')}}
                    <span class="camp-roll-result pass" title="Success! Rolled {{total}}">
                        <i class="fas fa-check-circle"></i> {{total}} - Passed
                    </span>
                    {{#each effectDescriptions}}
                    <div class="camp-roll-effect"><i class="fas fa-cog"></i> {{this}}</div>
                    {{/each}}
                    {{else if (eq status 'fail')}}
                    <span class="camp-roll-result fail" title="Failed. Rolled {{total}}">
                        <i class="fas fa-times-circle"></i> {{total}} - Failed
                    </span>
                    {{#each effectDescriptions}}
                    <div class="camp-roll-effect"><i class="fas fa-cog"></i> {{this}}</div>
                    {{/each}}
                    {{else if rolled}}
                    <span class="camp-roll-result pending">
                        <i class="fas fa-spinner fa-spin"></i> Awaiting...
                    </span>
                    {{else}}
                    <button type="button" class="btn-primary btn-camp-roll" data-action="rollCampCheck"
                        data-character-id="{{characterId}}">
                        <i class="fas fa-dice-d20"></i> Roll
                    </button>
                    {{/if}}
                </div>
                {{/each}}
            </div>
            {{/if}}
        </div>
        {{/if}}
        {{/if}}

    </div>
    {{#if isGM}}
    <div class="respite-action-bar">
        {{#if eventsRolled}}
            {{#if awaitingCombat}}
            {{!-- Combat in progress, GM decides when complete --}}
            <button type="button" class="btn-primary btn-combat-complete" data-action="completeEncounter">
                <i class="fas fa-check-circle"></i> Combat Complete
            </button>
            <button type="button" class="btn-secondary btn-hide-window" data-action="hideWindow">
                <i class="fas fa-eye-slash"></i> Hide
            </button>
            {{else if hasEncounterEvent}}
            {{!-- Encounter triggered but not yet acknowledged --}}
            <div class="encounter-gate">
                <div class="encounter-instructions">
                    <i class="fas fa-exclamation-triangle"></i>
                    <span>An encounter has been triggered. Set up the combat before proceeding.</span>
                </div>
                {{#if encounterAwareness}}
                <div class="encounter-awareness-advisory">
                    <i class="fas fa-eye"></i>
                    <span>{{encounterAwareness}}</span>
                </div>
                {{/if}}
                {{#if combatBuffs}}
                <div class="combat-readiness-report">
                    <div class="combat-readiness-header">
                        <i class="fas fa-shield-alt"></i> Combat Readiness
                    </div>
                    {{#if combatBuffs.perCharacter.length}}
                    <div class="combat-readiness-list">
                        {{#each combatBuffs.perCharacter}}
                        <div class="combat-buff-entry">
                            <span class="combat-buff-name">{{characterName}}</span>
                            <span class="combat-buff-activity">({{activityName}})</span>
                            <span class="combat-buff-summary">{{summary}}</span>
                        </div>
                        {{/each}}
                    </div>
                    {{/if}}
                    {{#if combatBuffs.partyWide.summary}}
                    <div class="combat-readiness-party">
                        <i class="fas fa-users"></i> {{combatBuffs.partyWide.summary}}
                    </div>
                    {{/if}}
                    {{#unless combatBuffs.perCharacter.length}}
                    <div class="combat-readiness-none">
                        No combat modifiers from the party's activities.
                    </div>
                    {{/unless}}
                </div>
                {{/if}}
                <button type="button" class="btn-primary btn-acknowledge-encounter" data-action="acknowledgeEncounter">
                    <i class="fas fa-swords"></i> Begin Combat
                </button>
            </div>
            {{else}}
            {{!-- No encounter, or encounter resolved, allow rest resolution --}}
            {{#if activeTreeState}}{{#unless activeTreeState.resolved}}
            {{!-- Hidden while decision tree is active --}}
            {{/unless}}{{/if}}
            {{#unless (and activeTreeState (not activeTreeState.resolved))}}
            <button type="button" class="btn-primary" data-action="resolveEvents"
                {{#if disasterChoice}}disabled title="Choose a disaster outcome first"{{/if}}
                {{#unless allEventChecksResolved}}disabled title="Resolve all event skill checks first"{{/unless}}>
                <i class="fas fa-arrow-right"></i> Proceed to Resolution
            </button>
            {{/unless}}
            {{/if}}
        {{else}}
        <button type="button" class="btn-primary btn-roll-events" data-action="rollEvents"
            {{#unless campPrepsResolved}}disabled title="Awaiting camp activity rolls"{{/unless}}>
            <i class="fas fa-dice-d20"></i> Roll for Events
        </button>
        {{/if}}
    </div>
    {{else}}
    <div class="respite-action-bar">
        {{#if eventsRolled}}
        <span class="phase-waiting-label"><i class="fas fa-hourglass-half"></i> The GM is resolving events...</span>
        {{else}}
        <span class="phase-waiting-label"><i class="fas fa-moon"></i> The party rests...</span>
        {{/if}}
    </div>
    {{/if}}
    {{/if}}

    {{!-- =============== RESOLUTION PHASE =============== --}}
    {{#if (eq phase 'resolve')}}
    <div class="phase-banner">
        <img src="{{terrainBanner}}" alt="" style="object-position: {{terrainBannerPos}}" onerror="this.onerror=null;this.src='{{terrainBannerFallback}}'">
    </div>
    {{> rosterStrip}}

    {{#if isGM}}
    <div class="respite-resolution">
        {{#each outcomes}}
        <div class="respite-outcome-card">
            <div class="outcome-header">
                <strong>{{characterName}}</strong>
                <span class="comfort-indicator {{recovery.comfortLevel}}">{{recovery.comfortLevel}}</span>
            </div>
            {{#if eventDisrupted}}
            <div class="outcome-disrupted">
                <i class="fas fa-exclamation-triangle"></i> Complications during rest
            </div>
            {{/if}}
            {{#each outcomes}}
            {{#if (eq source "event")}}
            <div class="outcome-event {{category}}">
                <div class="outcome-event-header">
                    <i class="fas {{#if (eq category 'complication')}}fa-exclamation-triangle{{else if (eq category 'encounter')}}fa-swords{{else if (eq category 'discovery')}}fa-search{{else}}fa-moon{{/if}}"></i>
                    <strong>{{eventName}}</strong>
                    {{#if resolvedOutcome}}
                    <span class="roll-verdict {{resolvedOutcome}}">{{#if (eq resolvedOutcome "success")}}Passed{{else}}Failed{{/if}}</span>
                    {{/if}}
                </div>
                <div class="outcome-narrative">{{narrative}}</div>
                {{#if effects.length}}
                <div class="outcome-effects">
                    {{#each effects}}
                    <div class="outcome-effect-line">
                        {{#if (eq type "damage")}}<i class="fas fa-heart-broken"></i> {{formula}} {{damageType}} damage
                        {{else if (eq type "recovery_penalty")}}<i class="fas fa-bed"></i> Recovery reduced (x{{hpMultiplier}})
                        {{else if (eq type "condition")}}<i class="fas fa-skull-crossbones"></i> Gained {{condition}}{{#if checks.length}} on {{#each checks}}{{#if @index}}, {{/if}}{{upper this}}{{/each}} checks{{/if}} {{#if duration}}({{humanDuration duration}}){{/if}}
                        {{else if (eq type "item_at_risk")}}<i class="fas fa-box-open"></i> {{narrative}}
                        {{else if (eq type "encounter")}}<i class="fas fa-swords"></i> Combat encounter
                        {{else}}{{narrative}}
                        {{/if}}
                    </div>
                    {{/each}}
                </div>
                {{/if}}
            </div>
            {{else}}
            {{#if result}}
            <span class="roll-verdict {{result}}">
                {{#if (eq result "exceptional")}}<i class="fas fa-star"></i> Exceptional
                {{else if (eq result "success")}}<i class="fas fa-check"></i> Success
                {{else if (eq result "failure")}}<i class="fas fa-times"></i> Failed
                {{else if (eq result "failure_complication")}}<i class="fas fa-exclamation-triangle"></i> Failed
                {{/if}}
            </span>
            {{/if}}
            <div class="outcome-narrative">{{narrative}}</div>
            {{#if effects.length}}
            <div class="outcome-effects">
                {{#each effects}}
                <div class="outcome-effect-line">
                    <i class="fas fa-cog"></i> {{description}}
                </div>
                {{/each}}
            </div>
            {{/if}}
            {{#if craftingResult}}
            <div class="outcome-craft-detail">
                Rolled {{craftingResult.roll}} vs DC {{craftingResult.dc}} ({{craftingResult.riskTier}})
            </div>
            {{/if}}
            {{#unless (eq source "event")}}
            {{#if items.length}}
            <div class="outcome-items">
                {{#each items}}
                <div class="item-gained"><i class="fas fa-plus-circle"></i> {{#if
                    name}}{{name}}{{else}}{{itemRef}}{{/if}} {{#if quantity}}x{{quantity}}{{/if}}</div>
                {{/each}}
            </div>
            {{/if}}
            {{/unless}}
            {{/if}}
            {{/each}}
            {{#if recovery.gearDescriptors.length}}
            <div class="outcome-effects" style="opacity:0.7;font-size:0.85em;">
                {{#each recovery.gearDescriptors}}
                <div class="outcome-effect-line"><i class="fas fa-cog"></i> {{this}}</div>
                {{/each}}
            </div>
            {{/if}}
            {{#if recovery.exhaustionDC}}
            <div class="outcome-exhaustion-advisory {{#if (eq recovery.exhaustionSaveResult 'passed')}}save-passed{{else if (eq recovery.exhaustionSaveResult 'failed')}}save-failed{{/if}}">
                <i class="fas fa-bed"></i>
                <span>CON save DC {{recovery.exhaustionDC}}{{#if recovery.exhaustionAdvantage}} <span class="gear-annotation">(advantage from hot meal)</span>{{/if}}{{#if (eq recovery.exhaustionSaveResult 'passed')}} <span class="exhaustion-recovered">Passed (no exhaustion gained)</span>{{else if (eq recovery.exhaustionSaveResult 'failed')}}{{#if (gt recovery.exhaustionDelta 0)}} <span class="exhaustion-gained">Failed (+1 Exhaustion)</span>{{else}} <span class="exhaustion-offset">Failed (offset by rest recovery)</span>{{/if}}{{/if}}</span>
            </div>
            <div class="outcome-effect-line" style="opacity:0.6;font-size:0.75em;padding-left:1.2rem;">{{#if (eq recovery.comfortLevel 'hostile')}}Hostile{{else}}Rough{{/if}} rest conditions require a Constitution save to avoid exhaustion.</div>
            {{/if}}
            {{#if (eq recovery.comfortLevel "hostile")}}
            {{#unless (lt recovery.exhaustionDelta 0)}}
            <div class="outcome-exhaustion-advisory hostile-note">
                <i class="fas fa-skull"></i>
                <span>Hostile conditions block recovery of existing exhaustion</span>
            </div>
            {{/unless}}
            {{/if}}
            {{#if recovery.eventDamage}}
            <div class="outcome-exhaustion-advisory" style="background: rgba(231, 76, 60, 0.1); border-left: 2px solid #e74c3c;">
                <i class="fas fa-tint" style="color: #e74c3c;"></i>
                <span style="color: #e74c3c;">Took {{recovery.eventDamage}} damage</span>
            </div>
            {{/if}}
        </div>
        {{/each}}
    </div>
    {{#if partyDiscoveries.length}}
    <div class="party-discoveries">
        <div class="party-discoveries-header"><i class="fas fa-gem"></i> Party Discoveries</div>
        {{#each partyDiscoveries}}
        <div class="party-discovery-item">
            {{#if granted}}
            <i class="fas fa-check-circle discovery-granted-icon"></i>
            <span class="discovery-name">{{#if grantedItemName}}{{grantedItemName}}{{else}}{{#if name}}{{name}}{{else}}{{itemRef}}{{/if}}{{/if}}</span>
            <span class="discovery-qty">x{{grantedQty}}</span>
            <span class="discovery-granted-to"><i class="fas fa-arrow-right"></i> {{grantedTo}}</span>
            {{else}}
            <i class="fas fa-plus-circle"></i>
            <span class="discovery-name">{{#if name}}{{name}}{{else}}{{itemRef}}{{/if}}</span>
            {{#if quantity}}<span class="discovery-qty">x{{quantity}}</span>{{/if}}
            <span class="discovery-source">from {{eventName}}</span>
            <select class="discovery-actor-select">
                <option value="">Assign to...</option>
                {{#each @root.grantActors}}
                <option value="{{id}}">{{name}}</option>
                {{/each}}
            </select>
            <button type="button" class="discovery-grant-btn" data-action="grantDiscoveryItem"
                data-grant-key="{{grantKey}}" data-item-ref="{{itemRef}}" data-quantity="{{quantity}}">
                <i class="fas fa-gift"></i> Grant
            </button>
            {{/if}}
        </div>
        {{/each}}
        <div class="party-discoveries-hint"><i class="fas fa-info-circle"></i> Items are rolled and created on the character sheet when granted.</div>
    </div>
    {{/if}}
    <div class="respite-action-bar">
        {{#if recoverySummary.length}}
        <div class="recovery-preview">
            {{#each recoverySummary}}
            <span class="recovery-chip{{#if eventDamage}} has-damage{{/if}}">{{name}}: +{{hp}} HP, +{{hd}} HD{{#if gearBonuses.hd}} <span class="gear-annotation">(+1 bedroll)</span>{{/if}}{{#if eventDamage}}, <span class="event-damage">-{{eventDamage}} dmg</span>{{/if}}{{#if exhaustionDC}}{{#if exhaustionDelta}}{{#if (gt exhaustionDelta 0)}}, <span class="exhaustion-gained">+{{exhaustionDelta}} Exhaustion</span>{{else}}, <span class="exhaustion-recovered">exhaustion save: passed{{#if gearBonuses.exhaustionAdvantage}} (advantage){{/if}}</span>{{/if}}{{else}} <span class="gear-annotation">(CON DC {{exhaustionDC}}{{#if gearBonuses.exhaustionAdvantage}}, advantage{{/if}})</span>{{/if}}{{/if}}{{#unless exhaustionDC}}{{#if exhaustionDelta}}{{#if (gt exhaustionDelta 0)}}, <span class="exhaustion-gained">+{{exhaustionDelta}} Exhaustion</span>{{else}}, <span class="exhaustion-recovered">{{exhaustionDelta}} Exhaustion</span>{{/if}}{{/if}}{{/unless}}</span>
            {{/each}}
            {{#each activitySummary}}
            <span class="recovery-chip {{#if (eq result 'failure')}}failure{{/if}}{{#if (eq result 'failure_complication')}}failure{{/if}}">
                {{#if (eq result 'failure')}}<i class="fas fa-times"></i>{{else}}{{#if (eq result 'failure_complication')}}<i class="fas fa-times"></i>{{else}}<i class="fas fa-check"></i>{{/if}}{{/if}}
                {{name}}: {{activityName}}
            </span>
            {{/each}}
        </div>
        {{/if}}
        <button type="button" class="btn-primary" data-action="finalize" style="white-space: nowrap;">
            <i class="fas fa-times"></i> Close
        </button>
    </div>
    {{else}}
    {{!-- Player: show personal results --}}
    <div class="respite-resolution">
        {{#if outcomes.length}}
        {{#each outcomes}}
        <div class="respite-outcome-card">
            <div class="outcome-header">
                <strong>{{characterName}}</strong>
                {{#if recovery.comfortLevel}}
                <span class="comfort-indicator {{recovery.comfortLevel}}" title="Rest comfort level affects HP recovery">
                    <i class="fas fa-bed"></i> Comfort: {{recovery.comfortLevel}}
                </span>
                {{/if}}
            </div>
            {{#each outcomes}}
            <div class="outcome-narrative">{{narrative}}</div>
            {{#if craftingResult}}
            <div class="outcome-craft-detail">
                Rolled {{craftingResult.roll}} vs DC {{craftingResult.dc}} ({{craftingResult.riskTier}})
            </div>
            {{/if}}
            {{#unless (eq source "event")}}
            {{#if items.length}}
            <div class="outcome-items">
                {{#each items}}
                <div class="item-gained"><i class="fas fa-plus-circle"></i> {{#if
                    name}}{{name}}{{else}}{{itemRef}}{{/if}} {{#if quantity}}x{{quantity}}{{/if}}</div>
                {{/each}}
            </div>
            {{/if}}
            {{/unless}}
            {{/each}}
            {{#if recovery.gearDescriptors.length}}
            <div class="outcome-effects" style="opacity:0.7;font-size:0.85em;">
                {{#each recovery.gearDescriptors}}
                <div class="outcome-effect-line"><i class="fas fa-cog"></i> {{this}}</div>
                {{/each}}
            </div>
            {{/if}}
            {{#if recovery.exhaustionDC}}
            <div class="outcome-exhaustion-advisory {{#if (eq recovery.exhaustionSaveResult 'passed')}}save-passed{{else if (eq recovery.exhaustionSaveResult 'failed')}}save-failed{{/if}}">
                <i class="fas fa-bed"></i>
                <span>CON save DC {{recovery.exhaustionDC}}{{#if recovery.exhaustionAdvantage}} <span class="gear-annotation">(advantage from hot meal)</span>{{/if}}{{#if (eq recovery.exhaustionSaveResult 'passed')}} <span class="exhaustion-recovered">Passed (no exhaustion gained)</span>{{else if (eq recovery.exhaustionSaveResult 'failed')}}{{#if (gt recovery.exhaustionDelta 0)}} <span class="exhaustion-gained">Failed (+1 Exhaustion)</span>{{else}} <span class="exhaustion-offset">Failed (offset by rest recovery)</span>{{/if}}{{/if}}</span>
            </div>
            <div class="outcome-effect-line" style="opacity:0.6;font-size:0.75em;padding-left:1.2rem;">{{#if (eq recovery.comfortLevel 'hostile')}}Hostile{{else}}Rough{{/if}} rest conditions require a Constitution save to avoid exhaustion.</div>
            {{/if}}
            {{#if (eq recovery.comfortLevel "hostile")}}
            {{#unless (lt recovery.exhaustionDelta 0)}}
            <div class="outcome-exhaustion-advisory hostile-note">
                <i class="fas fa-skull"></i>
                <span>Hostile conditions block recovery of existing exhaustion</span>
            </div>
            {{/unless}}
            {{/if}}
            {{#if recovery.eventDamage}}
            <div class="outcome-exhaustion-advisory" style="background: rgba(231, 76, 60, 0.1); border-left: 2px solid #e74c3c;">
                <i class="fas fa-tint" style="color: #e74c3c;"></i>
                <span style="color: #e74c3c;">Took {{recovery.eventDamage}} damage</span>
            </div>
            {{/if}}
        </div>
        {{/each}}
        {{#if partyDiscoveries.length}}
        <div class="party-discoveries">
            <div class="party-discoveries-header"><i class="fas fa-gem"></i> Party Discoveries</div>
            {{#each partyDiscoveries}}
            <div class="party-discovery-item">
                <i class="fas fa-plus-circle"></i>
                <span class="discovery-name">{{#if name}}{{name}}{{else}}{{itemRef}}{{/if}}</span>
                {{#if quantity}}<span class="discovery-qty">x{{quantity}}</span>{{/if}}
                <span class="discovery-source">from {{eventName}}</span>
            </div>
            {{/each}}
        </div>
        {{/if}}
        {{#if recoverySummary.length}}
        <div class="recovery-preview">
            {{#each recoverySummary}}
            <span class="recovery-chip{{#if eventDamage}} has-damage{{/if}}">{{name}}: +{{hp}} HP, +{{hd}} HD{{#if gearBonuses.hd}} <span class="gear-annotation">(+1 bedroll)</span>{{/if}}{{#if eventDamage}}, <span class="event-damage">-{{eventDamage}} dmg</span>{{/if}}{{#if exhaustionDC}}{{#if exhaustionDelta}}{{#if (gt exhaustionDelta 0)}}, <span class="exhaustion-gained">+{{exhaustionDelta}} Exhaustion</span>{{else}}, <span class="exhaustion-recovered">exhaustion save: passed{{#if gearBonuses.exhaustionAdvantage}} (advantage){{/if}}</span>{{/if}}{{else}} <span class="gear-annotation">(CON DC {{exhaustionDC}}{{#if gearBonuses.exhaustionAdvantage}}, advantage{{/if}})</span>{{/if}}{{/if}}{{#unless exhaustionDC}}{{#if exhaustionDelta}}{{#if (gt exhaustionDelta 0)}}, <span class="exhaustion-gained">+{{exhaustionDelta}} Exhaustion</span>{{else}}, <span class="exhaustion-recovered">{{exhaustionDelta}} Exhaustion</span>{{/if}}{{/if}}{{/unless}}</span>
            {{/each}}
            {{#each activitySummary}}
            <span class="recovery-chip {{#if (eq result 'failure')}}failure{{/if}}{{#if (eq result 'failure_complication')}}failure{{/if}}">
                {{#if (eq result 'failure')}}<i class="fas fa-times"></i>{{else}}{{#if (eq result 'failure_complication')}}<i class="fas fa-times"></i>{{else}}<i class="fas fa-check"></i>{{/if}}{{/if}}
                {{name}}: {{activityName}}
            </span>
            {{/each}}
        </div>
        {{/if}}
        <div class="respite-waiting-message resolution-complete">
            <p class="whisper-hint">The GM will finalize and apply these results shortly.</p>
        </div>
        {{else}}
        <div class="respite-waiting-message resolution-complete">
            <i class="fas fa-sun"></i>
            <p>Dawn breaks. The GM is finalizing rest outcomes.</p>
        </div>
        {{/if}}
    </div>
    {{/if}}
    {{/if}}

    {{!-- GM Copy Spell Transaction Card --}}
    {{#if gmCopySpellProposal}}
    <div class="gm-copy-spell-card" style="background: rgba(80,60,140,0.15); border: 1px solid {{#if gmCopySpellProposal.charged}}rgba(34,197,94,0.4){{else}}rgba(160,120,220,0.4){{/if}}; border-radius: 6px; padding: 0.6rem 0.75rem; margin: 0.5rem 0.75rem;">
        {{#if gmCopySpellProposal.charged}}
        {{!-- CHARGED STATE: Gold taken, awaiting player's Arcana roll --}}
        <div style="font-weight: 600; color: rgba(34,197,94,0.9); font-size: 0.85rem; margin-bottom: 0.4rem;">
            <i class="fas fa-coins"></i> Gold Charged - Awaiting Arcana Roll
        </div>
        <div style="font-size: 0.75rem; color: rgba(255,255,255,0.75); line-height: 1.5;">
            <strong>{{gmCopySpellProposal.actorName}}</strong>:
            Level <strong>{{gmCopySpellProposal.spellLevel}}</strong> spell.
            <strong>{{gmCopySpellProposal.cost}}gp</strong> charged
            ({{gmCopySpellProposal.remainingGold}}gp remaining).<br>
            <i class="fas fa-dice-d20" style="color: rgba(126,184,218,0.8);"></i>
            Waiting for player to roll Arcana DC <strong>{{gmCopySpellProposal.dc}}</strong>.
        </div>
        <div style="font-size: 0.65rem; color: rgba(255,255,255,0.4); margin-top: 0.3rem; font-style: italic;">
            If the player disconnected, use re-send or roll on their behalf.
        </div>
        <div style="display: flex; gap: 0.4rem; margin-top: 0.5rem;">
            <button type="button" data-action="resendCopySpellRoll"
                style="flex: 1; padding: 0.3rem 0.5rem; border-radius: 4px; background: linear-gradient(135deg, rgba(126,184,218,0.3), rgba(126,184,218,0.15)); border: 1px solid rgba(126,184,218,0.4); color: rgba(255,255,255,0.9); font-weight: 600; font-size: 0.75rem; cursor: pointer;">
                <i class="fas fa-redo"></i> Re-send Roll
            </button>
            <button type="button" data-action="gmCopySpellFallback"
                style="flex: 1; padding: 0.3rem 0.5rem; border-radius: 4px; background: linear-gradient(135deg, rgba(243,156,18,0.3), rgba(243,156,18,0.15)); border: 1px solid rgba(243,156,18,0.4); color: rgba(255,255,255,0.9); font-weight: 600; font-size: 0.75rem; cursor: pointer;">
                <i class="fas fa-dice-d20"></i> GM Rolls Instead
            </button>
            <button type="button" data-action="dismissGmCopySpell"
                style="padding: 0.3rem 0.5rem; border-radius: 4px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: rgba(255,255,255,0.5); font-size: 0.75rem; cursor: pointer;">
                <i class="fas fa-times"></i>
            </button>
        </div>
        {{else}}
        {{!-- INITIAL STATE: Proposal received, GM decides to charge --}}
        <div style="font-weight: 600; color: rgba(180,140,240,0.9); font-size: 0.85rem; margin-bottom: 0.4rem;">
            <i class="fas fa-scroll"></i> Copy Spell Request
        </div>
        <div style="font-size: 0.75rem; color: rgba(255,255,255,0.75); line-height: 1.5;">
            <strong>{{gmCopySpellProposal.actorName}}</strong> wants to copy a
            <strong>Level {{gmCopySpellProposal.spellLevel}}</strong> spell.<br>
            <i class="fas fa-coins" style="color: rgba(255,200,100,0.8);"></i>
            Cost: <strong>{{gmCopySpellProposal.cost}}gp</strong>
            (has {{gmCopySpellProposal.currentGold}}gp)
            {{#unless gmCopySpellProposal.canAfford}}
            <span style="color: #ef9a9a;"> - insufficient gold</span>
            {{/unless}}
            <br>
            <i class="fas fa-dice-d20" style="color: rgba(126,184,218,0.8);"></i>
            Arcana DC: <strong>{{gmCopySpellProposal.dc}}</strong>
        </div>
        <div style="font-size: 0.65rem; color: rgba(255,255,255,0.4); margin-top: 0.3rem; font-style: italic;">
            Determine which spell the player is copying. On success, add it to their spell listing.
            If copying from a scroll, the scroll is consumed regardless of outcome.
        </div>
        <div style="display: flex; gap: 0.4rem; margin-top: 0.5rem;">
            {{#if gmCopySpellProposal.canAfford}}
            <button type="button" data-action="processGmCopySpell"
                style="flex: 1; padding: 0.3rem 0.5rem; border-radius: 4px; background: linear-gradient(135deg, rgba(34,197,94,0.3), rgba(34,197,94,0.15)); border: 1px solid rgba(34,197,94,0.4); color: rgba(255,255,255,0.9); font-weight: 600; font-size: 0.75rem; cursor: pointer;">
                <i class="fas fa-coins"></i> Charge & Send Roll
            </button>
            {{else}}
            <button type="button" disabled
                style="flex: 1; padding: 0.3rem 0.5rem; border-radius: 4px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: rgba(255,255,255,0.3); font-weight: 600; font-size: 0.75rem; cursor: not-allowed;">
                <i class="fas fa-coins"></i> Can't Afford
            </button>
            {{/if}}
            <button type="button" data-action="dismissGmCopySpell"
                style="padding: 0.3rem 0.5rem; border-radius: 4px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: rgba(255,255,255,0.5); font-size: 0.75rem; cursor: pointer;">
                <i class="fas fa-times"></i> Dismiss
            </button>
        </div>
        {{/if}}
    </div>
    {{/if}}

    {{!-- Player Copy Spell Roll Card --}}
    {{#if copySpellRollPrompt}}
    <div class="player-copy-spell-roll" style="background: rgba(60,80,140,0.15); border: 1px solid rgba(126,184,218,0.4); border-radius: 6px; padding: 0.6rem 0.75rem; margin: 0.5rem 0.75rem;">
        <div style="font-weight: 600; color: rgba(126,184,218,0.9); font-size: 0.85rem; margin-bottom: 0.4rem;">
            <i class="fas fa-dice-d20"></i> Arcana Check Required
        </div>
        <div style="font-size: 0.75rem; color: rgba(255,255,255,0.75); line-height: 1.5;">
            <strong>{{copySpellRollPrompt.cost}}gp</strong> charged for a
            <strong>Level {{copySpellRollPrompt.spellLevel}}</strong> spell.
            ({{copySpellRollPrompt.remainingGold}}gp remaining)<br>
            Roll Arcana to meet <strong>DC {{copySpellRollPrompt.dc}}</strong>.
        </div>
        <div style="margin-top: 0.5rem;">
            <button type="button" data-action="rollCopySpellArcana"
                style="width: 100%; padding: 0.4rem 0.5rem; border-radius: 4px; background: linear-gradient(135deg, rgba(126,184,218,0.35), rgba(126,184,218,0.15)); border: 1px solid rgba(126,184,218,0.5); color: rgba(255,255,255,0.95); font-weight: 600; font-size: 0.85rem; cursor: pointer;">
                <i class="fas fa-dice-d20"></i> Roll Arcana
            </button>
        </div>
    </div>
    {{/if}}

    {{!-- Encounter Status Bar: persistent footer --}}
    {{#if encounterBar}}
    <div class="encounter-bar">
        <span class="encounter-bar-label-wrap">
            <span class="encounter-bar-label">
                <i class="fas fa-dice-d20"></i>
                {{encounterBar.totalLabel}}
            </span>
            <div class="encounter-bar-tooltip" role="tooltip">
                Roll a d20. Meet or beat this value for a quiet night; fall short and a camp event is drawn. Natural 1 always triggers the disaster fork. Higher DC means a harder night. Shelter, fire, defenses, and scouting all shift this number.
            </div>
        </span>
        {{#if encounterBar.chips.length}}
        <span class="encounter-bar-chips">
            {{#each encounterBar.chips}}
            <span class="encounter-chip {{#if warn}}warn{{/if}}">
                <i class="{{icon}}"></i> {{label}}{{#if value}} {{value}}{{/if}}
            </span>
            {{/each}}
        </span>
        {{/if}}
        {{#if encounterBar.isGM}}
        <span class="encounter-gm-adj">
            <button type="button" class="encounter-adj-btn" data-action="encounterAdjDown" title="Reduce DC">−</button>
            <button type="button" class="encounter-adj-btn" data-action="encounterAdjUp" title="Increase DC">+</button>
        </span>
        {{/if}}
    </div>
    {{/if}}

</form>
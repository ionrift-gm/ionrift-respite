        <span class="totm-footer-waiting"><i class="fas fa-hourglass-half" aria-hidden="true"></i> Waiting for others</span>
        {{/if}}
    </div>
    {{else}}
    <div class="activity-phase-layout">
        <div class="respite-activities activity-phase-player-overview-wrap">
            <div class="player-overview-heading">
                <i class="fas fa-users" aria-hidden="true"></i>
                <span>Party progress</span>
            </div>

            <div class="player-overview-stat">
                <span class="player-overview-label">Party members with an activity</span>
                <span class="player-overview-value">{{activityPhasePlayerOverview.resolvedCount}} / {{activityPhasePlayerOverview.totalCharacters}}</span>
            </div>

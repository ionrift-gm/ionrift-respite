{{!-- Ionrift Respite: Player Activity Picker (ApplicationV2) --}}
{{!-- Pushed to player clients when GM initiates a rest --}}

<div class="respite-picker">

    {{!-- Rest Context --}}
    <div class="respite-picker-header">
        <div class="picker-context">
            <span class="rest-type-badge">{{restType}}</span>
            <span class="terrain-badge"><i class="fas fa-map-marker-alt"></i> {{terrain}}</span>
            <span class="comfort-indicator {{comfort}}">{{comfortLabel}}</span>
        </div>
        {{#if comfortWarning}}
        <div class="picker-warning">
            <i class="fas fa-exclamation-triangle"></i> {{comfortWarning}}
        </div>
        {{/if}}
    </div>

    {{!-- Submitted State --}}
    {{#if hasSubmitted}}
    <div class="respite-submitted">
        <div class="submitted-icon"><i class="fas fa-check-circle"></i></div>
        <div class="submitted-text">Choices submitted. Waiting for the GM.</div>
    </div>
    {{else}}

    {{!-- Character Activity Cards --}}
    <div class="respite-picker-characters">
        {{#each characters}}
        <div class="respite-character-card">
            <img class="character-portrait" src="{{img}}" alt="{{name}}">
            <div class="character-info">
                <span class="character-name">{{name}}</span>
                <select class="activity-select" data-character-id="{{id}}">
                    <option value="">Choose activity...</option>
                    {{#each activities}}
                    <option value="{{id}}" {{#if (eq id ../currentChoice)}}selected{{/if}}
                        {{#if activityDisabled}}disabled title="{{disabledTooltip}}" class="activity-option-disabled"{{/if}}
                        data-crafting="{{isCrafting}}" data-profession="{{craftingProfession}}"
                        data-combat-hint="{{combatModifiers.description}}">
                        {{name}} {{#if isCrafting}}(recipes){{/if}}
                    </option>
                    {{/each}}
                </select>
                <div class="combat-readiness-hint"></div>
                <div class="activity-followup-panel" data-character-id="{{id}}" style="display:none;"></div>
                {{!-- Show Browse Recipes button for crafting activities --}}
                {{#each activities}}
                {{#if isCrafting}}
                <button type="button" class="btn-crafting-browse" data-action="openCrafting"
                    data-character-id="{{../id}}" data-profession="{{craftingProfession}}">
                    <i class="fas fa-utensils"></i> Browse Recipes
                </button>
                {{/if}}
                {{/each}}
            </div>
        </div>
        {{/each}}
    </div>

    {{!-- Submit --}}
    <div class="respite-action-bar">
        <button type="button" class="btn-primary" data-action="submitChoice">
            <i class="fas fa-paper-plane"></i> Submit Choices
        </button>
    </div>

    {{/if}}
</div>
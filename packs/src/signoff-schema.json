{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ionrift.local/schemas/respite-signoff.json",
  "title": "Ionrift Respite compendium sign-off",
  "type": "object",
  "required": ["version", "items", "actors", "guide"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "string" },
    "items": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/entry" }
    },
    "actors": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/entry" }
    },
    "guide": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/entry" }
    }
  },
  "$defs": {
    "entry": {
      "type": "object",
      "required": ["status", "assetSource"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["approved", "draft", "test", "pending-review"]
        },
        "approvedBy": { "type": "string" },
        "approvedDate": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
        "assetSource": {
          "type": "string",
          "enum": ["foundry-core", "cc0", "custom-art", "ai-generated", "none"]
        },
        "assetSourceNote": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}

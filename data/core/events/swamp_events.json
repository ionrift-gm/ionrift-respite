        {
            "id": "evt_swamp_stalkers",
            "name": "Swamp Stalkers",
            "category": "encounter",
            "terrainTags": [
                "swamp"
            ],
            "weight": 2,
            "watchTarget": "watch",
            "description": "Ripples in still water. Something is approaching camp from the marshes. It moves without sound.",
            "mechanical": {
                "type": "skill_check",
                "skill": "prc",
                "dc": 14,
                "targets": "watch",
                "bestOfN": true,
                "onSuccess": {
                    "narrative": "You caught the movement in time. Weapons drawn and fire stoked, the creatures slip back into the dark water.",
                    "effects": []
                },
                "onFailure": {
                    "narrative": "They rise from the water at the camp's edge. Mud-covered and silent until now.",
                    "effects": [
                        {
                            "type": "encounter",
                            "description": "Swamp ambush on the camp.",
                            "encounterHints": {
                                "creatureSuggestions": [
                                    "lizardfolk",
                                    "bullywugs",
                                    "grung",
                                    "shambling mound"
                                ],
                                "crRange": {
                                    "min": "party_level - 1",
                                    "max": "party_level + 1"
                                },
                                "groupSize": "3-5",
                                "environment": "knee-deep water, mud, reeds, low visibility, night",
                                "awareness": "surprised if watch failed, otherwise standard initiative",
                                "tactics": "Territorial defense. Drag targets into water. Retreat to deep marsh if losing.",
                                "loot": "Trophies, salvaged weapons, or a map scratched on hide showing dry paths through the swamp."
                            }
                        }
                    ]
                }
            },
            "tier": "normal",
            "sentiment": "negative",
            "pack": "base"
        },
        {

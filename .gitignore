# === Ionrift Respite ===

# Terrain packs: ignore all, then whitelist module-shipped base terrains.
# Overlay-delivered terrains (arctic, mountain, ruins, catacombs) live in
# ionrift-pack-workshop and never land here.
data/terrains/*/
!data/terrains/desert/
!data/terrains/dungeon/
!data/terrains/forest/
!data/terrains/short-rest/
!data/terrains/swamp/
!data/terrains/tavern/
!data/terrains/urban/

# !! CONTENT PACKS — PATREON ONLY !!
# These paths contain proprietary content distributed through Patreon.
# DO NOT remove these exclusions. DO NOT commit content pack data to this repo.
# See DEV_PROTOCOLS.md Section 28: Content Pack Safety.
data/wanderers_pack/

# Unreleased data (not shipped in current version)
data/professions/
data/core/forage/
data/core/events/mountain_events.json

# Node / dev tooling
node_modules/
package.json
package-lock.json
pack-items.mjs
pack-actors.mjs

# Dev scripts & test suites (IP-sensitive — hosted in private ionrift-tests repo)
scripts/tests/
scripts/utils/
scripts/dev-link-packs.ps1
macros/

# LevelDB compiled packs (build artifacts — compiled from packs/src/ at release time)
# JSON source files in packs/src/ are the canonical data.
packs/respite-items/
packs/respite-actors/
packs/respite-guide/

# Dev artifacts
*.bak
audit_*.json
audit_*.txt
audit_*.js
packs/src/archive/

# Agent handoff specs (ephemeral — see DEV_PROTOCOLS.md §30)
.cursor/
CURSOR_TASK_*
CURSOR_SPEC_*
CURSOR_PLAN_*

BACKLOG.md
ITEM_DESIGN_GUIDE.md

## tests/ and vitest.config.* are un-ignored so regression tests
## can be committed on coverage branches. The private ionrift-testharness
## still runs its own suite; these are complementary.
# tests/
# vitest.config.*

# Build output (filtered manifest for release)
.build/

# Dev composition profiles (local only)
dev-profiles.json
packs/.staging/
ionrift-respite.lock

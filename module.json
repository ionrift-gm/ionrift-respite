{
    "id": "ionrift-respite",
    "title": "Ionrift Respite",
    "description": "Structured rest phases for DnD 5e. Replaces the default rest dialog with a guided flow where players self-serve their downtime needs - identifying magic items, attuning gear, copying spells, crafting arrows - while the GM runs terrain-driven encounters and events. 30+ events across 6 terrains, each with multiple outcome tiers, collected over years of running a primitive version of this module at the table.",
    "bugs": "https://discord.gg/vFGXf7Fncj",
    "version": "1.0.3",
    "url": "https://github.com/ionrift-gm/ionrift-respite",
    "manifest": "https://github.com/ionrift-gm/ionrift-respite/releases/latest/download/module.json",
    "readme": "https://raw.githubusercontent.com/ionrift-gm/ionrift-respite/main/README.md",
    "download": "https://github.com/ionrift-gm/ionrift-respite/releases/download/v1.0.3/module.zip",
    "compatibility": {
        "minimum": "12",
        "verified": "13"
    },
    "esmodules": [
        "scripts/module.js"
    ],
    "packs": [
        {
            "name": "respite-items",
            "label": "Respite Items",
